---
const navItems = [
  { name: 'MAIN', href: '/' },
  { name: 'HOBBIES', href: '/hobbies' },
  { name: 'VISITOR GALLERY', href: '/visitor-gallery' },
];
---

<header class="fixed top-0 left-0 right-0 z-50" style="background:#000000; border-bottom:2px solid var(--primary-green);">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="text-2xl font-black tracking-tighter hover:scale-110 transition-transform glow-text">
        EC<span style="color:rgba(0,255,65,0.4);">_</span>
      </a>
    </div>

    <div class="flex-1 flex justify-center">
      <span class="hidden md:block text-sm font-bold font-mono" style="color:rgba(0,255,65,0.4); letter-spacing:0.12em;">
        CREATIVE DEVELOPER — TURKEY
      </span>
    </div>

    <div class="flex items-center gap-4">
      <ul class="flex items-center gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link px-3 py-2 text-sm font-bold font-mono uppercase"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .nav-link {
    color: var(--primary-green);
    border: 1px solid transparent;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease,
                text-shadow 0.2s ease;
  }
  .nav-link:hover {
    background: var(--primary-green);
    color: #000;
    border-color: var(--primary-green);
    text-shadow: none;
  }
</style>
