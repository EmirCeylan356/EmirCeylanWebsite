---
const navItems = [
  { name: 'MAIN', href: '/' },
  { name: 'HOBBIES', href: '/hobbies' },
  { name: 'VISITOR GALLERY', href: '/visitor-gallery' },
];
---

<header class="fixed top-0 left-0 right-0 z-50" style="background:var(--bg-surface); border-bottom:1px solid var(--border-color);">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href="/" class="logo-mark text-2xl font-black tracking-tighter transition-all" style="font-family:'Space Grotesk'; color:var(--accent);">
        EC<span style="color:var(--border-color);">_</span>
      </a>
    </div>

    <div class="flex-1 flex justify-center">
      <span class="hidden md:block text-xs font-bold font-mono" style="color:var(--text-secondary); letter-spacing:0.14em;">
        CREATIVE DEVELOPER — TURKEY
      </span>
    </div>

    <div class="flex items-center gap-4">
      <ul class="flex items-center gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link px-3 py-2 text-xs font-bold font-mono uppercase tracking-wider"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .logo-mark {
    text-shadow: 0 0 8px rgba(214,255,0,0.35);
    transition: text-shadow 0.2s ease;
  }
  .logo-mark:hover {
    text-shadow: 0 0 16px rgba(214,255,0,0.6);
  }

  .nav-link {
    color: var(--text-secondary);
    border: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    clip-path: polygon(6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%, 0 6px);
  }
  .nav-link:hover {
    color: #000;
    background: var(--accent);
    border-color: var(--accent);
  }
</style>
