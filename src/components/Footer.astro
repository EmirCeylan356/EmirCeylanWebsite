---
const socials = [
  { name: 'GITHUB', url: 'https://github.com/Riwex', short: '/Riwex' },
  { name: 'LINKEDIN', url: 'https://linkedin.com/in/emirceylan', short: '/in/emirceylan' },
  { name: 'EMAIL', url: 'mailto:emir.ceylan@sabanciuniv.edu', short: 'emir.ceylan@sabanciuniv.edu' },
];
---

<footer id="contact" class="bg-black text-white py-12 border-t-4 border-black">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="text-5xl md:text-7xl font-black mb-4 kinetic-text">
          LET'S<span class="text-[#f40c3f]">_</span>CONNECT
        </h2>
        <p class="text-lg font-bold text-gray-400">
          Have a project in mind or just want to chat?
        </p>
      </div>
      
      <div class="flex flex-col gap-5">
        <a 
          href="mailto:emir.ceylan@sabanciuniv.edu" 
          class="inline-flex items-center justify-center px-6 py-4 bg-[#f40c3f] text-white font-bold text-lg border-:bg-white hover:text4 border-white hover-black transition-all hover:shadow-[8px_8px_0px_#fff]"
        >
          GET IN TOUCH →
        </a>
        
        <div class="flex flex-col gap-2">
          {socials.map((social) => (
            <div class="flex items-center gap-3">
              <a 
                href={social.url}
                target="_blank"
                class="px-4 py-2 border-2 border-white font-bold hover:bg-white hover:text-black transition-colors text-sm whitespace-nowrap"
              >
                {social.name}
              </a>
              <span class="text-gray-500 font-mono text-sm truncate">{social.short}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Binary decoration -->
    <div class="mt-12 py-3 binary-border text-center">
      <p class="font-mono text-xs text-gray-500">
        01000011 01010011 01010011 00100000 01010001 01010100 01010100 01000101 01001110 01010100
      </p>
    </div>
    
    <div class="mt-6 text-center">
      <p class="font-bold text-gray-500">© {new Date().getFullYear()} EMİR CEYLAN. ALL RIGHTS RESERVED.</p>
    </div>
  </div>
</footer>
