---
const socials = [
  { name: 'GITHUB',   url: 'https://github.com/Riwex',                       short: '/Riwex' },
  { name: 'LINKEDIN', url: 'https://linkedin.com/in/emirceylan',              short: '/in/emirceylan' },
  { name: 'EMAIL',    url: 'mailto:emir.ceylan@sabanciuniv.edu',              short: 'emir.ceylan@sabanciuniv.edu' },
];
---

<footer id="contact" class="py-12" style="background:var(--bg-surface); border-top:1px solid var(--border-color);">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid md:grid-cols-2 gap-10 items-center">

      <div>
        <p class="text-xs font-mono mb-3" style="color:var(--text-secondary); letter-spacing:0.15em;">04 / CONTACT</p>
        <h2 class="text-5xl md:text-7xl font-black mb-4 kinetic-text" style="color:var(--text-primary);">
          LET'S<span style="color:var(--accent);">_</span>CONNECT
        </h2>
        <p class="text-sm font-mono" style="color:var(--text-secondary);">
          Have a project in mind or just want to chat?
        </p>
      </div>

      <div class="flex flex-col gap-5">
        <a
          href="mailto:emir.ceylan@sabanciuniv.edu"
          class="footer-cta inline-flex items-center justify-center px-6 py-4 font-bold text-sm font-mono cut-corner"
          style="background:var(--accent); color:#000; border:1px solid var(--accent); letter-spacing:0.08em;"
        >
          GET IN TOUCH →
        </a>

        <div class="flex flex-col gap-2">
          {socials.map((social) => (
            <div class="flex items-center gap-3">
              <a
                href={social.url}
                target="_blank"
                class="social-link px-4 py-2 font-bold font-mono text-xs whitespace-nowrap cut-corner-sm"
                style="border:1px solid var(--border-color); color:var(--text-secondary); letter-spacing:0.08em;"
              >
                {social.name}
              </a>
              <span class="font-mono text-xs truncate" style="color:var(--text-secondary); opacity:0.5;">{social.short}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-12" style="height:1px; background:var(--border-color);"></div>

    <div class="mt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
      <p class="font-mono text-xs hidden sm:block" style="color:var(--text-secondary); opacity:0.4;">
        01000011 01010011 00100000 01010011 01010100 01010101 01000100 01000101 01001110 01010100
      </p>
      <p class="font-mono text-xs" style="color:var(--text-secondary); opacity:0.4;">
        © {new Date().getFullYear()} EMİR CEYLAN
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-cta {
    transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
  }
  .footer-cta:hover {
    background: transparent;
    color: var(--accent);
    box-shadow: 0 0 16px var(--accent-glow);
  }
  .social-link {
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }
  .social-link:hover {
    border-color: var(--accent);
    color: #000;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }
</style>
