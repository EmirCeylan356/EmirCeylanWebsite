</Layout>

<style>
  .marquee-container {
    overflow: hidden;
    white-space: nowrap;
  }
  
  .marquee-content {
    display: inline-block;
    animation: marquee 15s linear infinite;
  }
  
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Binary float animation */
  .binary-float {
    position: absolute;
    animation: binaryFade 8s ease-in-out infinite;
    opacity: 0;
  }
  
  .binary-1 { top: 15%; left: 3%;  animation-delay: 0s; }
  .binary-2 { top: 50%; right: 3%; animation-delay: 3s; }
  .binary-3 { bottom: 25%; left: 10%; animation-delay: 6s; }
  .binary-4 { top: 70%; left: 8%;  animation-delay: 1s; }
  .binary-5 { top: 30%; right: 8%; animation-delay: 4s; }
  .binary-6 { top: 20%; right: 18%; animation-delay: 2s; }
  .binary-7 { bottom: 15%; right: 12%; animation-delay: 5s; }
  
  @keyframes binaryFade {
    0%, 100% { opacity: 0; transform: translateY(20px); }
    15%, 85% { opacity: 0.25; transform: translateY(0); }
  }

  /* Work card base */
  .work-card {
    overflow: hidden;
  }

  /* Work card hover */
  .work-card::after {
    content: 'Click for details →';
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    font-size: 0.75rem;
    font-weight: bold;
    opacity: 0;
    transition: opacity 0.3s;
  }
  
  .work-card:hover::after {
    opacity: 1;
  }

  /* WIP work card */
  .work-card.wip-hover {
    background-color: black !important;
    color: white !important;
  }
  
  .work-card.wip-hover .text-xs,
  .work-card.wip-hover .text-sm,
  .work-card.wip-hover .font-bold,
  .work-card.wip-hover .work-title {
    opacity: 0;
  }
  
  .work-card.wip-hover::before {
    content: 'Work In Progress...';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-weight: bold;
    font-size: 1.25rem;
  }

  /* Popup styles */
  #work-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }
  
  #work-popup.active {
    display: flex;
  }
  
  #work-popup.active .popup-content {
    animation: popupSlide 0.4s ease-out;
  }
  
  @keyframes popupSlide {
    from {
      transform: translateY(-50px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Skill accordion */
  .skill-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .skill-accordion.open .skill-body {
    max-height: 400px;
  }

  .skill-arrow {
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .skill-accordion.open .skill-arrow {
    transform: rotate(45deg);
  }

  /* Work content styling */
  .work-content h2 {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  
  .work-content p {
    margin-bottom: 0.75rem;
  }
  
  .work-content a.linkedin-link {
    color: #0077b5;
    text-decoration: underline;
    font-weight: bold;
  }
</style>

<script>
  // Work card click handlers
  const workCards = document.querySelectorAll('.work-card');
  const popup = document.getElementById('work-popup');
  const popupTitle = document.getElementById('popup-title');
  const popupBody = document.getElementById('popup-body');
  const popupClose = document.getElementById('popup-close');
  const popupOverlay = document.querySelector('.popup-overlay');
  
  workCards.forEach(card => {
    const isWip = card.getAttribute('data-is-wip') === 'true';
    const workId = card.getAttribute('data-work-id');
    const details = card.querySelector('.work-details');
    
    if (isWip) {
      // WIP - hover and click behavior
      let wipTimeout;
      
      card.addEventListener('mouseenter', () => {
        if (!card.classList.contains('clicked')) {
          card.classList.add('wip-hover');
        }
      });
      
      card.addEventListener('mouseleave', () => {
        if (!card.classList.contains('clicked')) {
          card.classList.remove('wip-hover');
        }
      });
      
      card.addEventListener('click', () => {
        if (card.classList.contains('clicked')) return;
        
        card.classList.add('clicked');
        card.classList.add('wip-hover');
        
        // Reset after 3 seconds
        setTimeout(() => {
          card.classList.remove('clicked');
          card.classList.remove('wip-hover');
        }, 3000);
      });
    } else {
      // Normal - show popup
      card.addEventListener('click', () => {
        const title = card.querySelector('.work-title').textContent;
        const content = details.innerHTML;

        popupTitle.textContent = title;
        popupBody.innerHTML = content;
        popup.classList.add('active');
        popup.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });
    }
  });
  
  // Red bubble splatter on close
  function createSplatter(originX, originY) {
    const count = 14;
    for (let i = 0; i < count; i++) {
      const blob = document.createElement('div');
      const angle = (i / count) * Math.PI * 2 + (Math.random() - 0.5) * 0.8;
      const distance = 70 + Math.random() * 130;
      const size = 7 + Math.random() * 16;
      blob.style.cssText = `
        position: fixed;
        width: ${size}px;
        height: ${size}px;
        background: #f40c3f;
        border-radius: 50%;
        left: ${originX}px;
        top: ${originY}px;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
      `;
      document.body.appendChild(blob);
      const tx = Math.cos(angle) * distance;
      const ty = Math.sin(angle) * distance;
      if (typeof gsap !== 'undefined') {
        gsap.to(blob, {
          x: tx, y: ty,
          opacity: 0,
          scale: 0.1,
          duration: 0.45 + Math.random() * 0.3,
          ease: 'power3.out',
          onComplete: () => blob.remove(),
        });
      } else {
        setTimeout(() => blob.remove(), 600);
      }
    }
  }

  // Close popup
  function closePopup() {
    const rect = popupClose.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    createSplatter(cx, cy);

    const popupContent = document.querySelector('.popup-content');
    if (typeof gsap !== 'undefined' && popupContent) {
      gsap.killTweensOf(popupContent);
      gsap.to(popupContent, {
        rotation: 30,
        y: 80,
        opacity: 0,
        duration: 0.38,
        ease: 'power2.in',
        transformOrigin: 'center top',
        onComplete: () => {
          popup.classList.remove('active');
          popup.style.display = 'none';
          document.body.style.overflow = '';
          gsap.set(popupContent, { rotation: 0, y: 0, opacity: 1 });
        },
      });
    } else {
      popup.classList.remove('active');
      popup.style.display = 'none';
      document.body.style.overflow = '';
    }
  }

  popupClose.addEventListener('click', closePopup);
  popupOverlay.addEventListener('click', closePopup);

  // Skill accordion toggle
  document.querySelectorAll('.skill-accordion').forEach((accordion) => {
    accordion.addEventListener('click', () => {
      accordion.classList.toggle('open');
    });
  });

  // Binary teleport: reposition to random location on each animation cycle
  document.querySelectorAll('.binary-float').forEach((el) => {
    el.addEventListener('animationiteration', () => {
      el.style.top = (Math.random() * 80 + 5) + '%';
      el.style.left = (Math.random() * 85 + 5) + '%';
      el.style.right = 'auto';
      el.style.bottom = 'auto';
    });
  });
</script>
