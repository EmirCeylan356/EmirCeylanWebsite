---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const works = [
  {
    id: 1,
    period: '2026 — PRESENT',
    title: 'TEACHING ASSISTANT',
    subtitle: 'DSA 210: Data Science',
    description: 'Assisting Prof. Oznur Tastan and Ozgun Yargi. Mentoring students in ML.',
    details: `<p>Currently serving as a Teaching Assistant for DSA 210, I support students in mastering the foundational pillars of data science, including computational thinking, machine learning, and statistical inference.</p>
<p>I lead weekly office hours to provide hands-on guidance with real-world data tools and techniques, helping students navigate complex topics such as exploratory data analysis (EDA), data privacy (K-anonymity), and predictive modeling.</p>
<p>By bridging the gap between theoretical coursework and practical application, I assist my peers in developing the technical rigor necessary to solve diverse problems across healthcare, business, and social domains.</p>`,
    link: '',
  },
  {
    id: 2,
    period: '2025 — 2026 Fall',
    title: 'UNDERGRADUATE RESEARCHER',
    subtitle: 'PURE - Sabancı University',
    description: 'Collaborating with Prof. Polat Göktaş on Explainable AI in Healthcare.',
    details: `<p>During the Fall 2025-26 term, I conducted a comprehensive scientometric study analyzing over 250 global publications to map the evolving landscape of AI in healthcare.</p>
<p>My research focused on the critical intersection of <strong>explainable AI (XAI)</strong>, clinician trust, and regulatory governance.</p>
<p>By utilizing literature mining and network analysis, I identified key knowledge gaps and emerging trends necessary for developing trustworthy and clinically deployable AI systems.</p>
<p><a href="https://www.linkedin.com/posts/emir-ceylan-student-482775332_pure-undergraduateresearch-ai-ugcPost-7433604110798544896-2cDY" target="_blank" class="linkedin-link">The LinkedIn Post</a></p>`,
    link: 'https://www.linkedin.com/posts/emir-ceylan-student-482775332_pure-undergraduateresearch-ai-ugcPost-7433604110798544896-2cDY',
  },
  {
    id: 3,
    period: '2026 — PRESENT',
    title: 'PROJECT LEAD',
    subtitle: 'Teknofest Medical AI',
    description: 'Leading multidisciplinary team to develop multimodal diagnostic tools.',
    details: `<p>As the Project Lead for <strong>DeepMyelinAI</strong>, I head a multidisciplinary team developing an explainable AI-based clinical decision support system for <strong>Multiple Sclerosis (MS)</strong>.</p>
<p>I oversee the integration of multimodal data—including CSF biomarkers, genetic risk profiles, and longitudinal clinical disability scores—into a unified machine learning framework designed for early diagnosis and disability progression prediction.</p>
<p>My role involves managing the full development lifecycle: from engineering <strong>Temporal Transformer</strong> architectures for longitudinal tracking to implementing <strong>XAI layers (SHAP/LIME)</strong> to ensure clinical transparency.</p>
<p>By aligning our system with the <strong>2024 McDonald Criteria</strong>, I ensure our technical solutions meet rigorous medical standards, ultimately aiming to provide neurologists with actionable, data-driven insights.</p>`,
    link: '',
  },
  {
    id: 4,
    period: 'SUMMER 2026',
    title: 'MACHINE LEARNING INTERN',
    subtitle: 'Amsterdam UMC',
    description: 'Developing AI models to reduce unnecessary sepsis testing in ER settings.',
    details: `<p>Developing AI models to reduce unnecessary sepsis testing in Emergency Room settings.</p>
<p>Focusing on clinical efficiency by optimizing diagnostic triggers to reduce physician workload and healthcare costs.</p>
<p><em>Work In Progress...</em></p>`,
    link: '',
    isWip: true,
  },
  {
    id: 5,
    period: '2024 — 2025',
    title: 'ML DEVELOPER',
    subtitle: 'Osteogenesis Imperfecta (OI) Pathogenicity Prediction',
    description: 'ENS 210: Bioinformatics Project. Surpassing SIFT and general-purpose diagnostic tools.',
    details: `<p>In this project, I developed a high-precision machine learning model to predict the pathogenicity of variants in the <strong>COL1A1</strong> and <strong>COL1A2</strong> genes, which are primary causes of Osteogenesis Imperfecta (OI) — a rare genetic disorder affecting bone fragility.</p>
<p>Using a curated dataset from ClinVar, I engineered biologically meaningful features and trained multiple classifiers, ultimately achieving performance that surpassed established tools such as <strong>SIFT</strong> and general-purpose diagnostic predictors.</p>
<p>The pipeline included variant filtering, feature selection, cross-validation, and interpretability analysis — resulting in a reproducible and clinically relevant bioinformatics workflow.</p>
<p><a href="https://github.com/EmirC356/ENS210_Project" target="_blank" class="linkedin-link">View on GitHub →</a></p>`,
    link: 'https://github.com/EmirC356/ENS210_Project',
  },
  {
    id: 6,
    period: '2024 — 2025',
    title: 'RESEARCH CONTRIBUTOR',
    subtitle: 'AI-Engineered Enzymes for Polymer Digestion',
    description: 'Molecular Biology Research. Optimizing PETase enzymes for sustainable plastic degradation.',
    details: `<p>Under the supervision of <strong>İleyna Sevde Üvak</strong>, I contributed to a molecular biology research project focused on computationally optimizing <strong>PETase enzymes</strong> for efficient degradation of PET plastics.</p>
<p>I applied computational biology techniques — including protein structure analysis and mutation screening — to identify candidate enzyme variants with improved thermostability and catalytic efficiency.</p>
<p>This work sits at the intersection of synthetic biology and environmental sustainability, exploring how AI-driven enzyme engineering can accelerate the development of biological solutions to plastic pollution.</p>`,
    link: '',
  },
  {
    id: 7,
    period: '2025 — PRESENT',
    title: 'BOARD MEMBER & HEAD OF BIOTECH',
    subtitle: 'Sabancı University Deep Technologies Club',
    description: 'Leading the BioTech division and fostering a high-tech community through hands-on events.',
    details: `<p>As a Board Member and the Head of the <strong>BioTech Division</strong> at Sabancı University's Deep Technologies Club, I lead initiatives that bridge cutting-edge biology with emerging technology.</p>
<p>My role involves organizing workshops, seminars, and hands-on projects that expose students to topics like CRISPR, synthetic biology, computational genomics, and AI-driven drug discovery.</p>
<p>I also coordinate interdisciplinary collaborations between CS, biology, and engineering students — cultivating a community of innovators passionate about the future of life sciences and deep tech.</p>`,
    link: '',
  },
];

const skillCategories = [
  { title: 'PROGRAMMING',    items: ['Python', 'C++'] },
  { title: 'LIBRARIES',      items: ['NumPy', 'pandas', 'matplotlib', 'scikit-learn', 'Biopython'] },
  { title: 'TOOLS',          items: ['Git/GitHub', 'Jupyter Notebook', 'Ubuntu', 'Claude Code', 'Clawbot'] },
  { title: 'LANGUAGES',      items: ['English (Fluent, C1)', 'Turkish (Native)'] },
  { title: 'CREATIVE SKILLS',items: ['Adobe Photoshop', 'Adobe Premiere Pro', 'Digital Illustration', 'Painting', 'Drawing'] },
  { title: 'INTERESTS',      items: ['Bioinformatics', 'AI in Medicine', 'Chess', 'Archery', 'Jiu-Jitsu', 'Fitness', 'Tattoo Design'] },
];
---

<Layout title="EMIR CEYLAN — Creative Developer">
  <Header />

  <main>
    <!-- ═══ HERO ══════════════════════════════════════════════════════════════ -->
    <section class="min-h-screen flex items-center justify-center px-4 pt-20 pb-10 relative overflow-hidden">
      <!-- Scanline sweep effect -->
      <div class="hero-scanline"></div>

      <div class="max-w-5xl mx-auto text-center relative z-10">

        <!-- System ID tag -->
        <div class="hero-tag inline-flex items-center gap-3 mb-8 px-4 py-2 font-mono text-xs"
          style="background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-secondary); letter-spacing:0.14em; opacity:0;">
          <span style="width:6px; height:6px; border-radius:50%; background:var(--accent); display:inline-block; box-shadow:0 0 6px var(--accent);"></span>
          SYS_ID: EC_2027 — ISTANBUL / TR — ONLINE
        </div>

        <div class="hero-name-frame">
          <h1 class="kinetic-text font-black -mt-2 leading-none" style="font-size:clamp(5rem,18vw,14rem); color:var(--text-primary);">
            <span class="hero-line-1">EMİR</span><br/>
            <span class="hero-line-2 glitch-accent" style="color:var(--accent);">CEYLAN</span>
          </h1>
        </div>

        <p class="hero-subtitle text-sm md:text-base font-bold max-w-2xl mx-auto mb-10 font-mono px-5 py-3 mt-4"
          style="background:var(--bg-surface); color:var(--text-secondary); border:1px solid var(--border-color); letter-spacing:0.1em; display:inline-block; opacity:0;">
          CS STUDENT — AI FOR HEALTHCARE
        </p>

        <div class="hero-ctas flex flex-wrap gap-4 justify-center" style="opacity:0;">
          <a href="#work" class="hero-btn-primary px-8 py-4 font-bold text-sm font-mono cut-corner"
            style="background:var(--accent); color:#000; border:1px solid var(--accent); letter-spacing:0.1em;">
            MY WORK →
          </a>
          <a href="#contact" class="hero-btn-outline px-8 py-4 font-bold text-sm font-mono cut-corner"
            style="background:transparent; color:var(--text-primary); border:1px solid var(--border-color); letter-spacing:0.1em;">
            CONTACT
          </a>
        </div>

        <div class="hero-scroll-hint mt-16" style="color:var(--text-secondary); opacity:0;">
          <span class="text-2xl animate-bounce block">↓</span>
        </div>
      </div>
    </section>

    <!-- ═══ MARQUEE BAR ═══════════════════════════════════════════════════════ -->
    <section class="py-3 overflow-hidden" style="background:var(--bg-surface); border-top:1px solid var(--border-color); border-bottom:1px solid var(--border-color);">
      <div class="marquee-container">
        <div class="marquee-content font-mono">
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Medical AI Specialist</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Data Scientist</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Machine Learning Researcher</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Sabancı University TA</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Team Leader</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ XAI Enthusiast</span>
          <span class="font-bold text-xs mx-10" style="color:var(--accent); letter-spacing:0.1em;">  ◆ Artist</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Medical AI Specialist</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Data Scientist</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Machine Learning Researcher</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Sabancı University TA</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ Team Leader</span>
          <span class="font-bold text-xs mx-10" style="color:var(--text-secondary); letter-spacing:0.1em;">  ◆ XAI Enthusiast</span>
          <span class="font-bold text-xs mx-10" style="color:var(--accent); letter-spacing:0.1em;">  ◆ Artist</span>
        </div>
      </div>
    </section>

    <!-- ═══ ABOUT ══════════════════════════════════════════════════════════════ -->
    <section id="about" class="about-section py-20 px-6 md:px-12">
      <div class="max-w-7xl mx-auto">

        <div class="grid md:grid-cols-3 gap-8 items-start">

          <!-- Left: Section label panel -->
          <div class="panel about-label-panel">
            <p class="font-mono text-xs mb-4" style="color:var(--text-secondary); letter-spacing:0.15em;">01 / ABOUT</p>
            <div class="font-black leading-none" style="font-family:'Syne'; font-size:clamp(56px,8vw,96px); color:var(--text-primary); line-height:0.88;">
              ABOUT
            </div>
            <div class="mt-8" style="border-top:1px solid var(--border-color); padding-top:20px;">
              <p class="font-mono text-xs mb-1" style="color:var(--text-secondary); letter-spacing:0.12em;">SYSTEM PROFILE</p>
              <p class="font-mono text-xs mt-2" style="color:var(--text-secondary); opacity:0.6; letter-spacing:0.08em;">CLASS / 2027</p>
              <p class="font-mono text-xs mt-1" style="color:var(--text-secondary); opacity:0.6; letter-spacing:0.08em;">NODE / ISTANBUL, TR</p>
            </div>

            <!-- Stats inside left panel -->
            <div class="mt-8 flex flex-col gap-4" style="border-top:1px solid var(--border-color); padding-top:20px;">
              <div>
                <div class="stat-num font-black text-2xl" style="color:var(--accent);">2027</div>
                <div class="font-mono text-xs mt-1" style="color:var(--text-secondary); letter-spacing:0.1em;">EXPECTED GRAD</div>
              </div>
              <div>
                <div class="stat-num font-black text-2xl" style="color:var(--accent);">07+</div>
                <div class="font-mono text-xs mt-1" style="color:var(--text-secondary); letter-spacing:0.1em;">PROJECTS</div>
              </div>
              <div>
                <div class="stat-num font-black text-2xl" style="color:var(--accent);">AI</div>
                <div class="font-mono text-xs mt-1" style="color:var(--text-secondary); letter-spacing:0.1em;">SPECIALIZATION</div>
              </div>
            </div>
          </div>

          <!-- Right: Narrative panel -->
          <div class="md:col-span-2 panel">
            <p class="font-mono text-xs mb-6" style="color:var(--text-secondary); letter-spacing:0.12em;">PROFILE_NARRATIVE.txt</p>
            <p class="text-xl md:text-2xl font-bold mb-6" style="color:var(--text-primary); line-height:1.6;">
              Computer Science student at
              <span style="color:var(--accent);">Sabancı University</span>
              passionate about AI applications in healthcare. Building the future of medical AI.
            </p>
            <p class="text-base mb-4" style="color:var(--text-secondary); line-height:1.7;">
              Driven by the potential of AI to bridge gaps in modern medicine, I focus on developing intelligent systems that are as ethical as they are efficient. My work at Sabancı University centers on collaborating with professors and fellow students to build projects that connect deep CS knowledge with complex medical hurdles to find practical, scalable solutions.
            </p>
            <p class="text-base" style="color:var(--text-secondary); line-height:1.7;">
              Outside of the lab, I balance the logic of neural networks with painting — a creative outlet that allows me to view technical challenges through a more expressive, lateral-thinking lens.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ WORK ═══════════════════════════════════════════════════════════════ -->
    <section id="work" class="py-16 px-6 md:px-12" style="border-top:1px solid var(--border-color); border-bottom:1px solid var(--border-color);">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end gap-4 mb-10">
          <p class="font-mono text-xs" style="color:var(--text-secondary); letter-spacing:0.15em; align-self:center;">02 /</p>
          <h2 class="text-5xl md:text-7xl font-black kinetic-text work-heading" style="color:var(--text-primary);">WORK</h2>
          <div class="section-line flex-1 h-px" style="background:var(--border-color);"></div>
          <span class="text-xl font-black font-mono" style="color:var(--text-secondary);">/07</span>
        </div>

        <div class="grid md:grid-cols-2 gap-4">
          {works.map((work) => (
            <div
              class="work-card relative p-6 cursor-pointer"
              data-work-id={work.id}
              data-is-wip={work.isWip ? 'true' : 'false'}
              style="background:var(--bg-surface); border:1px solid var(--border-color);"
            >
              <p class="text-xs font-mono font-bold mb-2" style="color:var(--text-secondary); letter-spacing:0.12em;">{work.period}</p>
              <span class="work-title text-lg font-black mb-1 block" style="color:var(--text-primary);">{work.title}</span>
              <p class="font-bold mb-3 text-sm" style="color:var(--accent);">{work.subtitle}</p>
              <p class="text-sm" style="color:var(--text-secondary); opacity:0.9;">{work.description}</p>

              <div class="work-details hidden">
                <div class="work-content text-sm" set:html={work.details} />
              </div>
            </div>
          ))}

          <!-- Permanent WIP placeholder -->
          <div class="relative p-6 flex items-center justify-center select-none"
            style="border:1px dashed var(--border-color); opacity:0.5; background:var(--bg-surface);">
            <div class="text-center">
              <p class="text-xs font-mono font-bold mb-2" style="color:var(--text-secondary); letter-spacing:0.12em;">COMING SOON</p>
              <span class="text-lg font-black mb-1 block" style="color:var(--text-primary);">WORK IN PROGRESS</span>
              <p class="text-sm" style="color:var(--text-secondary);">Something new is being built...</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ SKILLS ════════════════════════════════════════════════════════════ -->
    <section id="skills" class="py-16 px-6 md:px-12">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end gap-4 mb-10">
          <p class="font-mono text-xs" style="color:var(--text-secondary); letter-spacing:0.15em; align-self:center;">03 /</p>
          <h2 class="text-5xl md:text-7xl font-black kinetic-text skills-heading" style="color:var(--text-primary);">SKILLS</h2>
          <div class="section-line flex-1 h-px" style="background:var(--border-color);"></div>
          <span class="text-xl font-black font-mono" style="color:var(--text-secondary);">/06</span>
        </div>

        <div class="flex flex-col max-w-2xl" style="border:1px solid var(--border-color);">
          {skillCategories.map((category) => (
            <div class="skill-box skill-accordion cursor-pointer" style="border:none; border-bottom:1px solid var(--border-color);">
              <div class="skill-header px-5 py-4 flex justify-between items-center transition-colors duration-200">
                <span class="font-black text-sm font-mono tracking-wider">{category.title}</span>
                <span class="skill-arrow font-black text-xl leading-none" style="color:var(--accent);">+</span>
              </div>
              <div class="skill-body">
                <div class="flex flex-col" style="border-top:1px solid var(--border-color);">
                  {category.items.map((item) => (
                    <span class="px-5 py-2 text-sm font-mono" style="color:var(--text-secondary); border-bottom:1px solid var(--border-color);">{item}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- ═══ WORK POPUP MODAL ══════════════════════════════════════════════════ -->
  <div id="work-popup" class="fixed inset-0 z-[100] flex items-start justify-center p-20">
    <div class="popup-overlay absolute inset-0" style="background:rgba(0,0,0,0.85);"></div>
    <div class="popup-content relative z-[101] w-full max-w-2xl max-h-[70vh] overflow-y-auto"
      style="background:var(--bg-surface); border:1px solid var(--border-color);">
      <div class="popup-header px-6 py-4 flex justify-between items-center"
        style="background:var(--bg-elevated); border-bottom:1px solid var(--border-color);">
        <span id="popup-title" class="font-black text-lg" style="font-family:'Syne'; color:var(--text-primary);"></span>
        <button id="popup-close" class="font-bold text-2xl transition-all hover:opacity-60"
          style="color:var(--accent); background:none; border:none; cursor:pointer; line-height:1;">×</button>
      </div>
      <div id="popup-body" class="p-6 text-sm leading-relaxed popup-body-text"></div>
    </div>
  </div>
</Layout>

<style>
  /* ── Marquee ─────────────────────────────────────────────────────────────── */
  .marquee-container { overflow: hidden; white-space: nowrap; }
  .marquee-content { display: inline-block; animation: marquee 20s linear infinite; }
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Hero buttons ────────────────────────────────────────────────────────── */
  .hero-btn-primary {
    transition: background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
  }
  .hero-btn-primary:hover {
    background: transparent !important;
    color: var(--accent) !important;
    border-color: var(--accent) !important;
    box-shadow: 0 0 16px var(--accent-glow);
  }
  .hero-btn-outline {
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .hero-btn-outline:hover {
    background: var(--accent) !important;
    color: #000 !important;
    border-color: var(--accent) !important;
    box-shadow: 0 0 16px var(--accent-glow);
  }

  /* ── About section ───────────────────────────────────────────────────────── */
  .about-section { background: var(--bg-base); }
  .about-label-panel { min-height: 100%; }

  /* ── Work card hover hint ────────────────────────────────────────────────── */
  .work-card::after {
    content: 'CLICK FOR DETAILS →';
    position: absolute;
    bottom: 1rem; right: 1rem;
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-secondary);
    letter-spacing: 0.1em;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .work-card:hover::after { opacity: 0.6; }

  .work-card.wip-hover {
    border-color: var(--accent) !important;
    box-shadow: 0 0 12px var(--accent-glow) !important;
  }
  .work-card.wip-hover .text-xs,
  .work-card.wip-hover .text-sm,
  .work-card.wip-hover .font-bold,
  .work-card.wip-hover .work-title { opacity: 0; }
  .work-card.wip-hover::before {
    content: 'WORK IN PROGRESS...';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-weight: 700;
    font-size: 0.85rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent);
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  /* ── Popup ───────────────────────────────────────────────────────────────── */
  #work-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }
  #work-popup.active { display: flex; }
  #work-popup.active .popup-content { animation: popupSlide 0.35s cubic-bezier(0.16,1,0.3,1); }

  @keyframes popupSlide {
    from { transform: translateY(-30px); opacity: 0; }
    to   { transform: translateY(0);     opacity: 1; }
  }

  .popup-body-text { color: var(--text-secondary); }
  .popup-body-text p { margin-bottom: 0.75rem; }
  .popup-body-text strong { color: var(--text-primary); }
  .popup-body-text a { color: var(--accent); }

  /* ── Skill accordion ─────────────────────────────────────────────────────── */
  .skill-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .skill-accordion.open .skill-body { max-height: 500px; }
  .skill-accordion:last-child { border-bottom: none !important; }
  .skill-arrow {
    display: inline-block;
    transition: transform 0.3s ease;
  }
  .skill-accordion.open .skill-arrow { transform: rotate(45deg); }
</style>

<script>
  // ── Work card click handlers ────────────────────────────────────────────────
  const workCards   = document.querySelectorAll('.work-card');
  const popup       = document.getElementById('work-popup');
  const popupTitle  = document.getElementById('popup-title');
  const popupBody   = document.getElementById('popup-body');
  const popupClose  = document.getElementById('popup-close');
  const popupOverlay = document.querySelector('.popup-overlay');

  workCards.forEach(card => {
    const isWip   = card.getAttribute('data-is-wip') === 'true';
    const details = card.querySelector('.work-details');

    if (isWip) {
      card.addEventListener('mouseenter', () => { if (!card.classList.contains('clicked')) card.classList.add('wip-hover'); });
      card.addEventListener('mouseleave', () => { if (!card.classList.contains('clicked')) card.classList.remove('wip-hover'); });
      card.addEventListener('click', () => {
        if (card.classList.contains('clicked')) return;
        card.classList.add('clicked', 'wip-hover');
        setTimeout(() => card.classList.remove('clicked', 'wip-hover'), 3000);
      });
    } else {
      card.addEventListener('click', () => {
        const title   = card.querySelector('.work-title').textContent;
        const content = details.innerHTML;
        popupTitle.textContent = title;
        popupBody.innerHTML    = content;
        popup.classList.add('active');
        popup.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });
    }
  });

  // ── Green splatter on close ─────────────────────────────────────────────────
  function createSplatter(originX, originY) {
    const count = 14;
    for (let i = 0; i < count; i++) {
      const blob     = document.createElement('div');
      const angle    = (i / count) * Math.PI * 2 + (Math.random() - 0.5) * 0.8;
      const distance = 70 + Math.random() * 130;
      const size     = 7 + Math.random() * 16;
      blob.style.cssText = `
        position: fixed;
        width: ${size}px;
        height: ${size}px;
        background: #D6FF00;
        border-radius: 50%;
        left: ${originX}px;
        top: ${originY}px;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 8px rgba(214,255,0,0.6);
      `;
      document.body.appendChild(blob);
      const tx = Math.cos(angle) * distance;
      const ty = Math.sin(angle) * distance;
      if (typeof gsap !== 'undefined') {
        gsap.to(blob, {
          x: tx, y: ty,
          opacity: 0, scale: 0.1,
          duration: 0.45 + Math.random() * 0.3,
          ease: 'power3.out',
          onComplete: () => blob.remove(),
        });
      } else {
        setTimeout(() => blob.remove(), 600);
      }
    }
  }

  function closePopup() {
    const rect         = popupClose.getBoundingClientRect();
    const popupContent = document.querySelector('.popup-content');
    createSplatter(rect.left + rect.width / 2, rect.top + rect.height / 2);
    if (typeof gsap !== 'undefined' && popupContent) {
      gsap.killTweensOf(popupContent);
      gsap.to(popupContent, {
        rotation: 30, y: 80, opacity: 0,
        duration: 0.38,
        ease: 'power2.in',
        transformOrigin: 'center top',
        onComplete: () => {
          popup.classList.remove('active');
          popup.style.display = 'none';
          document.body.style.overflow = '';
          gsap.set(popupContent, { rotation: 0, y: 0, opacity: 1 });
        },
      });
    } else {
      popup.classList.remove('active');
      popup.style.display = 'none';
      document.body.style.overflow = '';
    }
  }

  popupClose.addEventListener('click', closePopup);
  popupOverlay.addEventListener('click', closePopup);

  // ── Skill accordion ─────────────────────────────────────────────────────────
  document.querySelectorAll('.skill-accordion').forEach(accordion => {
    accordion.addEventListener('click', () => accordion.classList.toggle('open'));
  });

  // ── Binary float teleport ───────────────────────────────────────────────────
  document.querySelectorAll('.binary-float').forEach(el => {
    el.addEventListener('animationiteration', () => {
      el.style.top    = (Math.random() * 80 + 5) + '%';
      el.style.left   = (Math.random() * 85 + 5) + '%';
      el.style.right  = 'auto';
      el.style.bottom = 'auto';
    });
  });

  // ── GSAP Entrance + Scroll Animations ──────────────────────────────────────
  (function() {
    // Fallback: if GSAP doesn't load, reveal everything
    function revealAll() {
      document.querySelectorAll('.hero-tag, .hero-subtitle, .hero-ctas, .hero-scroll-hint').forEach(el => {
        el.style.opacity = '1';
      });
    }

    if (typeof gsap === 'undefined') { revealAll(); return; }

    // ── Character split utility ───────────────────────────────────────────
    function splitToChars(el) {
      if (!el) return [];
      const text = el.textContent;
      el.innerHTML = [...text].map(ch =>
        `<span class="hero-char">${ch === ' ' ? '\u00A0' : ch}</span>`
      ).join('');
      return Array.from(el.querySelectorAll('.hero-char'));
    }

    const line1  = document.querySelector('.hero-line-1');
    const chars1 = splitToChars(line1);

    // ── Hero entrance timeline ────────────────────────────────────────────
    const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

    tl.from('.hero-tag', {
        opacity: 0, y: -18, duration: 0.55,
        onComplete: () => { document.querySelector('.hero-tag').style.opacity = ''; }
      })
      .from(chars1, {
        opacity: 0,
        y: 90,
        rotationX: -70,
        stagger: 0.055,
        duration: 0.75,
        transformPerspective: 500,
        transformOrigin: 'bottom center',
      }, '-=0.25')
      .from('.hero-line-2', {
        opacity: 0,
        y: -70,
        rotationX: 60,
        duration: 0.75,
        transformPerspective: 500,
        transformOrigin: 'top center',
        onComplete: () => {
          // Activate corner brackets after name is revealed
          document.querySelector('.hero-name-frame')?.classList.add('framed');
        }
      }, '-=0.5')
      .from('.hero-subtitle', {
        opacity: 0, scaleX: 0.5, duration: 0.45,
        transformOrigin: 'center',
        onComplete: () => { document.querySelector('.hero-subtitle').style.opacity = ''; }
      }, '-=0.2')
      .from('.hero-ctas', {
        opacity: 0, y: 22, duration: 0.45,
        onComplete: () => { document.querySelector('.hero-ctas').style.opacity = ''; }
      }, '-=0.15')
      .from('.hero-scroll-hint', {
        opacity: 0, duration: 0.35,
        onComplete: () => { document.querySelector('.hero-scroll-hint').style.opacity = ''; }
      });

    // ── Section line grow ─────────────────────────────────────────────────
    gsap.utils.toArray('.section-line').forEach(line => {
      gsap.fromTo(line,
        { scaleX: 0, transformOrigin: 'left center' },
        {
          scaleX: 1,
          duration: 1,
          ease: 'power3.inOut',
          scrollTrigger: { trigger: line, start: 'top 85%' }
        }
      );
    });

    // ── About section reveal ──────────────────────────────────────────────
    gsap.from('#about .panel', {
      opacity: 0, y: 45, stagger: 0.15, duration: 0.7, ease: 'power3.out',
      scrollTrigger: { trigger: '#about', start: 'top 72%' }
    });

    gsap.from('.stat-num', {
      opacity: 0, scale: 0.4, duration: 0.55, stagger: 0.12, ease: 'back.out(1.7)',
      scrollTrigger: { trigger: '#about', start: 'top 65%' }
    });

    // ── Work section ──────────────────────────────────────────────────────
    gsap.from('.work-heading', {
      opacity: 0, x: -50, duration: 0.7, ease: 'power3.out',
      scrollTrigger: { trigger: '#work', start: 'top 78%' }
    });

    gsap.from('.work-card', {
      opacity: 0, y: 55, stagger: { amount: 0.7, from: 'start' },
      duration: 0.65, ease: 'power3.out',
      scrollTrigger: { trigger: '#work .grid', start: 'top 82%' }
    });

    // ── Skills section ────────────────────────────────────────────────────
    gsap.from('.skills-heading', {
      opacity: 0, x: -50, duration: 0.7, ease: 'power3.out',
      scrollTrigger: { trigger: '#skills', start: 'top 78%' }
    });

    gsap.from('.skill-accordion', {
      opacity: 0, x: -25, stagger: 0.09, duration: 0.5, ease: 'power3.out',
      scrollTrigger: { trigger: '#skills .flex.flex-col', start: 'top 82%' }
    });
  })();
</script>
