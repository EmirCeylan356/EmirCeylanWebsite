---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const works = [
  {
    id: 1,
    period: '2026 — PRESENT',
    title: 'PROJECT LEAD',
    subtitle: 'Teknofest Medical AI',
    description: 'Leading multidisciplinary team to develop multimodal diagnostic tools.',
    details: `<p>As the Project Lead for <strong>DeepMyelinAI</strong>, I head a multidisciplinary team developing an explainable AI-based clinical decision support system for <strong>Multiple Sclerosis (MS)</strong>.</p>
<p>I oversee the integration of multimodal data—including CSF biomarkers, genetic risk profiles, and longitudinal clinical disability scores—into a unified machine learning framework designed for early diagnosis and disability progression prediction.</p>
<p>My role involves managing the full development lifecycle: from engineering <strong>Temporal Transformer</strong> architectures for longitudinal tracking to implementing <strong>XAI layers (SHAP/LIME)</strong> to ensure clinical transparency.</p>
<p>By aligning our system with the <strong>2024 McDonald Criteria</strong>, I ensure our technical solutions meet rigorous medical standards, ultimately aiming to provide neurologists with actionable, data-driven insights.</p>`,
    link: '',
  },
  {
    id: 2,
    period: '2026 — PRESENT',
    title: 'TEACHING ASSISTANT',
    subtitle: 'DSA 210: Data Science',
    description: 'Assisting Prof. Oznur Tastan and Ozgun Yargi. Mentoring students in ML.',
    details: `<p>Currently serving as a Teaching Assistant for DSA 210, I support students in mastering the foundational pillars of data science, including computational thinking, machine learning, and statistical inference.</p>
<p>I lead weekly office hours to provide hands-on guidance with real-world data tools and techniques, helping students navigate complex topics such as exploratory data analysis (EDA), data privacy (K-anonymity), and predictive modeling.</p>
<p>By bridging the gap between theoretical coursework and practical application, I assist my peers in developing the technical rigor necessary to solve diverse problems across healthcare, business, and social domains.</p>`,
    link: '',
  },
  {
    id: 3,
    period: '2025 — 2026 Fall',
    title: 'UNDERGRADUATE RESEARCHER',
    subtitle: 'PURE - Sabancı University',
    description: 'Collaborating with Prof. Polat Göktaş on Explainable AI in Healthcare.',
    details: `<p>During the Fall 2025-26 term, I conducted a comprehensive scientometric study analyzing over 250 global publications to map the evolving landscape of AI in healthcare.</p>
<p>My research focused on the critical intersection of <strong>explainable AI (XAI)</strong>, clinician trust, and regulatory governance.</p>
<p>By utilizing literature mining and network analysis, I identified key knowledge gaps and emerging trends necessary for developing trustworthy and clinically deployable AI systems.</p>
<p><a href="https://www.linkedin.com/posts/emir-ceylan-student-482775332_pure-undergraduateresearch-ai-ugcPost-7433604110798544896-2cDY" target="_blank" class="linkedin-link">The LinkedIn Post</a></p>`,
    link: 'https://www.linkedin.com/posts/emir-ceylan-student-482775332_pure-undergraduateresearch-ai-ugcPost-7433604110798544896-2cDY',
  },
  {
    id: 4,
    period: 'SUMMER 2026',
    title: 'MACHINE LEARNING INTERN',
    subtitle: 'Amsterdam UMC',
    description: 'Developing AI models to reduce unnecessary sepsis testing in ER settings.',
    details: `<p>Developing AI models to reduce unnecessary sepsis testing in Emergency Room settings.</p>
<p>Focusing on clinical efficiency by optimizing diagnostic triggers to reduce physician workload and healthcare costs.</p>
<p><em>Work In Progress...</em></p>`,
    link: '',
    isWip: true,
  },
];

const skills = [
  { 
    name: 'PYTHON', 
    description: 'Primary language for AI/ML development. Experienced with NumPy, Pandas, Scikit-learn, TensorFlow, and PyTorch.' 
  },
  { 
    name: 'MACHINE LEARNING', 
    description: 'Supervised and unsupervised learning, neural networks, reinforcement learning, and model optimization.' 
  },
  { 
    name: 'DEEP LEARNING', 
    description: 'CNNs, RNNs, Transformers, GANs, and applications in medical imaging and NLP.' 
  },
  { 
    name: 'DATA SCIENCE', 
    description: 'Statistical analysis, data visualization, exploratory data analysis, and insights extraction.' 
  },
  { 
    name: 'DATA STRUCTURES', 
    description: 'Arrays, linked lists, trees, graphs, heaps, and efficient algorithm design.' 
  },
  { 
    name: 'ALGORITHMS', 
    description: 'Sorting, searching, dynamic programming, greedy algorithms, and complexity analysis.' 
  },
  { 
    name: 'RESEARCH', 
    description: 'Academic writing, literature review, methodology design, and scientific methodology.' 
  },
  { 
    name: 'BIOINFORMATICS', 
    description: 'Applying computational methods to biological data, protein structure analysis, and genomic data processing.' 
  },
];
---

<Layout title="EMIR CEYLAN — Creative Developer">
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="min-h-screen flex items-center justify-center px-4 pt-20 pb-10 relative overflow-hidden">
      <!-- Floating binary decoration -->
      <div class="binary-float binary-1 text-xs font-mono hidden md:block" aria-hidden="true">
        101010101010<br>010101010101<br>101010101010
      </div>
      <div class="binary-float binary-2 text-xs font-mono hidden md:block" aria-hidden="true">
        010101010101<br>101010101010<br>010101010101
      </div>
      <div class="binary-float binary-3 text-xs font-mono hidden md:block" aria-hidden="true">
        111000111000<br>000111000111<br>111000111000
      </div>
      
      <div class="max-w-5xl mx-auto text-center relative z-10">
        <h1 class="kinetic-text text-6xl md:text-8xl lg:text-[10rem] font-black -mt-4 leading-none">
          EMİR<br/>
          <span class="text-white" style="text-shadow: 4px 4px 0 #000;">CEYLAN</span>
        </h1>
        
        <p class="text-lg md:text-xl font-bold max-w-2xl mx-auto mb-8 bg-black text-white inline-block px-4 py-2">
          CS STUDENT — AI FOR HEALTHCARE
        </p>
        
        <div class="flex flex-wrap gap-4 justify-center">
          <a 
            href="#work" 
            class="px-8 py-4 bg-black text-white font-bold text-lg border-4 border-black hover:bg-white hover:text-black transition-all hover:shadow-[8px_8px_0px_#000]"
          >
            MY WORK →
          </a>
          <a 
            href="#contact" 
            class="px-8 py-4 bg-white text-black font-bold text-lg border-4 border-black hover:bg-black hover:text-white transition-all"
          >
            CONTACT
          </a>
        </div>
        
        <!-- Scroll indicator -->
        <div class="mt-16 animate-bounce">
          <span class="text-4xl">↓</span>
        </div>
      </div>
    </section>

    <!-- Awards Bar -->
    <section class="bg-black text-white py-3 border-y-4 border-black overflow-hidden" aria-label="Roles and titles">
      <div class="max-w-7xl mx-auto px-4">
        <div class="marquee-container">
          <div class="marquee-content" aria-hidden="true">
            <span class="font-bold text-lg mx-12">★ Medical AI Specialist</span>
            <span class="font-bold text-lg mx-12">★ Data Scientist</span>
            <span class="font-bold text-lg mx-12">★ Machine Learning Researcher</span>
            <span class="font-bold text-lg mx-12">★ Sabancı University TA</span>
            <span class="font-bold text-lg mx-12">★ Team Leader</span>
            <span class="font-bold text-lg mx-12">★ XAI Enthusiast</span>
            <span class="font-bold text-lg mx-12">★ Artist</span>
            <span class="font-bold text-lg mx-12">★ Medical AI Specialist</span>
            <span class="font-bold text-lg mx-12">★ Data Scientist</span>
            <span class="font-bold text-lg mx-12">★ Machine Learning Researcher</span>
            <span class="font-bold text-lg mx-12">★ Sabancı University TA</span>
            <span class="font-bold text-lg mx-12">★ Team Leader</span>
            <span class="font-bold text-lg mx-12">★ XAI Enthusiast</span>
            <span class="font-bold text-lg mx-12">★ Artist</span>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-16 px-4">
      <div class="max-w-4xl mx-auto text-left">
        <div class="mb-8">
          <h2 class="text-5xl md:text-7xl font-black kinetic-text">
            ABOUT <span class="text-3xl">/01</span>
          </h2>
        </div>
        
        <p class="text-xl md:text-2xl font-bold leading-tight mb-6 text-left">
          Computer Science student at <span class="bg-[#f40c3f] text-white px-2">Sabancı University</span> passionate about AI applications in healthcare. Building the future of medical AI.
        </p>
        <p class="text-lg mt-6 opacity-80 max-w-2xl text-left">
          Driven by the potential of AI to bridge gaps in modern medicine, I focus on developing intelligent systems that are as ethical as they are efficient. My work at Sabancı University centers on collaborating with professors and fellow students to build projects that connect deep CS knowledge with complex medical hurdles to find practical, scalable solutions.
        </p>
        <p class="text-lg mt-4 opacity-80 max-w-2xl text-left">
          Outside of the lab, I balance the logic of neural networks with painting, a creative outlet that allows me to view technical challenges through a more expressive, lateral-thinking lens.
        </p>
        <p class="text-lg font-bold mt-6 text-left">
          Expected Graduation: 2027
        </p>
      </div>
    </section>

    <!-- Work Section -->
    <section id="work" class="py-16 px-4 bg-white border-y-4 border-black">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end gap-4 mb-12">
          <h2 class="text-5xl md:text-7xl font-black kinetic-text">
            WORK
          </h2>
          <div class="flex-1 h-4 bg-black"></div>
          <span class="text-3xl font-black">/02</span>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6">
          {works.map((work) => (
            <div 
              class="work-card relative border-4 border-black p-6 cursor-pointer transition-all duration-300 hover:bg-black hover:text-white group"
              data-work-id={work.id}
              data-is-wip={work.isWip ? 'true' : 'false'}
            >
              <p class="text-xs font-mono font-bold mb-2">{work.period}</p>
              <span class="work-title text-xl font-black mb-1 block">{work.title}</span>
              <p class="font-bold mb-2 text-sm">{work.subtitle}</p>
              <p class="text-sm opacity-70">{work.description}</p>
              
              <button class="expand-btn mt-3 text-xs font-bold border-2 border-current px-3 py-1 inline-flex items-center gap-1 group-hover:bg-white group-hover:text-black">
                <span>READ MORE</span>
                <span class="expand-icon">+</span>
              </button>
              
              <!-- Hidden details for popup -->
              <div class="work-details hidden">
                <div class="red-headline bg-[#f40c3f] text-white px-4 py-2 -mx-6 -mt-6 mb-4">
                  <span class="font-black text-lg">{work.title}</span>
                </div>
                <div class="work-content text-sm" set:html={work.details} />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="py-16 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end gap-4 mb-12">
          <h2 class="text-5xl md:text-7xl font-black kinetic-text">
            SKILLS
          </h2>
          <div class="flex-1 h-4 bg-black"></div>
          <span class="text-3xl font-black">/03</span>
        </div>
        
        <div class="grid md:grid-cols-2 gap-4 max-w-4xl">
          {skills.map((skill, index) => (
            <div 
              class="skill-card bg-white border-4 border-black p-4 hover:translate-x-2 transition-transform cursor-pointer group"
              data-skill-index={index}
            >
              <span class="font-black text-lg group-hover:text-[#f40c3f] transition-colors">{skill.name}</span>
              <span class="float-right text-xl opacity-0 group-hover:opacity-100 transition-opacity">+</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Popup Modal -->
  <div id="work-popup" class="fixed inset-0 z-100 flex items-start justify-center p-20">
    <div class="popup-overlay absolute inset-0 bg-black/80"></div>
    <div class="popup-content relative z-[101] w-full max-w-2xl bg-white border-4 border-black max-h-[70vh] overflow-y-auto">
      <div class="red-headline bg-[#f40c3f] text-white px-6 py-4 flex justify-between items-center">
        <span id="popup-title" class="font-black text-xl"></span>
        <button id="popup-close" class="text-white text-2xl font-bold hover:scale-110 transition-transform">×</button>
      </div>
      <div id="popup-body" class="p-6 text-sm leading-relaxed">
      </div>
    </div>
  </div>

  <!-- Skill Popup -->
  <div id="skill-popup" class="fixed inset-0 z-100 flex items-start justify-center p-20">
    <div class="popup-overlay absolute inset-0 bg-black/80"></div>
    <div class="popup-content relative z-[101] w-full max-w-xl bg-white border-4 border-black">
      <div class="bg-[#f40c3f] text-white px-6 py-4 flex justify-between items-center">
        <span id="skill-popup-title" class="font-black text-xl"></span>
        <button id="skill-popup-close" class="text-white text-2xl font-bold hover:scale-110 transition-transform">×</button>
      </div>
      <div id="skill-popup-body" class="p-6 text-sm leading-relaxed">
      </div>
    </div>
  </div>
</Layout>

<style>
  .marquee-container {
    overflow: hidden;
    white-space: nowrap;
  }
  
  .marquee-content {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }
  
  @keyframes marquee {
    0% { transform: translateX(100vw); }
    100% { transform: translateX(-100%); }
  }

  /* Binary float animation - reduced opacity */
  .binary-float {
    position: absolute;
    animation: binaryFade 8s ease-in-out infinite;
    opacity: 0;
  }
  
  .binary-1 { top: 15%; left: 3%; animation-delay: 0s; }
  .binary-2 { top: 50%; right: 3%; animation-delay: 3s; }
  .binary-3 { bottom: 25%; left: 10%; animation-delay: 6s; }
  .binary-4 { top: 70%; left: 8%; animation-delay: 1s; }
  .binary-5 { top: 30%; right: 8%; animation-delay: 4s; }
  
  @keyframes binaryFade {
    0%, 100% { opacity: 0; transform: translateY(20px); }
    15%, 85% { opacity: 0.1; transform: translateY(0); }
  }

  /* Work card hover */
  .work-card::after {
    content: '';
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    font-size: 0.75rem;
    font-weight: bold;
    opacity: 0;
    transition: opacity 0.3s;
  }
  
  .work-card:hover::after {
    opacity: 0;
  }

  .expand-btn {
    transition: transform 0.3s;
  }
  
  .expand-icon {
    transition: transform 0.3s;
  }
  
  .expand-btn:hover .expand-icon {
    transform: rotate(45deg);
  }

  /* WIP work card */
  .work-card.wip-hover {
    background-color: black !important;
    color: white !important;
  }
  
  .work-card.wip-hover .text-xs,
  .work-card.wip-hover .text-sm,
  .work-card.wip-hover .font-bold,
  .work-card.wip-hover .work-title {
    opacity: 0;
  }
  
  .work-card.wip-hover::before {
    content: 'Work In Progress...';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-weight: bold;
    font-size: 1.25rem;
  }

  /* Popup styles */
  #work-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }
  
  #work-popup.active {
    display: flex;
  }
  
  #skill-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }
  
  #skill-popup.active {
    display: flex;
  }
  
  #skill-popup.active .popup-content {
    animation: popupSlide 0.4s ease-out;
  }
  
  @keyframes popupSlide {
    from {
      transform: translateY(-50px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Droplet animation on close */
  .droplet {
    position: absolute;
    width: 10px;
    height: 10px;
    background: #f40c3f;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    animation: droplet 0.6s ease-out forwards;
  }
  
  @keyframes droplet {
    0% {
      opacity: 1;
      transform: rotate(-45deg) translateY(0);
    }
    100% {
      opacity: 0;
      transform: rotate(-45deg) translateY(100px);
    }
  }

  /* Work content styling */
  .work-content h2 {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  
  .work-content p {
    margin-bottom: 0.75rem;
  }
  
  .work-content a.linkedin-link {
    color: #0077b5;
    text-decoration: underline;
    font-weight: bold;
  }
</style>

<script is:inline>
  // Skills data
  const skillsData = [
    { name: 'PYTHON', description: 'Primary language for AI/ML development. Experienced with NumPy, Pandas, Scikit-learn, TensorFlow, and PyTorch.' },
    { name: 'MACHINE LEARNING', description: 'Supervised and unsupervised learning, neural networks, reinforcement learning, and model optimization.' },
    { name: 'DEEP LEARNING', description: 'CNNs, RNNs, Transformers, GANs, and applications in medical imaging and NLP.' },
    { name: 'DATA SCIENCE', description: 'Statistical analysis, data visualization, exploratory data analysis, and insights extraction.' },
    { name: 'DATA STRUCTURES', description: 'Arrays, linked lists, trees, graphs, heaps, and efficient algorithm design.' },
    { name: 'ALGORITHMS', description: 'Sorting, searching, dynamic programming, greedy algorithms, and complexity analysis.' },
    { name: 'RESEARCH', description: 'Academic writing, literature review, methodology design, and scientific methodology.' },
    { name: 'BIOINFORMATICS', description: 'Applying computational methods to biological data, protein structure analysis, and genomic data processing.' },
  ];

  // Skill popup handlers
  const skillCards = document.querySelectorAll('.skill-card');
  const skillPopup = document.getElementById('skill-popup');
  const skillPopupTitle = document.getElementById('skill-popup-title');
  const skillPopupBody = document.getElementById('skill-popup-body');
  const skillPopupClose = document.getElementById('skill-popup-close');
  const skillPopupOverlay = document.querySelector('#skill-popup .popup-overlay');
  
  skillCards.forEach(function(card) {
    card.addEventListener('click', function() {
      const index = parseInt(card.getAttribute('data-skill-index'));
      const skill = skillsData[index];
      
      if (skillPopupTitle) skillPopupTitle.textContent = skill.name;
      if (skillPopupBody) skillPopupBody.textContent = skill.description;
      if (skillPopup) {
        skillPopup.classList.add('active');
        skillPopup.style.display = 'flex';
      }
      document.body.style.overflow = 'hidden';
    });
  });

  function closeSkillPopup() {
    if (skillPopup) {
      skillPopup.classList.remove('active');
      skillPopup.style.display = 'none';
    }
    document.body.style.overflow = '';
  }
  
  if (skillPopupClose) skillPopupClose.addEventListener('click', closeSkillPopup);
  if (skillPopupOverlay) skillPopupOverlay.addEventListener('click', closeSkillPopup);

  // Work card expand handlers
  const workCards = document.querySelectorAll('.work-card');
  const popup = document.getElementById('work-popup');
  const popupTitle = document.getElementById('popup-title');
  const popupBody = document.getElementById('popup-body');
  const popupClose = document.getElementById('popup-close');
  const popupOverlay = document.querySelector('.popup-overlay');
  
  workCards.forEach(function(card) {
    const isWip = card.getAttribute('data-is-wip') === 'true';
    const details = card.querySelector('.work-details');
    const expandBtn = card.querySelector('.expand-btn');
    const expandIcon = card.querySelector('.expand-icon');
    
    if (isWip) {
      // WIP - hover and click behavior
      card.addEventListener('mouseenter', function() {
        if (!card.classList.contains('clicked')) {
          card.classList.add('wip-hover');
        }
      });
      
      card.addEventListener('mouseleave', function() {
        if (!card.classList.contains('clicked')) {
          card.classList.remove('wip-hover');
        }
      });
      
      card.addEventListener('click', function() {
        if (card.classList.contains('clicked')) return;
        
        card.classList.add('clicked');
        card.classList.add('wip-hover');
        
        // Reset after 3 seconds
        setTimeout(function() {
          card.classList.remove('clicked');
          card.classList.remove('wip-hover');
        }, 3000);
      });
    } else if (expandBtn) {
      // Expand button - show in popup
      expandBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        const titleEl = card.querySelector('.work-title');
        const title = titleEl ? titleEl.textContent : '';
        const content = details ? details.innerHTML : '';
        
        if (popupTitle) popupTitle.textContent = title;
        if (popupBody) popupBody.innerHTML = content;
        if (popup) {
          popup.classList.add('active');
          popup.style.display = 'flex';
        }
        document.body.style.overflow = 'hidden';
      });
    }
  });
  
  // Close popup
  function closePopup() {
    if (popup) {
      popup.classList.remove('active');
      popup.style.display = 'none';
    }
    document.body.style.overflow = '';
    
    // Create droplet animation
    const popupContent = document.querySelector('.popup-content');
    if (popupContent) {
      for (let i = 0; i < 20; i++) {
        const droplet = document.createElement('div');
        droplet.className = 'droplet';
        droplet.style.left = Math.random() * 100 + '%';
        droplet.style.top = '0';
        droplet.style.animationDelay = Math.random() * 0.3 + 's';
        popupContent.appendChild(droplet);
        
        setTimeout(function() { droplet.remove(); }, 1000);
      }
    }
  }
  
  if (popupClose) popupClose.addEventListener('click', closePopup);
  if (popupOverlay) popupOverlay.addEventListener('click', closePopup);

  // Grid fisheye effect
  const gridBg = document.querySelector('.grid-bg');
  document.addEventListener('mousemove', function(e) {
    const x = e.clientX / window.innerWidth;
    const y = e.clientY / window.innerHeight;
    
    if (gridBg) {
      gridBg.style.transform = 'perspective(500px) rotateX(' + ((y - 0.5) * 10) + 'deg) rotateY(' + ((x - 0.5) * 10) + 'deg)';
      gridBg.style.transformOrigin = (x * 100) + '% ' + (y * 100) + '%';
    }
  });
</script>
