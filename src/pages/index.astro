            SKILLS
          </h2>
          <div class="flex-1 h-4 bg-black"></div>
          <span class="text-3xl font-black">/06</span>
        </div>

        <div class="flex flex-col gap-0 max-w-2xl">
          {skillCategories.map((category) => (
            <div class="skill-box skill-accordion border-4 border-black -mb-[4px] cursor-pointer">
