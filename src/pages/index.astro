  <Footer />

  <!-- Popup Modal -->
  <div id="work-popup" class="fixed inset-0 z-[100] flex items-start justify-center p-20">
    <div class="popup-overlay absolute inset-0 bg-black/80"></div>
    <div class="popup-content relative z-[101] w-full max-w-2xl bg-white border-4 border-black max-h-[70vh] overflow-y-auto">
      <div class="red-headline bg-[#f40c3f] text-white px-6 py-4 flex justify-between items-center">
        <span id="popup-title" class="font-black text-xl"></span>
        <button id="popup-close" class="text-white text-2xl font-bold hover:opacity-70 transition-opacity">×</button>
      </div>
      <div id="popup-body" class="p-6 text-sm leading-relaxed">
      </div>
    </div>
