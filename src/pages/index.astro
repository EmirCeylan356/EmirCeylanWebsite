<style>
  .marquee-container {
    overflow: hidden;
    white-space: nowrap;
  }
  
  .marquee-content {
    display: inline-block;
    animation: marquee 15s linear forwards;
  }
  
  @keyframes marquee {
    0% { transform: translateX(100vw); }
    100% { transform: translateX(-100%); }
  }

  /* Binary float animation - reduced opacity */
  .binary-float {
    position: absolute;
    animation: binaryFade 4s ease-in-out forwards;
    opacity: 0;
  }
  
  .binary-1 { top: 15%; left: 3%; animation-delay: 0s; }
  .binary-2 { top: 50%; right: 3%; animation-delay: 1.5s; }
  .binary-3 { bottom: 25%; left: 10%; animation-delay: 3s; }
  
  @keyframes binaryFade {
    0% { opacity: 0; transform: translateY(20px); }
    15%, 70% { opacity: 0.08; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-20px); }
  }

  /* Work card hover */
  .work-card {
    overflow: visible;
  }
  
  .work-card::after {
    content: '';
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    font-size: 0.75rem;
    font-weight: bold;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .expand-btn {
    transition: transform 0.3s;
  }
  
  .expand-icon {
    transition: transform 0.3s;
  }
  
  .expand-btn:hover .expand-icon {
    transform: rotate(45deg);
  }

  /* WIP work card */
  .work-card.wip-hover {
    background-color: black !important;
    color: white !important;
  }
  
  .work-card.wip-hover .text-xs,
  .work-card.wip-hover .text-sm,
  .work-card.wip-hover .font-bold,
  .work-card.wip-hover .work-title {
    opacity: 0;
  }
  
  .work-card.wip-hover::before {
    content: 'Work In Progress...';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-weight: bold;
    font-size: 1.25rem;
  }

  /* Popup styles */
  #work-popup, #skill-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }
  
  #work-popup.active, #skill-popup.active {
    display: flex;
  }
  
  #work-popup.active .popup-content, #skill-popup.active .popup-content {
    animation: popupSlide 0.4s ease-out;
  }
  
  @keyframes popupSlide {
    from {
      transform: translateY(-50px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Droplet animation on close */
  .droplet {
    position: absolute;
    width: 10px;
    height: 10px;
    background: #f40c3f;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    animation: droplet 0.6s ease-out forwards;
  }
  
  @keyframes droplet {
    0% {
      opacity: 1;
      transform: rotate(-45deg) translateY(0);
    }
    100% {
      opacity: 0;
      transform: rotate(-45deg) translateY(100px);
    }
  }

  /* Work content styling */
  .work-content h2 {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  
  .work-content p {
    margin-bottom: 0.75rem;
  }
  
  .work-content a.linkedin-link {
    color: #0077b5;
    text-decoration: underline;
    font-weight: bold;
  }
</style>

<script is:inline>
  // Three.js Neural Network Background
  (function() {
    const canvas = document.getElementById('webgl-bg');
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    
    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
    
    // Particle class
    class Particle {
      constructor() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.vx = (Math.random() - 0.5) * 0.5;
        this.vy = (Math.random() - 0.5) * 0.5;
        this.radius = Math.random() * 2 + 1;
        this.color = Math.random() > 0.5 ? '#f40c3f' : '#000000';
      }
      
      update() {
        this.x += this.vx;
        this.y += this.vy;
        
        if (this.x < 0 || this.x > width) this.vx *= -1;
        if (this.y < 0 || this.y > height) this.vy *= -1;
      }
      
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = this.color;
        ctx.globalAlpha = 0.6;
        ctx.fill();
      }
    }
    
    // Create particles
    const particles = [];
    const particleCount = Math.floor((width * height) / 15000);
    
    for (let i = 0; i < particleCount; i++) {
      particles.push(new Particle());
    }
    
    // Mouse interaction
    let mouseX = width / 2;
    let mouseY = height / 2;
    
    document.addEventListener('mousemove', function(e) {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });
    
    // Animation loop
    function animate() {
      // Clear with fade effect
      ctx.fillStyle = 'rgba(244, 12, 63, 0.05)';
      ctx.fillRect(0, 0, width, height);
      
      // Update and draw particles
      particles.forEach(function(p) {
        p.update();
        
        // Mouse interaction - particles move away from mouse
        const dx = mouseX - p.x;
        const dy = mouseY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        
        if (dist < 150) {
          const force = (150 - dist) / 150;
          p.x -= (dx / dist) * force * 2;
          p.y -= (dy / dist) * force * 2;
        }
        
        p.draw();
      });
      
      // Draw connections (neural network effect)
      ctx.strokeStyle = '#000000';
      ctx.globalAlpha = 0.1;
      
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          
          if (dist < 120) {
            ctx.lineWidth = 1 - (dist / 120);
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }
      
      // Draw DNA helix effect (vertical connections)
      ctx.strokeStyle = '#f40c3f';
      ctx.globalAlpha = 0.05;
      
      for (let x = 0; x < width; x += 80) {
        ctx.beginPath();
        ctx.moveTo(x, 0);
        
        for (let y = 0; y < height; y += 20) {
          const offset = Math.sin(y * 0.02 + Date.now() * 0.001) * 20;
          ctx.lineTo(x + offset, y);
        }
        
        ctx.stroke();
      }
      
      requestAnimationFrame(animate);
    }
    
    animate();
    
    // Resize handler
    window.addEventListener('resize', function() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });
  })();

  // Skills data
  const skillsData = [
    { name: 'PYTHON', description: 'Primary language for AI/ML development. Experienced with NumPy, Pandas, Scikit-learn, TensorFlow, and PyTorch.' },
    { name: 'MACHINE LEARNING', description: 'Supervised and unsupervised learning, neural networks, reinforcement learning, and model optimization.' },
    { name: 'DEEP LEARNING', description: 'CNNs, RNNs, Transformers, GANs, and applications in medical imaging and NLP.' },
    { name: 'DATA SCIENCE', description: 'Statistical analysis, data visualization, exploratory data analysis, and insights extraction.' },
    { name: 'DATA STRUCTURES', description: 'Arrays, linked lists, trees, graphs, heaps, and efficient algorithm design.' },
    { name: 'ALGORITHMS', description: 'Sorting, searching, dynamic programming, greedy algorithms, and complexity analysis.' },
    { name: 'RESEARCH', description: 'Academic writing, literature review, methodology design, and scientific methodology.' },
    { name: 'BIOINFORMATICS', description: 'Applying computational methods to biological data, protein structure analysis, and genomic data processing.' },
  ];

  // Skill popup handlers
  const skillCards = document.querySelectorAll('.skill-card');
  const skillPopup = document.getElementById('skill-popup');
  const skillPopupTitle = document.getElementById('skill-popup-title');
  const skillPopupBody = document.getElementById('skill-popup-body');
  const skillPopupClose = document.getElementById('skill-popup-close');
  const skillPopupOverlay = document.querySelector('#skill-popup .popup-overlay');
  
  skillCards.forEach(function(card) {
    card.addEventListener('click', function() {
      const index = parseInt(card.getAttribute('data-skill-index'));
      const skill = skillsData[index];
      
      if (skillPopupTitle) skillPopupTitle.textContent = skill.name;
      if (skillPopupBody) skillPopupBody.textContent = skill.description;
      if (skillPopup) {
        skillPopup.classList.add('active');
        skillPopup.style.display = 'flex';
      }
      document.body.style.overflow = 'hidden';
    });
  });

  function closeSkillPopup() {
    if (skillPopup) {
      skillPopup.classList.remove('active');
      skillPopup.style.display = 'none';
    }
    document.body.style.overflow = '';
  }
  
  if (skillPopupClose) skillPopupClose.addEventListener('click', closeSkillPopup);
  if (skillPopupOverlay) skillPopupOverlay.addEventListener('click', closeSkillPopup);

  // Work card expand handlers (accordion style)
  const workCards = document.querySelectorAll('.work-card');
  
  workCards.forEach(function(card) {
    const isWip = card.getAttribute('data-is-wip') === 'true';
    const details = card.querySelector('.work-details');
    const expandBtn = card.querySelector('.expand-btn');
    const expandIcon = card.querySelector('.expand-icon');
    
    if (isWip) {
      // WIP - hover and click behavior
      card.addEventListener('mouseenter', function() {
        if (!card.classList.contains('clicked')) {
          card.classList.add('wip-hover');
        }
      });
      
      card.addEventListener('mouseleave', function() {
        if (!card.classList.contains('clicked')) {
          card.classList.remove('wip-hover');
        }
      });
      
      card.addEventListener('click', function() {
        if (card.classList.contains('clicked')) return;
        
        card.classList.add('clicked');
        card.classList.add('wip-hover');
        
        // Reset after 3 seconds
        setTimeout(function() {
          card.classList.remove('clicked');
          card.classList.remove('wip-hover');
        }, 3000);
      });
    } else if (expandBtn && details) {
      // Expand button - show inline accordion
      expandBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        
        const isExpanded = details.classList.contains('expanded');
        
        // Close all other cards first (accordion behavior)
        document.querySelectorAll('.work-details.expanded').forEach(function(d) {
          d.classList.remove('expanded');
          d.classList.add('hidden');
        });
        
        if (isExpanded) {
          details.classList.remove('expanded');
          details.classList.add('hidden');
          if (expandIcon) expandIcon.textContent = '+';
          expandBtn.querySelector('span').textContent = 'READ MORE';
        } else {
          details.classList.remove('hidden');
          details.classList.add('expanded');
          if (expandIcon) expandIcon.textContent = '−';
          expandBtn.querySelector('span').textContent = 'READ LESS';
        }
      });
    }
  });

  // Grid fisheye effect
  const gridBg = document.querySelector('.grid-bg');
  document.addEventListener('mousemove', function(e) {
    const x = e.clientX / window.innerWidth;
    const y = e.clientY / window.innerHeight;
    
    if (gridBg) {
      gridBg.style.transform = 'perspective(500px) rotateX(' + ((y - 0.5) * 10) + 'deg) rotateY(' + ((x - 0.5) * 10) + 'deg)';
      gridBg.style.transformOrigin = (x * 100) + '% ' + (y * 100) + '%';
    }
  });
</script>
