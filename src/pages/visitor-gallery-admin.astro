---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---

<Layout title="GALLERY ADMIN — Emir Ceylan">
  <Header />

  <main style="padding-top: 80px;">
    <section style="padding:3rem 2rem; min-height:70vh;">
      <div class="max-w-7xl mx-auto">

        <!-- Login (shown by default, hidden after auth) -->
        <div id="login-view" style="max-width:400px; margin:4rem auto;">
          <p class="font-mono text-xs mb-3" style="color:var(--text-secondary); letter-spacing:0.15em;">ADMIN /</p>
          <h1 class="font-black kinetic-text mb-8" style="font-family:'Syne'; font-size:3rem; color:var(--text-primary);">LOGIN</h1>
          <form id="login-form" style="display:flex; flex-direction:column; gap:1rem;">
            <input type="password" id="pw-input" required placeholder="Enter admin password"
              class="admin-input font-mono text-sm"
              style="background:var(--bg-elevated); border:1px solid var(--border-color); color:var(--text-primary); padding:0.85rem 1rem; outline:none;" />
            <p id="login-error" class="font-mono text-xs" style="color:#FF0055; display:none;">Invalid password.</p>
            <button type="submit" class="font-mono text-sm font-bold cut-corner admin-login-btn"
              style="background:var(--accent); color:#000; border:1px solid var(--accent); letter-spacing:0.1em; cursor:pointer; padding:1rem;">
              LOGIN
            </button>
          </form>
        </div>

        <!-- Dashboard (hidden by default, shown after auth) -->
        <div id="dashboard-view" style="display:none;">
          <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:2rem;">
            <div>
              <p class="font-mono text-xs mb-2" style="color:var(--text-secondary); letter-spacing:0.15em;">ADMIN /</p>
              <h1 class="font-black kinetic-text" style="font-family:'Syne'; font-size:clamp(2rem,5vw,3.5rem); color:var(--text-primary);">
                GALLERY<span style="color:var(--accent);">_</span>ADMIN
              </h1>
            </div>
            <div style="display:flex; gap:0.75rem;">
              <button id="refresh-btn" class="font-mono text-xs font-bold cut-corner-sm admin-action-btn" style="letter-spacing:0.08em; padding:0.5rem 1rem;">
                REFRESH
              </button>
              <a href="/visitor-gallery" class="font-mono text-xs font-bold cut-corner-sm admin-link-btn" style="letter-spacing:0.08em; text-decoration:none; padding:0.5rem 1rem;">
                VIEW GALLERY
              </a>
            </div>
          </div>

          <!-- Status bar -->
          <div class="panel" style="padding:1rem 1.5rem; margin-bottom:2rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
            <span style="width:8px; height:8px; border-radius:50%; background:var(--accent); display:inline-block; box-shadow:0 0 6px var(--accent);"></span>
            <span class="font-mono text-xs font-bold" style="color:var(--accent); letter-spacing:0.1em;">AUTHENTICATED</span>
            <span class="font-mono text-xs" style="color:var(--text-secondary); opacity:0.5;">|</span>
            <span id="admin-count" class="font-mono text-xs" style="color:var(--text-secondary);">Loading...</span>
          </div>

          <!-- Admin grid -->
          <div id="admin-grid" class="admin-grid"></div>
          <div id="admin-empty" style="display:none; text-align:center; padding:4rem 0;">
            <p class="font-mono text-sm" style="color:var(--text-secondary); opacity:0.5;">No submissions found.</p>
          </div>
        </div>

      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline define:vars={{ supabaseUrl, supabaseKey }}>
  window.__ADM_URL__ = supabaseUrl;
  window.__ADM_KEY__ = supabaseKey;
</script>

<style>
  .admin-input:focus { border-color: var(--accent) !important; box-shadow: 0 0 0 1px var(--accent); }
  .admin-input::placeholder { color: var(--text-secondary); opacity: 0.35; }
  .admin-login-btn { transition: background 0.2s, color 0.2s, box-shadow 0.2s; }
  .admin-login-btn:hover { background: transparent !important; color: var(--accent) !important; box-shadow: 0 0 16px var(--accent-glow); }

  .admin-action-btn {
    background: var(--accent); color: #000; border: 1px solid var(--accent);
    cursor: pointer; transition: background 0.2s, color 0.2s;
  }
  .admin-action-btn:hover { background: transparent; color: var(--accent); }

  .admin-link-btn {
    background: transparent; color: var(--text-primary); border: 1px solid var(--border-color);
    transition: border-color 0.2s, color 0.2s;
  }
  .admin-link-btn:hover { border-color: var(--accent); color: var(--accent); }

  .admin-grid {
    display: grid; gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .admin-card {
    background: var(--bg-surface); border: 1px solid var(--border-color); padding: 1rem;
    transition: border-color 0.2s;
  }
  .admin-card img { width: 100%; aspect-ratio: 600/390; object-fit: cover; display: block; border: 1px solid var(--border-color); margin-bottom: 0.75rem; }

  .del-btn {
    background: transparent; color: #FF0055; border: 1px solid #FF0055;
    font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 700;
    padding: 0.4rem 0.75rem; cursor: pointer; letter-spacing: 0.08em;
    transition: background 0.15s, color 0.15s; margin-top: 0.5rem;
  }
  .del-btn:hover { background: #FF0055; color: #fff; }
  .del-btn:disabled { opacity: 0.4; cursor: not-allowed; }
</style>

<script is:inline>
(function(){
  var ADMIN_PASSWORD = "emir2026";
  var sbClient = null;

  // Check URL param first (for bookmarkable login)
  var urlPassword = new URLSearchParams(window.location.search).get('password');
  if (urlPassword === ADMIN_PASSWORD) {
    authenticate();
  }

  // Login form handler
  document.getElementById('login-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var pw = document.getElementById('pw-input').value;
    if (pw === ADMIN_PASSWORD) {
      authenticate();
    } else {
      document.getElementById('login-error').style.display = '';
    }
  });

  function authenticate() {
    document.getElementById('login-view').style.display = 'none';
    document.getElementById('dashboard-view').style.display = '';
    loadAdmin();
  }

  async function getSB() {
    if (sbClient) return sbClient;
    var url = window.__ADM_URL__, key = window.__ADM_KEY__;
    if (!url || !key) return null;
    try {
      var mod = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm');
      sbClient = mod.createClient(url, key);
      return sbClient;
    } catch(e){ return null; }
  }

  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  async function loadAdmin() {
    var sb = await getSB();
    if (!sb) { document.getElementById('admin-count').textContent = 'Supabase not configured'; return; }

    var res = await sb.from('gallery_submissions').select('*').order('created_at', { ascending: false });
    var items = (res.data || []);
    var grid  = document.getElementById('admin-grid');
    var empty = document.getElementById('admin-empty');
    var count = document.getElementById('admin-count');

    count.textContent = items.length + ' submission' + (items.length !== 1 ? 's' : '') + ' total';
    grid.innerHTML = '';

    if (items.length === 0) { empty.style.display = ''; return; }
    empty.style.display = 'none';

    items.forEach(function(it){
      var d = document.createElement('div');
      d.className = 'admin-card';
      d.innerHTML =
        '<img src="' + esc(it.image_data) + '" alt="' + esc(it.title) + '" />' +
        '<p class="font-black text-sm" style="color:var(--text-primary);font-family:Syne;">' + esc(it.title) + '</p>' +
        '<p class="font-mono text-xs" style="color:var(--text-secondary);margin-top:0.25rem;">by ' + esc(it.name) + '</p>' +
        '<p class="font-mono text-xs" style="color:var(--text-secondary);opacity:0.4;margin-top:0.25rem;">' + new Date(it.created_at).toLocaleString() + '</p>' +
        '<p class="font-mono text-xs" style="color:var(--text-secondary);opacity:0.3;margin-top:0.25rem;">ID: ' + esc(it.id).substring(0,8) + '...</p>' +
        '<button class="del-btn" data-id="' + esc(it.id) + '">DELETE</button>';
      grid.appendChild(d);
    });

    grid.querySelectorAll('.del-btn').forEach(function(btn){
      btn.onclick = async function(){
        if (!confirm('Delete this artwork permanently?')) return;
        btn.disabled = true; btn.textContent = 'DELETING...';
        var delRes = await sb.from('gallery_submissions').delete().eq('id', btn.dataset.id);
        if (delRes.error) { alert('Delete failed: ' + delRes.error.message); btn.disabled = false; btn.textContent = 'DELETE'; return; }
        btn.closest('.admin-card').remove();
        var remaining = grid.querySelectorAll('.admin-card').length;
        count.textContent = remaining + ' submission' + (remaining !== 1 ? 's' : '') + ' total';
        if (remaining === 0) empty.style.display = '';
      };
    });
  }

  document.getElementById('refresh-btn').addEventListener('click', loadAdmin);
})();
</script>
