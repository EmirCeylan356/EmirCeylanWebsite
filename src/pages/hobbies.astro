---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// ── Artworks (paintings only — clean descriptions, no AI metaphors) ───────────
const artworks = [
  {
    id: 1,  title: 'FORM STUDY I',       medium: 'Oil on Canvas',  year: 2024,
    src: '/images/file_8---39151805-7313-4bb7-b8c8-1365aef884a3.jpg',
    desc: 'An exploration of negative space and structural tension. Built up with palette knife strokes, allowing the medium to dictate form rather than the other way around. The result captures something contained and alive at the same time.',
  },
  {
    id: 2,  title: 'COMPOSITION II',     medium: 'Mixed Media',    year: 2024,
    src: '/images/file_9---c5cd81b7-8140-4595-8297-af32f0e2edba.jpg',
    desc: 'Started as a charcoal sketch, then buried under translucent oil glazes until the original marks became ghosts beneath the surface. What you see is the result of a conversation between two different sessions, months apart.',
  },
  {
    id: 3,  title: 'LANDSCAPE III',      medium: 'Oil on Canvas',  year: 2024,
    src: '/images/file_10---714a56fd-d4fb-4316-8629-c6f06a4db7a8.jpg',
    desc: 'Painted from memory of the Bosphorus at dusk. The shift in color temperature from warm water to cool sky demanded constant re-evaluation — each decision about hue changed everything that came before it.',
  },
  {
    id: 4,  title: 'FIGURE IV',          medium: 'Acrylic',        year: 2024,
    src: '/images/file_11---e6cf7245-cda7-4ca8-884c-55c891575493.jpg',
    desc: 'A study in how light defines mass — anatomy read through shadow rather than outline. The discipline here was in what I left unpainted. Every mark was a commitment, and every white area a deliberate silence.',
  },
  {
    id: 5,  title: 'ABSTRACTION V',      medium: 'Oil on Canvas',  year: 2024,
    src: '/images/file_12---09cd522a-d5e5-433a-ac0f-d9c0c710c79a.jpg',
    desc: 'Began with no composition in mind — only a feeling about two colors side by side. Each layer reacted to the previous, building a visual argument neither planned nor resolved. I stopped when it started answering back.',
  },
  {
    id: 6,  title: 'TEXTURE VI',         medium: 'Mixed Media',    year: 2024,
    src: '/images/file_13---f94eea51-a229-4b42-bcf4-f489c8824e9b.jpg',
    desc: 'Impasto built up thick enough to cast shadows, then cut through with fine ink lines. The two processes fight each other on the surface. That friction is the point — neither wins, and the tension is what holds your eye.',
  },
  {
    id: 7,  title: 'STILLNESS VII',      medium: 'Oil on Canvas',  year: 2023,
    src: '/images/file_14---d6d37114-4da7-4cdf-896d-5b361bf9ac99.jpg',
    desc: 'Painted in a single long session to preserve the immediacy of the first instinct. A muted palette was chosen deliberately — not for mood, but to force the composition to carry the weight that color usually handles.',
  },
  {
    id: 8,  title: 'MOTION VIII',        medium: 'Acrylic',        year: 2023,
    src: '/images/file_15---cfdd2a00-8c9e-4367-8b88-c149ce15db2a.jpg',
    desc: 'The subject is movement itself — not a moving thing. Gestural strokes radiate outward from a fixed center, trying to capture the moment just after a force is applied. Paint as record of physical action.',
  },
  {
    id: 9,  title: 'DEPTH IX',           medium: 'Oil on Canvas',  year: 2023,
    src: '/images/file_16---a29e17b8-1972-4c3d-af3c-e4f65981a95f.jpg',
    desc: 'Dozens of transparent glaze layers, each one shifting the value relationships underneath. The depth is optical, not physical — the canvas surface is flat, but the eye insists otherwise. An illusion earned through patience.',
  },
  {
    id: 10, title: 'PATTERN X',          medium: 'Mixed Media',    year: 2023,
    src: '/images/file_17---f463b1dd-1139-4fad-81a9-b4b5bddd0ef0.jpg',
    desc: 'A geometric grid interrupted by hand-drawn imperfections that kept breaking through. I stopped trying to correct them. The irregularities became the most honest part of the piece.',
  },
  {
    id: 11, title: 'TENSION XI',         medium: 'Charcoal',       year: 2023,
    src: '/images/file_19---7fd47930-b43e-4e33-a1d0-ce5384175a40.jpg',
    desc: 'A charcoal study about the relationship between light and the absence of it. Heavy blacks pressed hard into the paper contrast with areas left untouched. Negative space as active element, not empty background.',
  },
  {
    id: 12, title: 'SIGNAL XII',         medium: 'Oil on Canvas',  year: 2023,
    src: '/images/file_20---4fa92226-8c06-4344-836a-2745c8ec1072.jpg',
    desc: 'Branching paths that narrow and dissolve toward the edges. I was thinking about the way a thought fades when you stop paying attention to it — vivid at the center, gone at the margins.',
  },
  {
    id: 13, title: 'THRESHOLD XIII',     medium: 'Mixed Media',    year: 2023,
    src: '/images/file_21---7f73c515-6959-4117-bc6b-a178b7e1f1fa.jpg',
    desc: 'Made between two academic years, at a transitional point. The composition is divided — not balanced, divided. One foot somewhere familiar, one somewhere still unknown. I think it shows.',
  },
  {
    id: 14, title: 'MONSTER',            medium: 'Marker',         year: 2026, status: 'PHYSICAL',
    src: '/images/file_26---176ca328-7aa6-47ac-8678-3147590dfd1e.jpg',
    desc: 'A childs imaginative marker drawing depicting a towering red monster with thin legs and a single eye. Written in bold letters at the top: MONSTER.',
  },
  {
    id: 15, title: 'HOUSE AND TREE',     medium: 'Marker',         year: 2026, status: 'PHYSICAL',
    src: '/images/file_28---42038613-cd61-482c-96be-7f5090d24bb4.jpg',
    desc: 'A childs colorful marker drawing featuring a house with chimney smoke, a green tree, yellow sun, blue sky with clouds, and figures below.',
  },
  {
    id: 16, title: 'CLOWN PORTRAIT',      medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_27---5cc231a4-9e3e-4c3e-8804-8c95a0e0000e.jpg',
    desc: 'A watercolor painting in a spiral sketchbook depicting a person with clown-inspired features. Vibrant colors and expressive brushwork capture a theatrical mood.',
  },
  {
    id: 17, title: 'FRUIT STILL LIFE',    medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_29---436fe3f3-a255-4e3a-aaed-3b9b2a4c14a4.jpg',
    desc: 'A watercolor still life featuring fruits in a composition with warm lighting and soft shadows.',
  },
  {
    id: 18, title: 'COLOR STUDY',         medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_30---d7b1cafb-40a7-4744-9160-c20abb329311.jpg',
    desc: 'A geometric pattern and color study exploring composition and chroma relationships in watercolor.',
  },
  {
    id: 19, title: 'FLORAL STUDY',        medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_31---47b3bd96-ae79-438e-a21b-8a39940d7025.jpg',
    desc: 'A delicate watercolor floral study with soft petals and flowing forms.',
  },
  {
    id: 20, title: 'DOG PORTRAIT',        medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_32---22a1e60c-02cf-4dc7-bea6-e5f54059a36d.jpg',
    desc: 'A watercolor portrait of a dog with expressive eyes and textured fur rendered through wet-on-wet techniques.',
  },
  {
    id: 21, title: 'WATERCOLOR LANDSCAPE', medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_33---e872272a-94bc-4b74-abab-fa2bfe270037.jpg',
    desc: 'A landscape painting capturing atmospheric perspective and natural light in watercolor.',
  },
  {
    id: 22, title: 'TIGER MURAL',         medium: 'Mural',          year: 2026, status: 'PHYSICAL',
    src: '/images/file_35---32e01751-1807-42c5-ab2f-348082093d0b.jpg',
    desc: 'A large mural of a roaring tigers head on a light-colored wall. The vibrant tiger dominates the composition with powerful brushstrokes and intense expression.',
  },
  {
    id: 23, title: 'MAN WITH GLASSES',    medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_45---63d5078b-35ae-446d-be59-28d59f1fa149.jpg',
    desc: 'A stylized watercolor illustration of a man with long hair, glasses, and a full beard. Rendered in a distinctive artistic style with confident brushwork.',
  },
  {
    id: 24, title: 'BEARDED MAN',          medium: 'Watercolor',     year: 2026, status: 'PHYSICAL',
    src: '/images/file_46---efd60167-05c3-4394-ae97-47632daded2d.jpg',
    desc: 'A watercolor portrait featuring a bearded man with expressive features and artistic flair.',
  },
  {
    id: 25, title: 'ARCHITECTURAL SKETCH', medium: 'Pencil',         year: 2026, status: 'PHYSICAL',
    src: '/images/file_36---fef23c14-9e17-42a9-a3b4-a10b4a435db1.jpg',
    desc: 'A detailed pencil architectural sketch capturing structure and form with precision linework.',
  },
  {
    id: 26, title: 'KURUKAFA',            medium: 'Pencil',        year: 2022,
    src: '/images/Kurukafa.png',
    desc: 'A skull rendered in graphite — not as a symbol of death but as an exercise in structure. The cranium is one of the most complex forms to get right. I came back to this drawing three times before I let it be.',
  },
  {
    id: 27, title: 'EARLY WORK I',        medium: 'Mixed Media',   year: 2020,
    src: '/images/IMG_20200314_205556.jpg',
    desc: 'One of my earliest pieces kept. Rough in a way I no longer am — less considered, more instinctive. Looking at it now, there is an energy in the marks that I sometimes miss in more deliberate work.',
  },
  {
    id: 28, title: 'SESSION STUDY I',     medium: 'Mixed Media',   year: 2020,
    src: '/images/IMG_20200829_131256.jpg',
    desc: 'From a long afternoon session in August 2020. Made quickly, without overthinking. The directness of the marks is what keeps it interesting to me.',
  },
  {
    id: 29, title: 'SESSION STUDY II',    medium: 'Mixed Media',   year: 2020,
    src: '/images/IMG_20200829_132851.jpg',
    desc: 'Continued from the same session. By this point in the afternoon my hand had loosened — the hesitation of the first marks was gone and something more honest started to come through.',
  },
  {
    id: 30, title: 'SESSION STUDY III',   medium: 'Mixed Media',   year: 2020,
    src: '/images/IMG_20200829_134200.jpg',
    desc: 'Third piece from the August 2020 session. I was exploring the same formal problem from different angles — what changes when you approach the same subject with a different entry point.',
  },
  {
    id: 31, title: 'SESSION STUDY IV',    medium: 'Mixed Media',   year: 2020,
    src: '/images/IMG_20200829_134409.jpg',
    desc: 'The fourth in the session. Fatigue starts to show — and that is not always a bad thing. The controlled decisions fall away and you are left with more direct responses.',
  },
  {
    id: 32, title: 'SESSION STUDY V',     medium: 'Mixed Media',   year: 2020,
    src: '/images/IMG_20200829_140438.jpg',
    desc: 'The last piece from that August afternoon. By the end of a long session the work either collapses or finds something essential. This one found something.',
  },
  {
    id: 33, title: 'NOCTURNE',            medium: 'Mixed Media',   year: 2021,
    src: '/images/IMG_20211118_235908.jpg',
    desc: 'Made late at night in November 2021. There is a different quality to work done past midnight — a quieter filter on decision-making. Less performance, more honesty.',
  },
  {
    id: 34, title: 'FIGURE STUDY I',      medium: 'Mixed Media',   year: 2022,
    src: '/images/IMG_20220508_213610.jpg',
    desc: 'A figure study from 2022. I was paying attention to weight distribution — how the body communicates balance and intention without needing a face or expression.',
  },
  {
    id: 35, title: 'FIGURE STUDY II',     medium: 'Mixed Media',   year: 2022,
    src: '/images/IMG-20220515-WA0005.jpeg',
    desc: 'A companion study to the previous. Same preoccupations — gesture, weight, posture. Two versions of the same question rarely give the same answer.',
  },
  {
    id: 36, title: 'MAY STUDY I',         medium: 'Mixed Media',   year: 2022,
    src: '/images/IMG_20220525_092620.jpg',
    desc: 'Morning work from May 2022. Morning light in the studio changes everything — harder shadows, cooler temperature. The work reflects that.',
  },
  {
    id: 37, title: 'MAY STUDY II',        medium: 'Mixed Media',   year: 2022,
    src: '/images/IMG_20220526_210349.jpg',
    desc: 'From the following evening. The same subject approached differently when the light has shifted and the energy of the day has settled.',
  },
  {
    id: 38, title: 'MAY STUDY III',       medium: 'Mixed Media',   year: 2022,
    src: '/images/IMG_20220526_210412.jpg',
    desc: 'Made within minutes of the previous piece — a second attempt at the same composition. Not a correction, a continuation.',
  },
  {
    id: 39, title: 'SUMMER STUDY',        medium: 'Mixed Media',   year: 2022,
    src: '/images/IMG_20220718_220804.jpg',
    desc: 'July in Istanbul. The heat makes you work faster, commit sooner. There is less time to second-guess yourself when the medium is drying before you finish the thought.',
  },
  {
    id: 40, title: 'AUTUMN STUDY',        medium: 'Mixed Media',   year: 2022,
    src: '/images/IMG_20220925_151943.jpg',
    desc: 'September, the light starting to change. I find autumn the most productive season — something about the shortening days makes the time in the studio feel more deliberate.',
  },
  {
    id: 41, title: 'SPRING WORK',         medium: 'Mixed Media',   year: 2023,
    src: '/images/IMG_20230406_020218.jpg',
    desc: 'April 2023, past 2am. One of those sessions where I had no intention of working and ended up staying for hours. The best pieces often start that way.',
  },
  {
    id: 42, title: 'LATE SUMMER',         medium: 'Mixed Media',   year: 2025,
    src: '/images/IMG_20250831_194420_970.jpg',
    desc: 'End of August 2025. A return to the studio after a period away. The distance shows — the marks are both looser and more considered, as if the break reset something useful.',
  },
  {
    id: 43, title: 'SEPTEMBER I',         medium: 'Mixed Media',   year: 2025,
    src: '/images/20250903_115020.jpg',
    desc: 'Early morning, September 3rd. Working at this hour feels like a different state — the studio is quiet and the decisions come from somewhere less guarded.',
  },
  {
    id: 44, title: 'SEPTEMBER II',        medium: 'Mixed Media',   year: 2025,
    src: '/images/20250903_125338.jpg',
    desc: 'Second piece from the same morning. The first one loosened the hand. This one moves more freely as a result.',
  },
  {
    id: 45, title: 'SEPTEMBER III',       medium: 'Mixed Media',   year: 2025,
    src: '/images/20250903_125348.jpg',
    desc: 'Still the same session, just minutes later. Testing whether one morning can hold multiple distinct pieces.',
  },
  {
    id: 46, title: 'SEPTEMBER IV',        medium: 'Mixed Media',   year: 2025,
    src: '/images/20250903_125354.jpg',
    desc: 'Fourth from the session. The composition decisions becoming more automatic let me focus on texture instead.',
  },
  {
    id: 47, title: 'SEPTEMBER V',         medium: 'Mixed Media',   year: 2025,
    src: '/images/20250903_125403.jpg',
    desc: 'The last piece from September 3rd. Five in one morning is too many and not enough. Each one taught me something about the limits of sustained focus.',
  },
  {
    id: 48, title: 'FEBRUARY',            medium: 'Mixed Media',   year: 2026,
    src: '/images/IMG-20260210-WA0003.jpeg',
    desc: 'February 2026. The most recent piece in this collection. Made during a period of transition — you can probably see it in the work even if you do not know the context.',
  },
];

