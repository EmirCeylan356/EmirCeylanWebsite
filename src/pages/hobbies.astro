---

<Layout title="HOBBIES — Emir Ceylan">
  <Header />

  <main class="flex-1" style="padding-top:80px;">

    <!-- ═══ ACTIVITIES — 3-Tab Interface ═════════════════════════════════════ -->
    <section id="activities" style="background:var(--bg-base); padding:48px 0 0;">
      <div class="max-w-7xl mx-auto px-8">
        <div class="flex items-end gap-4 mb-10">
          <p class="font-mono text-xs" style="color:var(--text-secondary); letter-spacing:0.15em; align-self:center;">01 /</p>
          <h2 class="text-5xl md:text-7xl font-black kinetic-text" style="color:var(--text-primary);">ACTIVITIES</h2>
          <div class="flex-1" style="background:var(--border-color); height:1px;"></div>
          <span class="text-xl font-black font-mono" style="color:var(--text-secondary);">/03</span>
        </div>

        <!-- Tab Navigation -->
        <div class="tab-nav flex gap-0 mb-0" style="border-bottom:1px solid var(--border-color);">
          <button class="tab-btn active" data-tab="sport">
            [ SPORT ]
          </button>
          <button class="tab-btn" data-tab="art">
            [ ART ]
          </button>
          <button class="tab-btn" data-tab="think">
            [ THINK ]
          </button>
        </div>
      </div>

      <!-- ── SPORT Tab ───────────────────────────────────────────────────── -->
      <div id="tab-sport" class="tab-panel active" style="background:var(--bg-base);">
        <div class="max-w-7xl mx-auto px-8 py-14">
          <div class="grid md:grid-cols-2 gap-16 items-start">

            <!-- Left: intro -->
            <div>
              <p class="font-mono text-xs mb-4" style="color:var(--text-secondary); letter-spacing:0.15em;">PHYSICAL REALITY</p>
              <h3 class="text-4xl md:text-5xl font-black glow-text mb-6" style="line-height:1;">THE BODY<br>AS PRACTICE</h3>
              <p class="text-base mb-5" style="color:var(--text-secondary); line-height:1.7;">
                I train Brazilian Jiu-Jitsu as a blue belt. The mat is one of the few places where thinking too much will get you tapped out — you have to react, adapt, and accept when you lose. I've been submitted by smaller people more times than I can count, and that's the point.
              </p>
              <p class="text-base mb-5" style="color:var(--text-secondary); line-height:1.7;">
                Archery came later. It's the opposite of BJJ in almost every way — no opponent, no urgency, just you and the stillness between breaths. The arrow doesn't care how you're feeling that day.
              </p>
              <p class="text-base" style="color:var(--text-secondary); line-height:1.7;">
                Daily conditioning keeps everything running. Not for aesthetics — for the simple fact that having energy changes how you move through the rest of life.
              </p>
            </div>

            <!-- Right: discipline cards -->
            <div class="flex flex-col gap-4">

              <div class="sport-card p-6" style="border:1px solid var(--border-color); background:transparent;">
                <div class="flex items-center gap-4 mb-3">
                  <span class="font-mono text-2xl font-black glow-text">BJJ</span>
                  <span class="font-mono text-xs px-2 py-1" style="border:1px solid var(--border-color); color:var(--accent-dim);">BLUE BELT</span>
                </div>
                <p class="text-sm font-mono" style="color:var(--text-secondary); line-height:1.6;">Brazilian Jiu-Jitsu. Ground grappling, positional control, submissions. The sport where the smaller person can win if they're smarter.</p>
              </div>

              <div class="sport-card p-6" style="border:1px solid var(--border-color); background:transparent;">
                <div class="flex items-center gap-4 mb-3">
                  <span class="font-mono text-2xl font-black glow-text">ARCHERY</span>
                  <span class="font-mono text-xs px-2 py-1" style="border:1px solid var(--border-color); color:var(--accent-dim);">RECURVE</span>
                </div>
                <p class="text-sm font-mono" style="color:var(--text-secondary); line-height:1.6;">Focus, breath control, stillness under pressure. The discipline of archery is mostly about learning to do nothing while everything tries to make you flinch.</p>
              </div>

              <div class="sport-card p-6" style="border:1px solid var(--border-color); background:transparent;">
                <div class="flex items-center gap-4 mb-3">
                  <span class="font-mono text-2xl font-black glow-text">CONDITIONING</span>
                  <span class="font-mono text-xs px-2 py-1" style="border:1px solid var(--border-color); color:var(--accent-dim);">DAILY</span>
                </div>
                <p class="text-sm font-mono" style="color:var(--text-secondary); line-height:1.6;">Strength and endurance work that supports everything else. Consistency over intensity. The goal is showing up tomorrow.</p>
              </div>

            </div>
          </div>
        </div>
      </div>

      <!-- ── ART Tab ─────────────────────────────────────────────────────── -->
      <div id="tab-art" class="tab-panel" style="background:var(--bg-surface);">
        <div class="max-w-7xl mx-auto px-8 py-14">
          <div class="grid md:grid-cols-2 gap-16 items-start mb-14">

            <!-- Left: intro -->
            <div>
              <p class="font-mono text-xs mb-4" style="color:var(--text-secondary); letter-spacing:0.15em;">THE STUDIO</p>
              <h3 class="text-4xl md:text-5xl font-black glow-text mb-6" style="line-height:1;">OIL<br>PAINTING</h3>
              <p class="text-base mb-5" style="color:var(--text-secondary); line-height:1.7;">
                I've been painting with oils since I was a teenager. There's something about a medium that dries slowly and demands commitment — you can't undo a stroke, you can only paint over it, and you carry every previous decision forward.
              </p>
              <p class="text-base mb-5" style="color:var(--text-secondary); line-height:1.7;">
                Most of my work starts without a clear plan. I mix a color that feels right, make a mark, and respond to it. The discipline is in resisting the urge to over-explain — in painting, too much intention usually kills the thing you were trying to make.
              </p>
              <p class="text-base" style="color:var(--text-secondary); line-height:1.7;">
                I work across oil, acrylic, charcoal, and mixed media. The gallery below is the work that made it past my own editing — 13 pieces kept from the ones that didn't.
              </p>
            </div>

            <!-- Right: stats -->
            <div class="flex flex-col gap-6">
              <div style="border-left:2px solid var(--accent); padding-left:20px;">
                <div class="font-black text-5xl glow-text">13</div>
                <div class="font-mono text-xs mt-1" style="color:var(--text-secondary); letter-spacing:0.12em;">SELECTED WORKS</div>
              </div>
              <div style="border-left:2px solid var(--border-color); padding-left:20px;">
                <div class="font-black text-5xl" style="color:var(--accent-dim);">OIL</div>
                <div class="font-mono text-xs mt-1" style="color:var(--text-secondary); letter-spacing:0.12em;">PRIMARY MEDIUM</div>
              </div>
              <div style="border-left:2px solid var(--border-color); padding-left:20px;">
                <div class="font-black text-5xl" style="color:var(--text-secondary);">2023–</div>
                <div class="font-mono text-xs mt-1" style="color:var(--text-secondary); letter-spacing:0.12em;">ACTIVE PERIOD</div>
              </div>
            </div>

          </div>

          <!-- Gallery -->
          <div class="mb-2">
            <p class="text-xs font-mono" style="color:var(--text-secondary); letter-spacing:0.12em;">← SCROLL TO EXPLORE · CLICK IMAGE TO OPEN →</p>
          </div>

          <div id="art-viewport" class="relative overflow-hidden" style="height:68vh; touch-action:pan-y;">
            <div id="art-bg" class="absolute inset-0 pointer-events-none art-bg-grid"></div>

            <div id="art-track" class="absolute top-0 left-0 flex items-center gap-10 px-10" style="height:100%; width:max-content; will-change:transform;">
              {artworks.map((d) => (
                <div class="art-item group flex-shrink-0 relative cursor-pointer" data-id={d.id}
                  style="width:300px; height:400px; transition:transform 0.4s ease;">
                  <div class="art-frame relative w-full h-full overflow-hidden" style="border:1px solid var(--border-color);">
                    <img src={d.src} alt={d.title} class="art-img w-full h-full object-cover" loading="lazy"
                      style="filter:brightness(0.82) contrast(1.1) grayscale(0.3); transition:filter 0.45s ease;" />
                    <div class="art-grain absolute inset-0 pointer-events-none" style="opacity:0.25;"></div>
                    <!-- Title tag -->
                    <div class="absolute top-0 left-0 right-0 translate-y-[-100%] group-hover:translate-y-0 transition-transform duration-300 z-20 px-3 py-2" style="background:var(--accent);">
                      <span class="text-black text-[10px] font-black font-mono tracking-widest">{d.title}</span>
                    </div>
                    <!-- Info panel -->
                    <div class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 z-20 p-3" style="background:rgba(0,0,0,0.92); border-top:1px solid var(--border-color);">
                      <p class="text-[10px] font-mono mb-1" style="color:var(--accent);">MEDIUM: {d.medium} | {d.year}</p>
                      <p class="text-[10px] font-mono" style="color:var(--text-secondary);">CLICK TO VIEW →</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div style="height:1px; background:rgba(0,255,65,0.08);">
            <div id="art-progress" style="height:100%; width:0%; background:var(--primary-green); transition:none;"></div>
          </div>
        </div>
      </div>

      <!-- ── THINK Tab ───────────────────────────────────────────────────── -->
      <div id="tab-think" class="tab-panel" style="background:var(--bg-base);">
        <div class="max-w-7xl mx-auto px-8 py-14">
          <div class="grid md:grid-cols-2 gap-16 items-start">

            <!-- Chess -->
            <div>
              <p class="font-mono text-xs mb-4" style="color:var(--text-secondary); letter-spacing:0.15em;">CURIOSITY & STRATEGY</p>
              <h3 class="text-4xl md:text-5xl font-black glow-text mb-6" style="line-height:1;">CHESS<br>& BOOKS</h3>

              <div class="mb-10 p-6" style="border:1px solid rgba(0,255,65,0.25); background:transparent;">
                <div class="flex items-center gap-4 mb-4">
                  <span class="font-mono text-3xl font-black glow-text">♟</span>
                  <div>
                    <div class="font-black text-xl glow-text">CHESS</div>
                    <div class="font-mono text-xs" style="color:var(--text-secondary); letter-spacing:0.1em;">1800 ELO — RAPID</div>
                  </div>
                </div>
                <p class="text-sm font-mono mb-3" style="color:var(--text-secondary); line-height:1.7;">
                  I've been playing chess seriously for a few years. At 1800 I'm comfortable with most tactical patterns — the gap now is not calculation, it's judgment about when to exchange pieces and when to keep the tension.
                </p>
                <p class="text-sm font-mono" style="color:var(--text-secondary); line-height:1.7;">
                  I study endgames more than openings. Openings are memorized — endgames are understood. That distinction matters.
                </p>
              </div>

            </div>

            <!-- Books -->
            <div>
              <p class="font-mono text-xs mb-6" style="color:var(--text-secondary); letter-spacing:0.15em;">CURRENTLY READING / HAVE READ</p>

              <div class="flex flex-col gap-4">

                <div class="book-card p-5" style="border:1px solid var(--border-color); background:rgba(0,255,65,0.02);">
                  <div class="flex items-start gap-4">
                    <span class="font-mono font-black text-lg glow-text mt-1">I.</span>
                    <div>
                      <div class="font-black text-base" style="color:var(--accent);">Crime and Punishment</div>
                      <div class="font-mono text-xs mb-2" style="color:var(--text-secondary);">Fyodor Dostoevsky</div>
                      <p class="text-xs font-mono" style="color:rgba(0,204,51,0.65); line-height:1.6;">A man who convinces himself his own logic is airtight, then watches it collapse under the weight of what he can't reason away. The most honest book about arrogance I've read.</p>
                    </div>
                  </div>
                </div>

                <div class="book-card p-5" style="border:1px solid var(--border-color); background:rgba(0,255,65,0.02);">
                  <div class="flex items-start gap-4">
                    <span class="font-mono font-black text-lg glow-text mt-1">II.</span>
                    <div>
                      <div class="font-black text-base" style="color:var(--accent);">Sapiens</div>
                      <div class="font-mono text-xs mb-2" style="color:var(--text-secondary);">Yuval Noah Harari</div>
                      <p class="text-xs font-mono" style="color:rgba(0,204,51,0.65); line-height:1.6;">Useful for putting everything in context. The agricultural revolution as the greatest con in human history is a framing I think about more than I expected when I first read it.</p>
                    </div>
                  </div>
                </div>

                <div class="book-card p-5" style="border:1px solid var(--border-color); background:rgba(0,255,65,0.02);">
                  <div class="flex items-start gap-4">
                    <span class="font-mono font-black text-lg glow-text mt-1">III.</span>
                    <div>
                      <div class="font-black text-base" style="color:var(--accent);">The Origin of Species</div>
                      <div class="font-mono text-xs mb-2" style="color:var(--text-secondary);">Charles Darwin</div>
                      <p class="text-xs font-mono" style="color:rgba(0,204,51,0.65); line-height:1.6;">Still astonishing that one person observed this much and made it cohere. The argument builds so carefully that by the time you reach the conclusion, it already feels inevitable.</p>
                    </div>
                  </div>
                </div>

              </div>
            </div>

          </div>
        </div>
      </div>

    </section>

    <!-- ═══ TRAVELS — SVG World Map ════════════════════════════════════════════ -->
    <section id="travels" style="background:var(--bg-base); padding:80px 0 0; border-top:1px solid var(--border-color);">
      <div class="max-w-7xl mx-auto px-8 pb-10">
        <div class="flex items-end gap-4">
          <h2 class="text-5xl md:text-7xl font-black kinetic-text" style="color:var(--text-primary);">TRAVELS</h2>
          <div class="flex-1" style="background:var(--border-color); height:1px;"></div>
          <span class="text-xl font-black font-mono" style="color:var(--text-secondary);">/{travels.length.toString().padStart(2,'0')}</span>
        </div>
        <div id="map-coords" class="font-mono text-xs mt-3" style="color:var(--text-secondary); opacity:0.5; letter-spacing:0.12em;">
          MOVE CURSOR OVER MAP — LAT: —  LON: —
        </div>
      </div>

      <div style="position:relative; width:100%; overflow:hidden; border-top:1px solid var(--border-color); border-bottom:1px solid var(--border-color);">
        <svg id="travel-map" viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid meet"
          style="width:100%; max-height:72vh; display:block; background:#0A0A0D; cursor:crosshair;">

          <g stroke="rgba(51,51,56,0.8)" stroke-width="0.5" fill="none">
            <line x1="0" y1="79"  x2="1000" y2="79"  />
            <line x1="0" y1="145" x2="1000" y2="145" />
            <line x1="0" y1="182" x2="1000" y2="182" />
            <line x1="0" y1="211" x2="1000" y2="211" />
            <line x1="0" y1="233" x2="1000" y2="233" />
            <line x1="0" y1="250" x2="1000" y2="250" />
            <line x1="0" y1="267" x2="1000" y2="267" />
            <line x1="0" y1="289" x2="1000" y2="289" />
            <line x1="0" y1="318" x2="1000" y2="318" />
            <line x1="83"  y1="0" x2="83"  y2="500" />
            <line x1="167" y1="0" x2="167" y2="500" />
            <line x1="250" y1="0" x2="250" y2="500" />
            <line x1="333" y1="0" x2="333" y2="500" />
            <line x1="417" y1="0" x2="417" y2="500" />
            <line x1="500" y1="0" x2="500" y2="500" />
            <line x1="583" y1="0" x2="583" y2="500" />
            <line x1="667" y1="0" x2="667" y2="500" />
            <line x1="750" y1="0" x2="750" y2="500" />
            <line x1="833" y1="0" x2="833" y2="500" />
            <line x1="917" y1="0" x2="917" y2="500" />
          </g>

          <g style="font-family:monospace; font-size:7px; fill:rgba(138,138,147,0.4);">
            <text x="6" y="248">0°</text>
            <text x="6" y="143">60°N</text>
            <text x="6" y="213">30°N</text>
            <text x="502" y="10">0°</text>
            <text x="582" y="10">30°E</text>
          </g>

          <g fill="rgba(30,30,36,0.9)" stroke="rgba(51,51,56,1)" stroke-width="0.8" stroke-linejoin="round">
            <path d={C.northAmerica} />
            <path d={C.southAmerica} />
            <path d={C.greenland} />
            <path d={C.europe} />
            <path d={C.uk} />
            <path d={C.scandinavia} />
            <path d={C.northAfrica} />
            <path d={C.subAfrica} />
            <path d={C.middleEast} />
            <path d={C.asia} />
            <path d={C.india} />
            <path d={C.seAsia} />
            <path d={C.japan} />
            <path d={C.australia} />
          </g>

          {travels.map(t => (
            <path
              d={`M ${homeBase.x},${homeBase.y} Q ${t.cpx},${t.cpy} ${t.x},${t.y}`}
              fill="none" stroke="rgba(214,255,0,0.3)" stroke-width="1"
              stroke-dasharray="4 8" class="flight-path"
            />
          ))}

          <g class="home-node">
            <circle cx={homeBase.x} cy={homeBase.y} r="3.5" fill="#fff" />
            <circle cx={homeBase.x} cy={homeBase.y} r="3.5" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1" class="pulse-home" />
            <text x={homeBase.x + 7} y={homeBase.y + 3} style="font-family:monospace; font-size:8px; fill:rgba(138,138,147,0.7); letter-spacing:0.08em;">IST [HOME]</text>
          </g>

          {travels.map(t => (
            <g class="travel-node" data-id={t.id} style="cursor:pointer;">
              <circle cx={t.x} cy={t.y} r="12" fill="rgba(0,0,0,0)" />
              <circle cx={t.x} cy={t.y} r="3.5" fill="var(--accent)" class="node-dot" />
              <circle cx={t.x} cy={t.y} r="3.5" fill="none" stroke="var(--accent)" stroke-width="1" class="pulse-ring" />
              <text x={t.x + 7} y={t.y + 3} style="font-family:monospace; font-size:8px; fill:rgba(214,255,0,0.6); letter-spacing:0.06em;">{t.city}</text>
            </g>
          ))}
        </svg>
      </div>

      <div class="max-w-7xl mx-auto px-8 py-6 flex gap-8 flex-wrap">
        <div class="flex items-center gap-2">
          <div style="width:8px; height:8px; border-radius:50%; background:#fff;"></div>
          <span class="font-mono text-[10px]" style="color:var(--text-secondary); letter-spacing:0.1em;">HOME BASE</span>
        </div>
        <div class="flex items-center gap-2">
          <div style="width:8px; height:8px; border-radius:50%; background:var(--accent);"></div>
          <span class="font-mono text-[10px]" style="color:var(--text-secondary); letter-spacing:0.1em;">VISITED — CLICK TO OPEN PASSPORT</span>
        </div>
      </div>
      <div style="padding-bottom:80px;"></div>
    </section>

  </main>

  <!-- ═══ ART LIGHTBOX MODAL ═══════════════════════════════════════════════════ -->
  <div id="art-lightbox" class="fixed inset-0 z-[400] flex items-center justify-center p-4 md:p-8" style="background:rgba(0,0,0,0.95); display:none;">
    <div id="art-lightbox-content" class="relative w-full max-w-5xl max-h-[90vh] flex flex-col md:flex-row overflow-hidden"
      style="border:1px solid var(--border-color);">
      <!-- Image panel -->
      <div class="art-lb-img-wrap flex-shrink-0" style="width:100%; max-width:480px; background:#0a0a0a;">
        <img id="art-lb-img" src="" alt="" style="width:100%; height:100%; object-fit:cover; display:block; min-height:300px; max-height:70vh;" loading="lazy" />
      </div>
      <!-- Info panel -->
      <div class="art-lb-info flex-1 flex flex-col overflow-y-auto" style="background:var(--bg-base); padding:40px; border-left:1px solid var(--border-color);">
        <div id="art-lb-id" class="font-mono text-xs mb-4" style="color:var(--text-secondary); letter-spacing:0.15em;"></div>
        <h3 id="art-lb-title" class="font-black text-3xl mb-2 glow-text" style="font-family:'Space Grotesk'; line-height:1;"></h3>
        <div class="flex gap-4 mb-6">
          <span id="art-lb-medium" class="font-mono text-xs" style="color:var(--text-secondary);"></span>
          <span id="art-lb-year" class="font-mono text-xs" style="color:var(--text-secondary);"></span>
        </div>
        <div style="height:1px; background:var(--border-color); margin-bottom:24px;"></div>
        <p id="art-lb-desc" class="text-sm leading-relaxed flex-1" style="color:var(--text-secondary); line-height:1.75;"></p>
        <!-- Handwritten caption -->
        <div class="mt-8 pt-6" style="border-top:1px solid var(--border-color);">
          <p id="art-lb-caption" class="font-handwritten text-xl" style="color:var(--text-secondary);"></p>
        </div>
      </div>
      <!-- Close -->
      <button id="art-lb-close" class="absolute top-4 right-4 font-mono text-sm font-bold"
        style="color:var(--text-secondary); background:none; border:none; cursor:pointer; letter-spacing:0.1em; z-index:10;">
        × CLOSE
      </button>
    </div>
  </div>

  <!-- ═══ PASSPORT CARD ════════════════════════════════════════════════════════ -->
  <div id="passport-card" class="fixed top-0 right-0 h-full z-[300] pointer-events-none" style="width:min(420px,100vw);">
    <div class="relative h-full flex flex-col" style="background:var(--bg-surface); border-left:1px solid var(--border-color);">
      <div id="passport-photo-wrap" style="height:280px; overflow:hidden; border-bottom:1px solid var(--border-color); position:relative; background:#0a0a0a; flex-shrink:0;">
        <img id="passport-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;filter:grayscale(1) contrast(1.15);" loading="lazy" />
        <div id="passport-no-photo" class="absolute inset-0 flex flex-col items-center justify-center gap-2">
          <span class="font-mono text-xs" style="color:var(--text-secondary); opacity:0.4;">[ NO PHOTO YET ]</span>
        </div>
        <div class="absolute top-4 left-4 px-3 py-1" style="background:rgba(214,255,0,0.08); border:1px solid var(--border-color);">
          <span id="passport-status" class="font-mono text-[10px] font-bold" style="color:var(--accent); letter-spacing:0.15em;"></span>
        </div>
      </div>
      <div style="padding:32px; flex:1; overflow:auto;">
        <div style="border-bottom:1px solid rgba(0,255,65,0.08); padding-bottom:20px; margin-bottom:20px;">
          <div id="passport-date" class="font-mono text-[10px] mb-4" style="color:var(--text-secondary); letter-spacing:0.15em;"></div>
          <div id="passport-city" class="font-black glow-text" style="font-family:'Space Grotesk'; font-size:clamp(32px,8vw,52px); line-height:1; margin-bottom:4px;"></div>
          <div id="passport-country" class="font-mono text-xs" style="color:var(--text-secondary); letter-spacing:0.1em;"></div>
        </div>
        <p id="passport-memory" class="font-mono text-sm" style="color:var(--text-secondary); line-height:1.7; font-style:italic;"></p>
        <div id="passport-coords" class="font-mono text-[10px] mt-6" style="color:var(--text-secondary); letter-spacing:0.1em;"></div>
      </div>
      <button id="passport-close" class="absolute top-4 right-4 font-mono text-xs"
        style="color:var(--text-secondary); background:none; border:none; cursor:pointer; letter-spacing:0.1em;">
        × CLOSE
      </button>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  /* ── Tab navigation ──────────────────────────────────────────────────────── */
  .tab-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 14px 28px;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
    margin-bottom: -1px;
  }
  .tab-btn:hover { color: var(--text-primary); }
  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── Tab panels ──────────────────────────────────────────────────────────── */
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── Sport cards ─────────────────────────────────────────────────────────── */
  .sport-card {
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .sport-card:hover {
    border-color: var(--accent) !important;
    box-shadow: 0 0 10px var(--accent-glow) !important;
  }

  /* ── Book cards ──────────────────────────────────────────────────────────── */
  .book-card {
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .book-card:hover {
    border-color: var(--accent) !important;
    box-shadow: 0 0 10px var(--accent-glow) !important;
  }

  /* ── Art Gallery ─────────────────────────────────────────────────────────── */
  .art-bg-grid {
    background-image:
      linear-gradient(rgba(214,255,0,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(214,255,0,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .art-grain {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    mix-blend-mode: overlay;
  }

  .art-item:hover .art-img   { filter: brightness(1) contrast(1.05) grayscale(0) !important; }
  .art-item:hover .art-grain { opacity: 0 !important; }
  .art-item:hover            { transform: scale(1.03); }
  .art-item:hover .art-frame { border-color: var(--accent) !important; box-shadow: 0 0 12px var(--accent-glow); }

  #art-viewport.grabbing { cursor: grabbing; }

  @media (pointer: coarse) {
    #art-viewport {
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      height: 75vw;
      touch-action: pan-x;
    }
    #art-track { position:relative !important; transform:none !important; }
    .art-item  { scroll-snap-align: center; }
    #art-bg, #art-progress { display: none; }
  }

  /* ── Travel Map ──────────────────────────────────────────────────────────── */
  .flight-path {
    stroke-dasharray: 4 8;
    animation: flowDash 2s linear infinite;
  }
  @keyframes flowDash {
    from { stroke-dashoffset: 24; }
    to   { stroke-dashoffset: 0;  }
  }

  .pulse-ring, .pulse-home {
    transform-box: fill-box;
    transform-origin: center;
    animation: pulseNode 2.2s ease-out infinite;
  }
  .pulse-home { animation-duration: 3s; }

  @keyframes pulseNode {
    0%   { transform: scale(1);   opacity: 0.85; }
    100% { transform: scale(4.5); opacity: 0; }
  }

  .travel-node:hover .node-dot { opacity: 1; }
  .travel-node:hover text { fill: rgba(214,255,0,0.9) !important; }

  /* ── Art Lightbox ────────────────────────────────────────────────────────── */
  #art-lightbox.active { display: flex !important; }
  #art-lightbox-content { animation: lbSlide 0.4s cubic-bezier(0.16,1,0.3,1); }

  @keyframes lbSlide {
    from { transform: scale(0.94) translateY(20px); opacity: 0; }
    to   { transform: scale(1) translateY(0); opacity: 1; }
  }

  /* ── Passport Card ────────────────────────────────────────────────────────── */
  #passport-card { transform: translateX(100%); pointer-events: none; }
  #passport-card.open { pointer-events: all; }
</style>

<script>
  // ── Tab switching ──────────────────────────────────────────────────────────
  (function() {
    const buttons = document.querySelectorAll('.tab-btn');
    const panels  = document.querySelectorAll('.tab-panel');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        buttons.forEach(b => b.classList.remove('active'));
        panels.forEach(p  => p.classList.remove('active'));
        btn.classList.add('active');
        const panel = document.getElementById('tab-' + target);
        if (panel) {
          panel.classList.add('active');
          if (target === 'art') {
            // Delay so browser finishes laying out the newly-visible track
            setTimeout(() => window.dispatchEvent(new Event('resize')), 80);
          }
        }
      });
    });
  })();

  // ── Art Gallery horizontal drag/scroll ────────────────────────────────────
  (function() {
    if (window.matchMedia('(pointer: coarse)').matches) return;

    const viewport = document.getElementById('art-viewport');
    const track    = document.getElementById('art-track');
    const bgLayer  = document.getElementById('art-bg');
    const progress = document.getElementById('art-progress');
    if (!viewport || !track) return;

    let targetX = 0, currentX = 0, maxX = 0;
    let isOver = false, isDragging = false, dragStartX = 0, dragStartCurrent = 0;

    function calcMax() {
      const w = track.scrollWidth - viewport.offsetWidth;
      maxX = Math.max(0, w);
    }
    // Also recalc on first mouse-enter in case tab was hidden at load
    viewport.addEventListener('mouseenter', calcMax, { once: false });
    setTimeout(calcMax, 300);
    window.addEventListener('resize', calcMax);

    viewport.addEventListener('wheel', (e) => {
      if (!isOver) return;
      e.preventDefault();
      targetX -= e.deltaY * 1.3;
      targetX  = Math.max(-maxX, Math.min(0, targetX));
    }, { passive: false });

    viewport.addEventListener('mouseenter', () => { isOver = true; });
    viewport.addEventListener('mouseleave', () => { isOver = false; });

    viewport.addEventListener('mousedown', (e) => {
      isDragging = true; dragStartX = e.clientX; dragStartCurrent = targetX;
      viewport.classList.add('grabbing');
    });
    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      targetX = Math.max(-maxX, Math.min(0, dragStartCurrent + (e.clientX - dragStartX)));
    });
    window.addEventListener('mouseup', () => { isDragging = false; viewport.classList.remove('grabbing'); });

    function raf() {
      requestAnimationFrame(raf);
      currentX += (targetX - currentX) * 0.08;
      const x = Math.round(currentX * 100) / 100;
      track.style.transform = `translateX(${x}px)`;
      if (bgLayer) bgLayer.style.transform = `translateX(${x * 0.2}px)`;
      if (progress) progress.style.width = (maxX > 0 ? (Math.abs(x) / maxX) * 100 : 0) + '%';
    }
    raf();
  })();

  // ── Art Lightbox ───────────────────────────────────────────────────────────
  (function() {
    const artworksData = [
      { id: 1,  title: 'FORM STUDY I',          medium: 'Oil on Canvas', year: 2024, src: '/images/file_8---39151805-7313-4bb7-b8c8-1365aef884a3.jpg',         desc: 'An exploration of negative space and structural tension. Built up with palette knife strokes, allowing the medium to dictate form rather than the other way around. The result captures something contained and alive at the same time.' },
      { id: 2,  title: 'COMPOSITION II',         medium: 'Mixed Media',   year: 2024, src: '/images/file_9---c5cd81b7-8140-4595-8297-af32f0e2edba.jpg',          desc: 'Started as a charcoal sketch, then buried under translucent oil glazes until the original marks became ghosts beneath the surface. What you see is the result of a conversation between two different sessions, months apart.' },
      { id: 3,  title: 'LANDSCAPE III',          medium: 'Oil on Canvas', year: 2024, src: '/images/file_10---714a56fd-d4fb-4316-8629-c6f06a4db7a8.jpg',        desc: 'Painted from memory of the Bosphorus at dusk. The shift in color temperature from warm water to cool sky demanded constant re-evaluation — each decision about hue changed everything that came before it.' },
      { id: 4,  title: 'FIGURE IV',              medium: 'Acrylic',       year: 2024, src: '/images/file_11---e6cf7245-cda7-4ca8-884c-55c891575493.jpg',        desc: 'A study in how light defines mass — anatomy read through shadow rather than outline. The discipline here was in what I left unpainted. Every mark was a commitment, and every white area a deliberate silence.' },
      { id: 5,  title: 'ABSTRACTION V',          medium: 'Oil on Canvas', year: 2024, src: '/images/file_12---09cd522a-d5e5-433a-ac0f-d9c0c710c79a.jpg',        desc: 'Began with no composition in mind — only a feeling about two colors side by side. Each layer reacted to the previous, building a visual argument neither planned nor resolved. I stopped when it started answering back.' },
      { id: 6,  title: 'TEXTURE VI',             medium: 'Mixed Media',   year: 2024, src: '/images/file_13---f94eea51-a229-4b42-bcf4-f489c8824e9b.jpg',        desc: 'Impasto built up thick enough to cast shadows, then cut through with fine ink lines. The two processes fight each other on the surface. That friction is the point — neither wins, and the tension is what holds your eye.' },
      { id: 7,  title: 'STILLNESS VII',          medium: 'Oil on Canvas', year: 2023, src: '/images/file_14---d6d37114-4da7-4cdf-896d-5b361bf9ac99.jpg',        desc: 'Painted in a single long session to preserve the immediacy of the first instinct. A muted palette was chosen deliberately — not for mood, but to force the composition to carry the weight that color usually handles.' },
      { id: 8,  title: 'MOTION VIII',            medium: 'Acrylic',       year: 2023, src: '/images/file_15---cfdd2a00-8c9e-4367-8b88-c149ce15db2a.jpg',        desc: 'The subject is movement itself — not a moving thing. Gestural strokes radiate outward from a fixed center, trying to capture the moment just after a force is applied. Paint as record of physical action.' },
      { id: 9,  title: 'DEPTH IX',               medium: 'Oil on Canvas', year: 2023, src: '/images/file_16---a29e17b8-1972-4c3d-af3c-e4f65981a95f.jpg',        desc: 'Dozens of transparent glaze layers, each one shifting the value relationships underneath. The depth is optical, not physical — the canvas surface is flat, but the eye insists otherwise. An illusion earned through patience.' },
      { id: 10, title: 'PATTERN X',              medium: 'Mixed Media',   year: 2023, src: '/images/file_17---f463b1dd-1139-4fad-81a9-b4b5bddd0ef0.jpg',        desc: 'A geometric grid interrupted by hand-drawn imperfections that kept breaking through. I stopped trying to correct them. The irregularities became the most honest part of the piece.' },
      { id: 11, title: 'TENSION XI',             medium: 'Charcoal',      year: 2023, src: '/images/file_19---7fd47930-b43e-4e33-a1d0-ce5384175a40.jpg',        desc: 'A charcoal study about the relationship between light and the absence of it. Heavy blacks pressed hard into the paper contrast with areas left untouched. Negative space as active element, not empty background.' },
      { id: 12, title: 'SIGNAL XII',             medium: 'Oil on Canvas', year: 2023, src: '/images/file_20---4fa92226-8c06-4344-836a-2745c8ec1072.jpg',        desc: 'Branching paths that narrow and dissolve toward the edges. I was thinking about the way a thought fades when you stop paying attention to it — vivid at the center, gone at the margins.' },
      { id: 13, title: 'THRESHOLD XIII',         medium: 'Mixed Media',   year: 2023, src: '/images/file_21---7f73c515-6959-4117-bc6b-a178b7e1f1fa.jpg',        desc: 'Made between two academic years, at a transitional point. The composition is divided — not balanced, divided. One foot somewhere familiar, one somewhere still unknown. I think it shows.' },
      { id: 14, title: 'MONSTER',                medium: 'Marker',        year: 2026, src: '/images/file_26---176ca328-7aa6-47ac-8678-3147590dfd1e.jpg',        desc: 'A childs imaginative marker drawing depicting a towering red monster with thin legs and a single eye. Written in bold letters at the top: MONSTER.' },
      { id: 15, title: 'HOUSE AND TREE',         medium: 'Marker',        year: 2026, src: '/images/file_28---42038613-cd61-482c-96be-7f5090d24bb4.jpg',        desc: 'A childs colorful marker drawing featuring a house with chimney smoke, a green tree, yellow sun, blue sky with clouds, and figures below.' },
      { id: 16, title: 'CLOWN PORTRAIT',         medium: 'Watercolor',    year: 2026, src: '/images/file_27---5cc231a4-9e3e-4c3e-8804-8c95a0e0000e.jpg',        desc: 'A watercolor painting in a spiral sketchbook depicting a person with clown-inspired features. Vibrant colors and expressive brushwork capture a theatrical mood.' },
      { id: 17, title: 'FRUIT STILL LIFE',       medium: 'Watercolor',    year: 2026, src: '/images/file_29---436fe3f3-a255-4e3a-aaed-3b9b2a4c14a4.jpg',        desc: 'A watercolor still life featuring fruits in a composition with warm lighting and soft shadows.' },
      { id: 18, title: 'COLOR STUDY',            medium: 'Watercolor',    year: 2026, src: '/images/file_30---d7b1cafb-40a7-4744-9160-c20abb329311.jpg',        desc: 'A geometric pattern and color study exploring composition and chroma relationships in watercolor.' },
      { id: 19, title: 'FLORAL STUDY',           medium: 'Watercolor',    year: 2026, src: '/images/file_31---47b3bd96-ae79-438e-a21b-8a39940d7025.jpg',        desc: 'A delicate watercolor floral study with soft petals and flowing forms.' },
      { id: 20, title: 'DOG PORTRAIT',           medium: 'Watercolor',    year: 2026, src: '/images/file_32---22a1e60c-02cf-4dc7-bea6-e5f54059a36d.jpg',        desc: 'A watercolor portrait of a dog with expressive eyes and textured fur rendered through wet-on-wet techniques.' },
      { id: 21, title: 'WATERCOLOR LANDSCAPE',   medium: 'Watercolor',    year: 2026, src: '/images/file_33---e872272a-94bc-4b74-abab-fa2bfe270037.jpg',        desc: 'A landscape painting capturing atmospheric perspective and natural light in watercolor.' },
      { id: 22, title: 'TIGER MURAL',            medium: 'Mural',         year: 2026, src: '/images/file_35---32e01751-1807-42c5-ab2f-348082093d0b.jpg',        desc: 'A large mural of a roaring tigers head on a light-colored wall. The vibrant tiger dominates the composition with powerful brushstrokes and intense expression.' },
      { id: 23, title: 'MAN WITH GLASSES',       medium: 'Watercolor',    year: 2026, src: '/images/file_45---63d5078b-35ae-446d-be59-28d59f1fa149.jpg',        desc: 'A stylized watercolor illustration of a man with long hair, glasses, and a full beard. Rendered in a distinctive artistic style with confident brushwork.' },
      { id: 24, title: 'BEARDED MAN',            medium: 'Watercolor',    year: 2026, src: '/images/file_46---efd60167-05c3-4394-ae97-47632daded2d.jpg',        desc: 'A watercolor portrait featuring a bearded man with expressive features and artistic flair.' },
      { id: 25, title: 'ARCHITECTURAL SKETCH',   medium: 'Pencil',        year: 2026, src: '/images/file_36---fef23c14-9e17-42a9-a3b4-a10b4a435db1.jpg',        desc: 'A detailed pencil architectural sketch capturing structure and form with precision linework.' },
      { id: 26, title: 'KURUKAFA',               medium: 'Pencil',        year: 2022, src: '/images/Kurukafa.png',                                               desc: 'A skull rendered in graphite — not as a symbol of death but as an exercise in structure. The cranium is one of the most complex forms to get right. I came back to this drawing three times before I let it be.' },
      { id: 27, title: 'EARLY WORK I',           medium: 'Mixed Media',   year: 2020, src: '/images/IMG_20200314_205556.jpg',                                    desc: 'One of my earliest pieces kept. Rough in a way I no longer am — less considered, more instinctive. Looking at it now, there is an energy in the marks that I sometimes miss in more deliberate work.' },
      { id: 28, title: 'SESSION STUDY I',        medium: 'Mixed Media',   year: 2020, src: '/images/IMG_20200829_131256.jpg',                                    desc: 'From a long afternoon session in August 2020. Made quickly, without overthinking. The directness of the marks is what keeps it interesting to me.' },
      { id: 29, title: 'SESSION STUDY II',       medium: 'Mixed Media',   year: 2020, src: '/images/IMG_20200829_132851.jpg',                                    desc: 'Continued from the same session. By this point in the afternoon my hand had loosened — the hesitation of the first marks was gone and something more honest started to come through.' },
      { id: 30, title: 'SESSION STUDY III',      medium: 'Mixed Media',   year: 2020, src: '/images/IMG_20200829_134200.jpg',                                    desc: 'Third piece from the August 2020 session. I was exploring the same formal problem from different angles — what changes when you approach the same subject with a different entry point.' },
      { id: 31, title: 'SESSION STUDY IV',       medium: 'Mixed Media',   year: 2020, src: '/images/IMG_20200829_134409.jpg',                                    desc: 'The fourth in the session. Fatigue starts to show — and that is not always a bad thing. The controlled decisions fall away and you are left with more direct responses.' },
      { id: 32, title: 'SESSION STUDY V',        medium: 'Mixed Media',   year: 2020, src: '/images/IMG_20200829_140438.jpg',                                    desc: 'The last piece from that August afternoon. By the end of a long session the work either collapses or finds something essential. This one found something.' },
      { id: 33, title: 'NOCTURNE',               medium: 'Mixed Media',   year: 2021, src: '/images/IMG_20211118_235908.jpg',                                    desc: 'Made late at night in November 2021. There is a different quality to work done past midnight — a quieter filter on decision-making. Less performance, more honesty.' },
      { id: 34, title: 'FIGURE STUDY I',         medium: 'Mixed Media',   year: 2022, src: '/images/IMG_20220508_213610.jpg',                                    desc: 'A figure study from 2022. I was paying attention to weight distribution — how the body communicates balance and intention without needing a face or expression.' },
      { id: 35, title: 'FIGURE STUDY II',        medium: 'Mixed Media',   year: 2022, src: '/images/IMG-20220515-WA0005.jpeg',                                   desc: 'A companion study to the previous. Same preoccupations — gesture, weight, posture. Two versions of the same question rarely give the same answer.' },
      { id: 36, title: 'MAY STUDY I',            medium: 'Mixed Media',   year: 2022, src: '/images/IMG_20220525_092620.jpg',                                    desc: 'Morning work from May 2022. Morning light in the studio changes everything — harder shadows, cooler temperature. The work reflects that.' },
      { id: 37, title: 'MAY STUDY II',           medium: 'Mixed Media',   year: 2022, src: '/images/IMG_20220526_210349.jpg',                                    desc: 'From the following evening. The same subject approached differently when the light has shifted and the energy of the day has settled.' },
      { id: 38, title: 'MAY STUDY III',          medium: 'Mixed Media',   year: 2022, src: '/images/IMG_20220526_210412.jpg',                                    desc: 'Made within minutes of the previous piece — a second attempt at the same composition. Not a correction, a continuation.' },
      { id: 39, title: 'SUMMER STUDY',           medium: 'Mixed Media',   year: 2022, src: '/images/IMG_20220718_220804.jpg',                                    desc: 'July in Istanbul. The heat makes you work faster, commit sooner. There is less time to second-guess yourself when the medium is drying before you finish the thought.' },
      { id: 40, title: 'AUTUMN STUDY',           medium: 'Mixed Media',   year: 2022, src: '/images/IMG_20220925_151943.jpg',                                    desc: 'September, the light starting to change. I find autumn the most productive season — something about the shortening days makes the time in the studio feel more deliberate.' },
      { id: 41, title: 'SPRING WORK',            medium: 'Mixed Media',   year: 2023, src: '/images/IMG_20230406_020218.jpg',                                    desc: 'April 2023, past 2am. One of those sessions where I had no intention of working and ended up staying for hours. The best pieces often start that way.' },
      { id: 42, title: 'LATE SUMMER',            medium: 'Mixed Media',   year: 2025, src: '/images/IMG_20250831_194420_970.jpg',                                desc: 'End of August 2025. A return to the studio after a period away. The distance shows — the marks are both looser and more considered, as if the break reset something useful.' },
      { id: 43, title: 'SEPTEMBER I',            medium: 'Mixed Media',   year: 2025, src: '/images/20250903_115020.jpg',                                        desc: 'Early morning, September 3rd. Working at this hour feels like a different state — the studio is quiet and the decisions come from somewhere less guarded.' },
      { id: 44, title: 'SEPTEMBER II',           medium: 'Mixed Media',   year: 2025, src: '/images/20250903_125338.jpg',                                        desc: 'Second piece from the same morning. The first one loosened the hand. This one moves more freely as a result.' },
      { id: 45, title: 'SEPTEMBER III',          medium: 'Mixed Media',   year: 2025, src: '/images/20250903_125348.jpg',                                        desc: 'Still the same session, just minutes later. Testing whether one morning can hold multiple distinct pieces.' },
      { id: 46, title: 'SEPTEMBER IV',           medium: 'Mixed Media',   year: 2025, src: '/images/20250903_125354.jpg',                                        desc: 'Fourth from the session. Composition decisions became more automatic — let me focus on texture instead.' },
      { id: 47, title: 'SEPTEMBER V',            medium: 'Mixed Media',   year: 2025, src: '/images/20250903_125403.jpg',                                        desc: 'The last piece from September 3rd. Five in one morning is too many and not enough. Each one taught me something about the limits of sustained focus.' },
      { id: 48, title: 'FEBRUARY',               medium: 'Mixed Media',   year: 2026, src: '/images/IMG-20260210-WA0003.jpeg',                                   desc: 'February 2026. The most recent piece in this collection. Made during a period of transition — you can probably see it in the work even if you do not know the context.' },
    ];

    const captions = [
      'painted from a feeling, not a plan',
      'layer by layer, the original disappears',
      'memory of the Bosphorus at dusk',
      'what you leave out matters as much',
      'two colors in conversation',
      'rough and precise, at war',
      'a single session, start to finish',
      'movement as subject, not object',
      'patience as technique',
      'the grid keeps breaking',
      'shadow as structure',
      'thoughts fading at the margin',
      'one foot in, one foot out',
      'drawn in marker, meant for keeps',
      'a house, a tree, a whole world',
      'theatrical and committed',
      'warm light, soft shadows',
      'color as its own subject',
      'petals dissolve into paper',
      'wet on wet, form through feeling',
      'atmosphere over detail',
      'bigger than the wall it\'s on',
      'glasses, beard, and a story',
      'a face held in watercolor',
      'structure, line by line',
      'bone as architecture',
      'before the habits formed',
      'afternoon light, no plans',
      'the hand loosens by the second hour',
      'same problem, different angle',
      'fatigue as a filter',
      'last piece of the day',
      'past midnight, nothing to prove',
      'weight without a face',
      'the same question twice',
      'harder shadows in the morning',
      'evening light, same subject',
      'not a correction — a continuation',
      'the paint dries before you finish thinking',
      'autumn makes the studio feel earned',
      'stayed up until it was done',
      'returning after time away',
      'quiet at this hour',
      'the first one loosens the hand',
      'how many can one morning hold',
      'texture, not composition',
      'five pieces, one lesson',
      'transition, if you know where to look',
    ];

    const lb      = document.getElementById('art-lightbox');
    const lbImg   = document.getElementById('art-lb-img');
    const lbId    = document.getElementById('art-lb-id');
    const lbTitle = document.getElementById('art-lb-title');
    const lbMed   = document.getElementById('art-lb-medium');
    const lbYear  = document.getElementById('art-lb-year');
    const lbDesc  = document.getElementById('art-lb-desc');
    const lbCaption = document.getElementById('art-lb-caption');
    const lbClose = document.getElementById('art-lb-close');

    function openLightbox(artwork) {
      lbImg.src           = artwork.src;
      lbId.textContent    = `ARTWORK / ${String(artwork.id).padStart(2,'0')}`;
      lbTitle.textContent = artwork.title;
      lbMed.textContent   = artwork.medium;
      lbYear.textContent  = String(artwork.year);
      lbDesc.textContent  = artwork.desc;
      if (lbCaption) lbCaption.textContent = captions[artwork.id - 1] || '';
      lb.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lb.classList.remove('active');
      document.body.style.overflow = '';
      lbImg.src = '';
    }

    let dragThreshold = false;
    const viewport = document.getElementById('art-viewport');
    if (viewport) {
      viewport.addEventListener('mousedown', () => { dragThreshold = false; });
      viewport.addEventListener('mousemove', () => { dragThreshold = true; });
    }

    document.querySelectorAll('.art-item').forEach(item => {
      item.addEventListener('click', () => {
        if (dragThreshold) return;
        const id = parseInt(item.dataset.id);
        const artwork = artworksData.find(a => a.id === id);
        if (artwork) openLightbox(artwork);
      });
    });

    lbClose?.addEventListener('click', closeLightbox);
    lb?.addEventListener('click', (e) => { if (e.target === lb) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  })();

  // ── Travel Map ────────────────────────────────────────────────────────────
  (function() {
    const travelsData = [
      { id: 'amsterdam', city: 'AMSTERDAM', country: 'NETHERLANDS', date: 'MARCH 2026', status: 'VISITED', memory: 'The rain in Amsterdam makes the canals look like oil paintings.', x: 514, y: 164, photo: '' },
      { id: 'london',    city: 'LONDON',    country: 'UNITED KINGDOM', date: 'FEBRUARY 2026', status: 'VISITED', memory: 'Eight million stories compressed into one Underground carriage at rush hour.', x: 499, y: 166, photo: '' },
    ];

    const svg      = document.getElementById('travel-map');
    const coordsEl = document.getElementById('map-coords');

    if (svg && coordsEl) {
      svg.addEventListener('mousemove', (e) => {
        const rect  = svg.getBoundingClientRect();
        const svgX  = (e.clientX - rect.left)  * (1000 / rect.width);
        const svgY  = (e.clientY - rect.top)   * (500  / rect.height);
        const lon   = (svgX / 1000) * 360 - 180;
        const lat   = Math.atan(Math.sinh(Math.PI * (1 - 2 * svgY / 500))) * (180 / Math.PI);
        const latStr = `${Math.abs(lat).toFixed(2)}°${lat >= 0 ? 'N' : 'S'}`;
        const lonStr = `${Math.abs(lon).toFixed(2)}°${lon >= 0 ? 'E' : 'W'}`;
        coordsEl.textContent = `LAT: ${latStr}   LON: ${lonStr}`;
      });
      svg.addEventListener('mouseleave', () => {
        coordsEl.textContent = 'MOVE CURSOR OVER MAP — LAT: —   LON: —';
      });
    }

    const card    = document.getElementById('passport-card');
    const closeBtn = document.getElementById('passport-close');

    function openPassport(t) {
      document.getElementById('passport-status').textContent  = t.status;
      document.getElementById('passport-city').textContent    = t.city;
      document.getElementById('passport-country').textContent = t.country;
      document.getElementById('passport-date').textContent    = t.date;
      document.getElementById('passport-memory').textContent  = `"${t.memory}"`;
      const lon = (t.x / 1000) * 360 - 180;
      const lat = Math.atan(Math.sinh(Math.PI * (1 - 2 * t.y / 500))) * (180 / Math.PI);
      document.getElementById('passport-coords').textContent =
        `${Math.abs(lat).toFixed(4)}°${lat >= 0 ? 'N' : 'S'} / ${Math.abs(lon).toFixed(4)}°${lon >= 0 ? 'E' : 'W'}`;
      const img     = document.getElementById('passport-img');
      const noPhoto = document.getElementById('passport-no-photo');
      if (t.photo) { img.src = t.photo; img.style.display = 'block'; noPhoto.style.display = 'none'; }
      else         { img.style.display = 'none'; noPhoto.style.display = 'flex'; }
      card.classList.add('open');
      if (typeof gsap !== 'undefined') {
        gsap.fromTo(card, { x: '100%' }, { x: '0%', duration: 0.55, ease: 'power3.out' });
      }
    }

    function closePassport() {
      if (typeof gsap !== 'undefined') {
        gsap.to(card, { x: '100%', duration: 0.4, ease: 'power3.in', onComplete: () => card.classList.remove('open') });
      } else {
        card.classList.remove('open');
      }
    }

    document.querySelectorAll('.travel-node').forEach(node => {
      node.addEventListener('click', () => {
        const t = travelsData.find(d => d.id === node.dataset.id);
        if (t) openPassport(t);
      });
    });

    closeBtn?.addEventListener('click', closePassport);
    document.addEventListener('click', (e) => {
      if (card.classList.contains('open') && !card.contains(e.target) && !e.target.closest('.travel-node')) closePassport();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePassport(); });
  })();
</script>
