---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const paintings = [
  { title: 'PAINTING 01', src: '/images/painting-1.jpg' },
  { title: 'PAINTING 02', src: '/images/painting-2.jpg' },
  { title: 'PAINTING 03', src: '/images/painting-3.jpg' },
  { title: 'PAINTING 04', src: '/images/painting-4.jpg' },
];
---

<Layout title="HOBBIES — Emir Ceylan">
  <Header />
  
  <main class="flex-1">
    <!-- Activities Section -->
    <section class="pb-16 px-4" style="padding-top: 120px;">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end gap-4 mb-12">
          <h2 class="text-5xl md:text-7xl font-black kinetic-text">
            ACTIVITIES
          </h2>
          <div class="flex-1 h-4 bg-black"></div>
          <span class="text-3xl font-black">/02</span>
        </div>

        <div class="mb-20">
          <div class="bg-white border-4 border-black p-8 min-h-[200px]">
            <p class="text-base leading-relaxed text-black">
              <!-- Paragraph content will be added here -->
            </p>
          </div>
        </div>

        <!-- Paintings Section -->
        <div class="flex items-end gap-4 mb-12">
          <h2 class="text-5xl md:text-7xl font-black kinetic-text">
            PAINTINGS
          </h2>
          <div class="flex-1 h-4 bg-black"></div>
          <span class="text-3xl font-black">/04</span>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {paintings.map((painting, index) => (
            <div class="group relative overflow-hidden border-4 border-black aspect-square bg-black">
              <img 
                src={painting.src} 
                alt={painting.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 grayscale group-hover:grayscale-0"
              />
              <div class="absolute inset-0 bg-[#f40c3f] opacity-0 group-hover:opacity-80 transition-opacity duration-300 flex items-center justify-center">
                <p class="text-white font-black text-xl kinetic-text">{painting.title}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
