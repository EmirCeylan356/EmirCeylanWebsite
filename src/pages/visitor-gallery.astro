---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="VISITOR GALLERY — Emir Ceylan">
  <Header />
  
  <main>
    <section class="py-16 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end gap-4 mb-12">
          <h2 class="text-5xl md:text-7xl font-black kinetic-text">
            VISITOR GALLERY
          </h2>
          <div class="flex-1 h-4 bg-black"></div>
          <span class="text-3xl font-black">/NEW</span>
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
          <!-- Drawing Canvas Section -->
          <div>
            <h3 class="text-2xl font-black mb-4">DRAW YOUR ART</h3>
            
            <!-- Tool Bar -->
            <div class="flex flex-wrap gap-3 mb-4">
              <div class="flex gap-2">
                <button id="brush-btn" class="tool-btn active px-4 py-2 bg-black text-white font-bold border-2 border-black">Brush</button>
                <button id="eraser-btn" class="tool-btn px-4 py-2 bg-white text-black font-bold border-2 border-black hover:bg-black hover:text-white">Eraser</button>
              </div>
              
              <div class="flex gap-1">
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#000000" style="background:#000"></button>
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#f40c3f" style="background:#f40c3f"></button>
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#FF6B2C" style="background:#FF6B2C"></button>
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#FFD700" style="background:#FFD700"></button>
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#00C853" style="background:#00C853"></button>
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#2196F3" style="background:#2196F3"></button>
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#9C27B0" style="background:#9C27B0"></button>
                <button class="color-btn w-8 h-8 rounded-full border-2 border-black" data-color="#FFFFFF" data-default style="background:#FFF; border: 3px solid #000"></button>
              </div>

              <div class="flex gap-2">
                <button id="size-small" class="size-btn px-3 py-2 bg-white border-2 border-black font-bold text-sm">S</button>
                <button id="size-medium" class="size-btn active px-3 py-2 bg-black text-white border-2 border-black font-bold text-sm">M</button>
                <button id="size-large" class="size-btn px-3 py-2 bg-white border-2 border-black font-bold text-sm">L</button>
              </div>

              <button id="clear-btn" class="px-4 py-2 bg-[#f40c3f] text-white font-bold border-2 border-black hover:bg-red-700">Clear</button>
            </div>

            <!-- Canvas -->
            <canvas 
              id="drawing-canvas" 
              width="600" 
              height="400" 
              class="border-4 border-black bg-white cursor-crosshair w-full"
            ></canvas>
          </div>

          <!-- Submission Form -->
          <div>
            <h3 class="text-2xl font-black mb-4">SUBMIT YOUR ARTWORK</h3>
            
            <form id="submit-form" class="space-y-4">
              <div>
                <label class="block font-bold mb-2">Your Name *</label>
                <input 
                  type="text" 
                  id="artist-name" 
                  required
                  class="w-full p-3 border-4 border-black font-bold"
                  placeholder="Enter your name"
                />
              </div>

              <div>
                <label class="block font-bold mb-2">Email (optional)</label>
                <input 
                  type="email" 
                  id="artist-email" 
                  class="w-full p-3 border-4 border-black font-bold"
                  placeholder="your@email.com"
                />
              </div>

              <div>
                <label class="block font-bold mb-2">Title of your artwork</label>
                <input 
                  type="text" 
                  id="artwork-title" 
                  class="w-full p-3 border-4 border-black font-bold"
                  placeholder="Give your art a name"
                />
              </div>

              <button 
                type="submit" 
                class="w-full py-4 bg-black text-white font-bold text-xl border-4 border-black hover:bg-[#f40c3f] hover:border-[#f40c3f] transition-colors"
              >
                SUBMIT ARTWORK →
              </button>
            </form>

            <div id="success-message" class="hidden mt-4 p-4 bg-green-500 text-white font-bold text-center border-4 border-green-700">
              ✓ Thank you! Your artwork has been submitted for review.
            </div>
          </div>
        </div>

        <!-- Gallery Preview -->
        <div class="mt-16">
          <h3 class="text-3xl font-black mb-8">GALLERY PREVIEW</h3>
          <p class="text-lg opacity-70">Coming soon! Submissions will appear here after approval.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .tool-btn.active {
    background: black !important;
    color: white !important;
  }
  
  .color-btn.active {
    transform: scale(1.2);
    box-shadow: 0 0 0 3px black;
  }
  
  .size-btn.active {
    background: black !important;
    color: white !important;
  }

  canvas {
    touch-action: none;
  }
</style>

<script is:inline>
  const canvas = document.getElementById('drawing-canvas');
  const ctx = canvas.getContext('2d');
  
  let isDrawing = false;
  let currentTool = 'brush';
  let currentColor = '#000000';
  let currentSize = 8;
  
  // Set up canvas
  ctx.fillStyle = '#FFFFFF';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';

  // Tool buttons
  const brushBtn = document.getElementById('brush-btn');
  const eraserBtn = document.getElementById('eraser-btn');
  
  if (brushBtn) {
    brushBtn.addEventListener('click', function() {
      currentTool = 'brush';
      brushBtn.classList.add('active');
      eraserBtn.classList.remove('active');
    });
  }
  
  if (eraserBtn) {
    eraserBtn.addEventListener('click', function() {
      currentTool = 'eraser';
      eraserBtn.classList.add('active');
      brushBtn.classList.remove('active');
    });
  }

  // Color buttons
  const colorBtns = document.querySelectorAll('.color-btn');
  colorBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentColor = btn.getAttribute('data-color') || '#000000';
      colorBtns.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
    });
  });

  // Set default color
  const defaultColorBtn = document.querySelector('.color-btn[data-default]');
  if (defaultColorBtn) defaultColorBtn.classList.add('active');

  // Size buttons
  const sizeSmall = document.getElementById('size-small');
  const sizeMedium = document.getElementById('size-medium');
  const sizeLarge = document.getElementById('size-large');
  
  function updateSize() {
    if (sizeSmall) sizeSmall.classList.remove('active');
    if (sizeMedium) sizeMedium.classList.remove('active');
    if (sizeLarge) sizeLarge.classList.remove('active');
    if (currentSize === 3 && sizeSmall) sizeSmall.classList.add('active');
    else if (currentSize === 8 && sizeMedium) sizeMedium.classList.add('active');
    else if (currentSize === 15 && sizeLarge) sizeLarge.classList.add('active');
  }
  
  if (sizeSmall) {
    sizeSmall.addEventListener('click', function() {
      currentSize = 3;
      updateSize();
    });
  }
  
  if (sizeMedium) {
    sizeMedium.addEventListener('click', function() {
      currentSize = 8;
      updateSize();
    });
  }
  
  if (sizeLarge) {
    sizeLarge.addEventListener('click', function() {
      currentSize = 15;
      updateSize();
    });
  }
  
  // Set default
  if (sizeMedium) sizeMedium.classList.add('active');

  // Drawing functions
  function getPos(e) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    
    if (e.touches && e.touches.length > 0) {
      return {
        x: (e.touches[0].clientX - rect.left) * scaleX,
        y: (e.touches[0].clientY - rect.top) * scaleY
      };
    } else {
      return {
        x: (e.clientX - rect.left) * scaleX,
        y: (e.clientY - rect.top) * scaleY
      };
    }
  }

  function startDrawing(e) {
    isDrawing = true;
    const pos = getPos(e);
    ctx.beginPath();
    ctx.moveTo(pos.x, pos.y);
    e.preventDefault();
  }

  function stopDrawing() {
    isDrawing = false;
    ctx.beginPath();
  }

  function draw(e) {
    if (!isDrawing) return;
    
    const pos = getPos(e);
    ctx.lineWidth = currentSize;
    ctx.strokeStyle = currentTool === 'eraser' ? '#FFFFFF' : currentColor;
    
    ctx.lineTo(pos.x, pos.y);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(pos.x, pos.y);
    e.preventDefault();
  }

  // Event listeners
  canvas.addEventListener('mousedown', startDrawing);
  canvas.addEventListener('mouseup', stopDrawing);
  canvas.addEventListener('mousemove', draw);
  canvas.addEventListener('mouseout', stopDrawing);
  
  canvas.addEventListener('touchstart', startDrawing, { passive: false });
  canvas.addEventListener('touchend', stopDrawing);
  canvas.addEventListener('touchmove', draw, { passive: false });

  // Clear button
  const clearBtn = document.getElementById('clear-btn');
  if (clearBtn) {
    clearBtn.addEventListener('click', function() {
      ctx.fillStyle = '#FFFFFF';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    });
  }

  // Form submission
  const form = document.getElementById('submit-form');
  const successMessage = document.getElementById('success-message');
  
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const nameInput = document.getElementById('artist-name');
      const emailInput = document.getElementById('artist-email');
      const titleInput = document.getElementById('artwork-title');
      
      const name = nameInput ? nameInput.value : '';
      const email = emailInput ? emailInput.value : '';
      const title = titleInput ? titleInput.value : '';
      
      // Get canvas as image
      const canvasDataUrl = canvas.toDataURL('image/png');
      
      // Store in localStorage (for demo - will need Google Form in production)
      try {
        const submissions = JSON.parse(localStorage.getItem('artSubmissions') || '[]');
        submissions.push({
          name: name,
          email: email,
          title: title,
          image: canvasDataUrl,
          date: new Date().toISOString()
        });
        localStorage.setItem('artSubmissions', JSON.stringify(submissions));
      } catch(err) {
        console.log('Storage error (expected in some browsers):', err);
      }
      
      // Show success
      form.classList.add('hidden');
      if (successMessage) successMessage.classList.remove('hidden');
      
      console.log('Submission:', { name: name, email: email, title: title });
    });
  }
</script>
