---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import seedData from '../data/gallery-submissions.json';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
const seedJson = JSON.stringify(seedData || []);
---

<Layout title="VISITOR GALLERY — Emir Ceylan">
  <Header />

  <main style="padding-top: 80px;">

    <!-- ═══ PAGE HEADER ══════════════════════════════════════════════════════ -->
    <section style="padding:3rem 2rem 2rem; border-bottom:1px solid var(--border-color);">
      <div class="max-w-7xl mx-auto">
        <p class="font-mono text-xs mb-3" style="color:var(--text-secondary); letter-spacing:0.15em;">NEURAL_ARCHIVE /</p>
        <div class="flex items-end gap-4">
          <h1 class="font-black kinetic-text" style="font-family:'Syne'; font-size:clamp(3rem,9vw,7rem); color:var(--text-primary); line-height:0.9;">
            VISITOR<br/><span style="color:var(--accent);">GALLERY</span>
          </h1>
          <div class="flex-1 h-px" style="background:var(--border-color); margin-bottom:0.5rem;"></div>
          <span id="artwork-count" class="font-black font-mono text-xl" style="color:var(--text-secondary); margin-bottom:0.4rem;">/--</span>
        </div>
        <p class="font-mono text-xs mt-4" style="color:var(--text-secondary); opacity:0.6; letter-spacing:0.1em;">
          &gt; DRAW_TOOL_ACTIVE — SUBMIT YOUR CREATION TO THE NEURAL ARCHIVE
        </p>
      </div>
    </section>

    <!-- ═══ DRAW + SUBMIT ════════════════════════════════════════════════════ -->
    <section style="padding:3rem 2rem;">
      <div class="max-w-7xl mx-auto">
        <div class="vg-grid">

          <!-- LEFT: Canvas -->
          <div class="panel">
            <p class="font-mono text-xs mb-5" style="color:var(--text-secondary); letter-spacing:0.12em;">01 / DRAW_YOUR_ART.exe</p>

            <!-- Toolbar -->
            <div class="toolbar-row">
              <div class="toolbar-group">
                <button id="brush-btn" class="tool-active font-mono text-xs font-bold px-4 py-2 cut-corner-sm tool-btn"
                  style="letter-spacing:0.08em;">BRUSH</button>
                <button id="eraser-btn" class="font-mono text-xs font-bold px-4 py-2 cut-corner-sm tool-btn"
                  style="letter-spacing:0.08em;">ERASER</button>
                <button id="fill-btn" class="font-mono text-xs font-bold px-4 py-2 cut-corner-sm tool-btn"
                  style="letter-spacing:0.08em;" title="Bucket fill">FILL</button>
              </div>

              <div class="toolbar-group" style="flex-wrap:wrap;">
                <button class="color-btn active" data-color="#222222" style="background:#222;"></button>
                <button class="color-btn" data-color="#FFFFFF" style="background:#FFF; box-shadow:0 0 0 1px var(--border-color);"></button>
                <button class="color-btn" data-color="#D6FF00" style="background:#D6FF00;"></button>
                <button class="color-btn" data-color="#00E5FF" style="background:#00E5FF;"></button>
                <button class="color-btn" data-color="#FF0055" style="background:#FF0055;"></button>
                <button class="color-btn" data-color="#FF6B2C" style="background:#FF6B2C;"></button>
                <button class="color-btn" data-color="#FFD700" style="background:#FFD700;"></button>
                <button class="color-btn" data-color="#00C853" style="background:#00C853;"></button>
                <button class="color-btn" data-color="#2196F3" style="background:#2196F3;"></button>
                <button class="color-btn" data-color="#9C27B0" style="background:#9C27B0;"></button>
                <button class="color-btn" data-color="#8B4513" style="background:#8B4513;"></button>
                <button class="color-btn" data-color="#FFCD94" style="background:#FFCD94; box-shadow:0 0 0 1px var(--border-color);"></button>
                <button class="color-btn" data-color="#FF69B4" style="background:#FF69B4;"></button>
              </div>

              <div class="toolbar-group">
                <button id="size-s" class="size-btn font-mono text-xs font-bold px-3 py-2">S</button>
                <button id="size-m" class="size-btn size-active font-mono text-xs font-bold px-3 py-2">M</button>
                <button id="size-l" class="size-btn font-mono text-xs font-bold px-3 py-2">L</button>
              </div>

              <button id="clear-btn" class="clear-btn font-mono text-xs font-bold px-4 py-2 cut-corner-sm"
                style="letter-spacing:0.08em;">CLEAR</button>
              <button id="fullscreen-btn" class="fs-btn font-mono text-xs font-bold px-4 py-2 cut-corner-sm"
                style="letter-spacing:0.08em;" title="Fullscreen">⛶</button>
            </div>

            <div id="canvas-wrap" style="position:relative;">
              <canvas id="drawing-canvas" width="600" height="390"
                style="width:100%; display:block; cursor:crosshair; border:1px solid var(--border-color); box-shadow:inset 0 0 30px rgba(0,0,0,0.5);"></canvas>
            </div>

            <p class="font-mono text-xs mt-3" style="color:var(--text-secondary); opacity:0.35; letter-spacing:0.08em;">
              600 x 390 — touch supported
            </p>
          </div>

          <!-- RIGHT: Submit Form -->
          <div class="panel">
            <p class="font-mono text-xs mb-5" style="color:var(--text-secondary); letter-spacing:0.12em;">02 / TRANSMIT_TO_ARCHIVE.exe</p>

            <!-- Success state -->
            <div id="success-box" class="success-hidden" style="text-align:center; padding:4rem 0;">
              <div class="transmitted-anim font-black font-mono" style="font-size:2rem; color:var(--accent); letter-spacing:0.08em;">TRANSMITTED</div>
              <p class="font-mono text-sm mt-3" style="color:var(--text-secondary);">Your artwork is now in the archive.</p>
              <button id="draw-another-btn" class="mt-8 font-mono text-xs font-bold px-6 py-3 cut-corner another-btn"
                style="letter-spacing:0.1em;">DRAW ANOTHER</button>
            </div>

            <!-- Form -->
            <form id="submit-form">
              <div id="setup-warning" style="display:none; padding:0.75rem 1rem; margin-bottom:1.5rem; background:var(--bg-elevated); border:1px solid var(--border-color); font-family:'JetBrains Mono',monospace; font-size:0.7rem; color:var(--text-secondary); line-height:1.8;">
                <span style="color:var(--accent);">SUPABASE NOT CONFIGURED</span><br/>
                Add your credentials to <code style="color:var(--text-primary);">.env</code> to enable submissions.
              </div>

              <div style="margin-bottom:1.5rem;">
                <label class="font-mono text-xs" style="display:block; margin-bottom:0.5rem; color:var(--text-secondary); letter-spacing:0.12em;">YOUR NAME</label>
                <input id="inp-name" type="text" maxlength="60" required placeholder="e.g. Anonymous"
                  class="gallery-input" />
              </div>

              <div style="margin-bottom:1.5rem;">
                <label class="font-mono text-xs" style="display:block; margin-bottom:0.5rem; color:var(--text-secondary); letter-spacing:0.12em;">ARTWORK TITLE</label>
                <input id="inp-title" type="text" maxlength="80" required placeholder="e.g. Untitled #01"
                  class="gallery-input" />
              </div>

              <!-- Preview -->
              <div style="margin-bottom:1.5rem;">
                <label class="font-mono text-xs" style="display:block; margin-bottom:0.5rem; color:var(--text-secondary); letter-spacing:0.12em;">PREVIEW</label>
                <div class="preview-box">
                  <img id="preview-img" alt="Canvas preview" style="width:100%; height:120px; object-fit:cover; opacity:0.85; display:none;" />
                  <span id="preview-empty" class="font-mono text-xs" style="color:var(--text-secondary); opacity:0.4;">DRAW SOMETHING FIRST</span>
                </div>
              </div>

              <!-- Error -->
              <div id="err-msg" class="err-box" style="display:none;"></div>

              <button id="submit-btn" type="submit" class="submit-btn font-mono text-sm font-bold py-4 cut-corner" style="width:100%; letter-spacing:0.1em;">
                <span id="submit-text">SUBMIT TO GALLERY</span>
                <span id="submit-spin" style="display:none;">TRANSMITTING...</span>
              </button>

              <p class="font-mono text-xs mt-4" style="color:var(--text-secondary); opacity:0.4; letter-spacing:0.06em;">
                All submissions are public and visible to everyone.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ GALLERY ══════════════════════════════════════════════════════════ -->
    <section id="gallery-section" style="padding:3rem 2rem; border-top:1px solid var(--border-color);">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-end gap-4 mb-10">
          <p class="font-mono text-xs" style="color:var(--text-secondary); letter-spacing:0.15em; align-self:center;">ARCHIVE /</p>
          <h2 class="font-black kinetic-text" style="font-family:'Syne'; font-size:clamp(2rem,6vw,4.5rem); color:var(--text-primary);">ALL WORKS</h2>
          <div class="flex-1 h-px" style="background:var(--border-color);"></div>
        </div>

        <!-- Loading -->
        <div id="gallery-loading" class="gallery-grid">
          <div class="skeleton-card"></div>
          <div class="skeleton-card"></div>
          <div class="skeleton-card"></div>
        </div>

        <!-- Gallery -->
        <div id="gallery-grid" class="gallery-grid" style="display:none;"></div>

        <!-- Empty -->
        <div id="gallery-empty" style="display:none; text-align:center; padding:5rem 0;">
          <p class="font-mono font-bold" style="font-size:1.5rem; color:var(--text-secondary);">
            BE THE FIRST TO SUBMIT<span class="blink-cursor">_</span>
          </p>
          <p class="font-mono text-xs mt-2" style="color:var(--text-secondary); opacity:0.4; letter-spacing:0.1em;">THE ARCHIVE AWAITS ITS FIRST ENTRY</p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<!-- Inject env values for the client script -->
<script is:inline define:vars={{ supabaseUrl, supabaseKey, seedJson }}>
window.__SB_URL__  = supabaseUrl;
window.__SB_KEY__  = supabaseKey;
window.__SEEDS__   = seedJson;
</script>

<style>
  /* ── Layout ──────────────────────────────────────────────────────────────── */
  .vg-grid { display: grid; gap: 2rem; }
  @media (min-width: 1024px) { .vg-grid { grid-template-columns: 1fr 1fr; align-items: start; } }

  /* ── Toolbar ─────────────────────────────────────────────────────────────── */
  .toolbar-row { display:flex; flex-wrap:wrap; gap:0.75rem; margin-bottom:1.25rem; align-items:center; }
  .toolbar-group { display:flex; gap:0.5rem; align-items:center; }

  .tool-btn {
    background: transparent; color: var(--text-primary); border: 1px solid var(--border-color);
    cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .tool-btn:hover { border-color: var(--text-secondary); }
  .tool-active, .tool-btn.tool-active {
    background: var(--accent) !important; color: #000 !important; border-color: var(--accent) !important;
  }

  .color-btn {
    width: 22px; height: 22px; border-radius: 50%; border: 2px solid transparent;
    cursor: pointer; transition: transform 0.15s, box-shadow 0.15s;
  }
  .color-btn:hover { transform: scale(1.2); }
  .color-btn.active { transform: scale(1.3); box-shadow: 0 0 0 2px var(--accent), 0 0 8px rgba(214,255,0,0.4); }

  .size-btn {
    background: transparent; color: var(--text-primary); border: 1px solid var(--border-color);
    cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .size-btn:hover { border-color: var(--text-secondary); }
  .size-active, .size-btn.size-active {
    background: var(--accent) !important; color: #000 !important; border-color: var(--accent) !important;
  }

  .clear-btn {
    background: transparent; color: #FF0055; border: 1px solid #FF0055;
    cursor: pointer; transition: background 0.15s, color 0.15s;
  }
  .clear-btn:hover { background: #FF0055; color: #fff; }

  .fs-btn {
    background: transparent; color: var(--text-secondary); border: 1px solid var(--border-color);
    cursor: pointer; transition: border-color 0.15s, color 0.15s; font-size: 1rem;
  }
  .fs-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* Fullscreen canvas overlay */
  .canvas-fullscreen-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: var(--bg-base);
    display: flex; flex-direction: column;
    padding: 1rem;
  }
  .canvas-fullscreen-overlay .fs-canvas-wrap {
    flex: 1; display: flex; align-items: center; justify-content: center;
    min-height: 0;
  }
  .canvas-fullscreen-overlay canvas {
    max-width: 100%; max-height: 100%;
    border: 1px solid var(--border-color);
    box-shadow: inset 0 0 30px rgba(0,0,0,0.5);
    cursor: crosshair; touch-action: none;
  }
  .canvas-fullscreen-bar {
    display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; flex-wrap: wrap;
    flex-shrink: 0;
  }
  .fs-close-btn {
    margin-left: auto; background: transparent; color: #FF0055; border: 1px solid #FF0055;
    font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 700;
    padding: 0.4rem 0.75rem; cursor: pointer; letter-spacing: 0.08em;
  }
  .fs-close-btn:hover { background: #FF0055; color: #fff; }

  canvas { touch-action: none; }

  /* ── Form ─────────────────────────────────────────────────────────────────── */
  .gallery-input {
    width: 100%; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;
    background: var(--bg-elevated); border: 1px solid var(--border-color); color: var(--text-primary);
    padding: 0.75rem 1rem; outline: none; letter-spacing: 0.04em;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .gallery-input:focus { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent); }
  .gallery-input::placeholder { color: var(--text-secondary); opacity: 0.35; }

  .preview-box {
    border: 1px solid var(--border-color); background: var(--bg-elevated);
    height: 120px; overflow: hidden; display: flex; align-items: center; justify-content: center;
  }

  .err-box {
    font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
    padding: 0.6rem 0.8rem; margin-bottom: 1rem;
    background: rgba(255,0,85,0.08); border: 1px solid #FF0055; color: #FF0055;
  }

  .submit-btn {
    background: var(--accent); color: #000; border: 1px solid var(--accent);
    cursor: pointer; transition: background 0.2s, color 0.2s, box-shadow 0.2s;
  }
  .submit-btn:hover:not(:disabled) {
    background: transparent; color: var(--accent); box-shadow: 0 0 16px var(--accent-glow);
  }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .another-btn {
    background: transparent; color: var(--accent); border: 1px solid var(--accent);
    cursor: pointer; transition: background 0.2s, color 0.2s;
  }
  .another-btn:hover { background: var(--accent); color: #000; }

  .success-hidden { display: none; }

  @keyframes transmitted-in {
    0%   { opacity:0; transform:skewX(-5deg) scale(0.9); text-shadow: -3px 0 #00E5FF, 3px 0 #FF0055; }
    50%  { opacity:1; transform:skewX(2deg) scale(1.03); text-shadow: 2px 0 #00E5FF, -2px 0 #FF0055; }
    100% { opacity:1; transform:none; text-shadow: 0 0 20px rgba(214,255,0,0.3); }
  }
  .transmitted-anim { animation: transmitted-in 0.6s cubic-bezier(0.16,1,0.3,1) forwards; }

  /* ── Gallery ─────────────────────────────────────────────────────────────── */
  .gallery-grid {
    display: grid; gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .gallery-card {
    background: var(--bg-surface); border: 1px solid var(--border-color); padding: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    opacity: 0; transform: translateY(20px);
  }
  .gallery-card.vis {
    opacity: 1; transform: translateY(0);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.2s, box-shadow 0.2s;
  }
  .gallery-card:hover {
    border-color: var(--accent); box-shadow: 0 0 16px var(--accent-glow); transform: translateY(-2px);
  }
  .gallery-card img { width: 100%; aspect-ratio: 600/390; object-fit: cover; display: block; border: 1px solid var(--border-color); }

  @keyframes skpulse { 0%,100%{opacity:0.3;} 50%{opacity:0.6;} }
  .skeleton-card { height: 260px; background: var(--bg-surface); border: 1px solid var(--border-color); animation: skpulse 1.5s ease-in-out infinite; }

  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }
  .blink-cursor { animation: blink 1s step-end infinite; }
</style>

<script is:inline>
(function(){
  /* ── Supabase CDN import ──────────────────────────────────────────────── */
  var sbClient = null;
  var SB_URL = window.__SB_URL__ || '';
  var SB_KEY = window.__SB_KEY__ || '';
  var SEEDS  = [];
  try { SEEDS = JSON.parse(window.__SEEDS__ || '[]'); } catch(e){}

  async function getSB() {
    if (sbClient) return sbClient;
    if (!SB_URL || !SB_KEY || SB_URL.includes('your-project')) {
      document.getElementById('setup-warning').style.display = 'block';
      return null;
    }
    try {
      var mod = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm');
      sbClient = mod.createClient(SB_URL, SB_KEY);
      return sbClient;
    } catch(e) { console.warn('Supabase load failed', e); return null; }
  }

  /* ── DOM ──────────────────────────────────────────────────────────────── */
  var cv  = document.getElementById('drawing-canvas');
  var ctx = cv.getContext('2d');

  var brushBtn  = document.getElementById('brush-btn');
  var eraserBtn = document.getElementById('eraser-btn');
  var fillBtn   = document.getElementById('fill-btn');
  var clearBtn  = document.getElementById('clear-btn');
  var fsBtn     = document.getElementById('fullscreen-btn');
  var sizeS = document.getElementById('size-s');
  var sizeM = document.getElementById('size-m');
  var sizeL = document.getElementById('size-l');

  var form       = document.getElementById('submit-form');
  var successBox = document.getElementById('success-box');
  var submitBtn  = document.getElementById('submit-btn');
  var submitText = document.getElementById('submit-text');
  var submitSpin = document.getElementById('submit-spin');
  var errMsg     = document.getElementById('err-msg');
  var prevImg    = document.getElementById('preview-img');
  var prevEmpty  = document.getElementById('preview-empty');

  var galleryGrid    = document.getElementById('gallery-grid');
  var galleryLoading = document.getElementById('gallery-loading');
  var galleryEmpty   = document.getElementById('gallery-empty');
  var artworkCount   = document.getElementById('artwork-count');

  /* ── Canvas state ────────────────────────────────────────────────────── */
  var drawing = false, tool = 'brush', color = '#222222', size = 8, drawn = false;

  ctx.fillStyle = '#FFFFFF';
  ctx.fillRect(0, 0, cv.width, cv.height);
  ctx.lineCap = 'round'; ctx.lineJoin = 'round';

  /* ── Tool buttons ────────────────────────────────────────────────────── */
  function setTool(t) {
    tool = t;
    brushBtn.classList.toggle('tool-active', t === 'brush');
    eraserBtn.classList.toggle('tool-active', t === 'eraser');
    fillBtn.classList.toggle('tool-active', t === 'fill');
    cv.style.cursor = t === 'fill' ? 'cell' : 'crosshair';
  }
  brushBtn.onclick  = function(){ setTool('brush'); };
  eraserBtn.onclick = function(){ setTool('eraser'); };
  fillBtn.onclick   = function(){ setTool('fill'); };

  /* ── Flood fill ──────────────────────────────────────────────────────── */
  function hexToRgb(hex) {
    var r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
    return [r, g, b];
  }
  function floodFill(cx, cy) {
    var imgData = ctx.getImageData(0, 0, cv.width, cv.height);
    var data = imgData.data;
    var W = cv.width;
    var idx = (cy * W + cx) * 4;
    var tr = data[idx], tg = data[idx+1], tb = data[idx+2], ta = data[idx+3];
    var fc = hexToRgb(color);
    if (tr === fc[0] && tg === fc[1] && tb === fc[2] && ta === 255) return;
    var stack = [cx + cy * W];
    var visited = new Uint8Array(W * cv.height);
    while (stack.length) {
      var pos = stack.pop();
      var x = pos % W, y = (pos / W) | 0;
      if (x < 0 || x >= W || y < 0 || y >= cv.height) continue;
      if (visited[pos]) continue;
      var i = pos * 4;
      if (data[i] !== tr || data[i+1] !== tg || data[i+2] !== tb || data[i+3] !== ta) continue;
      visited[pos] = 1;
      data[i] = fc[0]; data[i+1] = fc[1]; data[i+2] = fc[2]; data[i+3] = 255;
      stack.push(pos+1, pos-1, pos+W, pos-W);
    }
    ctx.putImageData(imgData, 0, 0);
  }

  /* ── Colors ──────────────────────────────────────────────────────────── */
  document.querySelectorAll('.color-btn').forEach(function(b){
    b.onclick = function(){
      color = b.dataset.color;
      setTool('brush');
      document.querySelectorAll('.color-btn').forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
    };
  });

  /* ── Sizes ───────────────────────────────────────────────────────────── */
  function setSize(btn, s) {
    [sizeS, sizeM, sizeL].forEach(function(b){ b.classList.remove('size-active'); });
    btn.classList.add('size-active');
    size = s;
  }
  sizeS.onclick = function(){ setSize(sizeS, 3); };
  sizeM.onclick = function(){ setSize(sizeM, 8); };
  sizeL.onclick = function(){ setSize(sizeL, 16); };

  /* ── Clear ───────────────────────────────────────────────────────────── */
  clearBtn.onclick = function(){
    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, 0, cv.width, cv.height);
    drawn = false;
    prevImg.style.display = 'none';
    prevEmpty.style.display = '';
  };

  /* ── Drawing ─────────────────────────────────────────────────────────── */
  function pos(e, canvasEl) {
    var target = canvasEl || cv;
    var r = target.getBoundingClientRect();
    var sx = target.width / r.width, sy = target.height / r.height;
    var src = e.touches ? e.touches[0] : e;
    return { x: (src.clientX - r.left) * sx, y: (src.clientY - r.top) * sy };
  }
  function startD(e) {
    if (tool === 'fill') {
      var p = pos(e, cv);
      floodFill(Math.round(p.x), Math.round(p.y));
      drawn = true;
      prevImg.src = cv.toDataURL('image/jpeg', 0.5);
      prevImg.style.display = 'block';
      prevEmpty.style.display = 'none';
      e.preventDefault(); return;
    }
    drawing = true; var p2 = pos(e, cv); ctx.beginPath(); ctx.moveTo(p2.x, p2.y); e.preventDefault();
  }
  function doD(e) {
    if (!drawing || tool === 'fill') return;
    var p = pos(e, cv);
    ctx.lineWidth = size;
    ctx.strokeStyle = tool === 'eraser' ? '#FFFFFF' : color;
    ctx.lineTo(p.x, p.y); ctx.stroke(); ctx.beginPath(); ctx.moveTo(p.x, p.y);
    drawn = true; e.preventDefault();
  }
  function stopD() {
    if (!drawing) return;
    drawing = false; ctx.beginPath();
    if (drawn) {
      prevImg.src = cv.toDataURL('image/jpeg', 0.5);
      prevImg.style.display = 'block';
      prevEmpty.style.display = 'none';
    }
  }

  function attachDrawEvents(target, canvasEl) {
    target.addEventListener('mousedown', startD);
    target.addEventListener('mousemove', doD);
    target.addEventListener('mouseup', stopD);
    target.addEventListener('mouseleave', stopD);
    target.addEventListener('touchstart', startD, { passive: false });
    target.addEventListener('touchmove', doD, { passive: false });
    target.addEventListener('touchend', stopD);
  }
  attachDrawEvents(cv, cv);

  /* ── Fullscreen ──────────────────────────────────────────────────────── */
  fsBtn.onclick = function() {
    // All styles inline because Astro scopes <style> and won't apply to dynamic elements
    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:var(--bg-base);display:flex;flex-direction:column;padding:1rem;';

    var bar = document.createElement('div');
    bar.style.cssText = 'display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;flex-shrink:0;';
    var label = document.createElement('span');
    label.textContent = 'FULLSCREEN MODE';
    label.style.cssText = "color:var(--accent);letter-spacing:0.1em;font-family:'JetBrains Mono',monospace;font-size:0.75rem;font-weight:700;";
    bar.appendChild(label);

    var closeBtn = document.createElement('button');
    closeBtn.textContent = 'EXIT';
    closeBtn.style.cssText = "margin-left:auto;background:transparent;color:#FF0055;border:1px solid #FF0055;font-family:'JetBrains Mono',monospace;font-size:0.75rem;font-weight:700;padding:0.4rem 0.75rem;cursor:pointer;letter-spacing:0.08em;";
    bar.appendChild(closeBtn);

    var wrap = document.createElement('div');
    wrap.style.cssText = 'flex:1;display:flex;align-items:center;justify-content:center;min-height:0;';

    var fsCanvas = document.createElement('canvas');
    fsCanvas.width = cv.width; fsCanvas.height = cv.height;
    fsCanvas.style.cssText = 'max-width:100%;max-height:100%;border:1px solid var(--border-color);box-shadow:inset 0 0 30px rgba(0,0,0,0.5);cursor:crosshair;touch-action:none;';
    var fsCtx = fsCanvas.getContext('2d');
    fsCtx.drawImage(cv, 0, 0);
    fsCtx.lineCap = 'round'; fsCtx.lineJoin = 'round';

    wrap.appendChild(fsCanvas);
    overlay.appendChild(bar);
    overlay.appendChild(wrap);
    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';

    // Swap drawing target to fullscreen canvas
    var mainCv = cv, mainCtx = ctx;
    cv = fsCanvas; ctx = fsCtx;
    attachDrawEvents(fsCanvas, fsCanvas);

    function closeFs() {
      cv = mainCv; ctx = mainCtx;
      ctx.drawImage(fsCanvas, 0, 0);
      if (drawn) {
        prevImg.src = cv.toDataURL('image/jpeg', 0.5);
        prevImg.style.display = 'block'; prevEmpty.style.display = 'none';
      }
      document.removeEventListener('keydown', escHandler);
      document.body.removeChild(overlay);
      document.body.style.overflow = '';
    }

    function escHandler(e) { if (e.key === 'Escape') closeFs(); }
    document.addEventListener('keydown', escHandler);
    closeBtn.onclick = closeFs;
  };

  /* ── Gallery load ────────────────────────────────────────────────────── */
  function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function renderGallery(items) {
    galleryLoading.style.display = 'none';
    artworkCount.textContent = '/' + String(items.length).padStart(2, '0');
    if (items.length === 0) { galleryEmpty.style.display = ''; return; }
    galleryEmpty.style.display = 'none';
    galleryGrid.innerHTML = '';
    items.forEach(function(it, i){
      var d = document.createElement('div');
      d.className = 'gallery-card';
      d.innerHTML =
        '<img src="' + esc(it.image_data || it.image || '') + '" alt="' + esc(it.title) + '" loading="lazy" />' +
        '<div style="padding-top:0.75rem;">' +
          '<p class="font-black text-sm" style="color:var(--text-primary);font-family:Syne;">' + esc(it.title) + '</p>' +
          '<p class="font-mono text-xs" style="color:var(--text-secondary);margin-top:0.25rem;">by ' + esc(it.name) + '</p>' +
          (it.created_at || it.date ? '<p class="font-mono text-xs" style="color:var(--text-secondary);opacity:0.4;margin-top:0.25rem;">' + new Date(it.created_at || it.date).toLocaleDateString() + '</p>' : '') +
        '</div>';
      galleryGrid.appendChild(d);
      setTimeout(function(){ d.classList.add('vis'); }, 50 * i);
    });
    galleryGrid.style.display = '';
  }

  async function loadGallery(prepend) {
    var sb = await getSB();
    var items = [];
    if (sb) {
      var res = await sb.from('gallery_submissions').select('id, name, title, image_data, created_at').order('created_at', { ascending: false });
      if (!res.error && res.data) items = res.data;
    }
    // Append seed data
    SEEDS.forEach(function(s){
      items.push({ id: 'seed', name: s.name, title: s.title, image_data: s.image, created_at: s.date });
    });
    if (prepend) items.unshift(prepend);
    renderGallery(items);
  }

  /* ── Submit ──────────────────────────────────────────────────────────── */
  form.addEventListener('submit', async function(e){
    e.preventDefault();
    errMsg.style.display = 'none';

    var name  = document.getElementById('inp-name').value.trim();
    var title = document.getElementById('inp-title').value.trim();
    if (!name || !title) { showErr('Fill in your name and artwork title.'); return; }
    if (!drawn) { showErr('Draw something on the canvas first.'); return; }

    var imageData = cv.toDataURL('image/jpeg', 0.35);
    var sb = await getSB();
    if (!sb) { showErr('Supabase not configured. Add credentials to .env'); return; }

    submitBtn.disabled = true;
    submitText.style.display = 'none';
    submitSpin.style.display = '';

    var res = await sb.from('gallery_submissions').insert([{ name: name, title: title, image_data: imageData }]).select().single();

    submitBtn.disabled = false;
    submitText.style.display = '';
    submitSpin.style.display = 'none';

    if (res.error) { showErr('Submission failed: ' + res.error.message); return; }

    form.style.display = 'none';
    successBox.style.display = '';

    loadGallery({ id: res.data?.id, name: name, title: title, image_data: imageData, created_at: new Date().toISOString() });
    document.getElementById('gallery-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('draw-another-btn').onclick = function(){
    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, 0, cv.width, cv.height);
    drawn = false;
    prevImg.style.display = 'none';
    prevEmpty.style.display = '';
    document.getElementById('inp-name').value = '';
    document.getElementById('inp-title').value = '';
    successBox.style.display = 'none';
    form.style.display = '';
    errMsg.style.display = 'none';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  function showErr(msg) { errMsg.textContent = msg; errMsg.style.display = ''; }

  /* ── Init ─────────────────────────────────────────────────────────────── */
  loadGallery(null);
})();
</script>
