---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#f40c3f] text-black min-h-screen">
    <div class="fixed inset-0 grid-bg pointer-events-none z-0"></div>
    <canvas id="fisheye-canvas" class="fixed pointer-events-none z-[2]" style="display:none;"></canvas>
    
    <!-- Contrast Toggle -->
    <button 
      id="contrast-toggle" 
      class="fixed top-20 right-4 z-50 px-4 py-2 bg-black text-white font-bold text-sm border-2 border-black hover:bg-white hover:text-black transition-colors"
    >
      CONTRAST
    </button>
    
    <div id="main-content" class="relative z-10 min-h-screen flex flex-col">
      <slot />
    </div>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script is:inline>
      // Initialize GSAP
      if (typeof gsap !== 'undefined' && gsap.registerPlugin) {
        gsap.registerPlugin(ScrollTrigger);
      }
      
      // Contrast toggle
      let contrastMode = false;
      const toggle = document.getElementById('contrast-toggle');
      const body = document.body;
      const header = document.querySelector('header');
      
      if (toggle) {
        toggle.addEventListener('click', () => {
          contrastMode = !contrastMode;
          if (contrastMode) {
            body.classList.add('contrast-mode');
            body.style.backgroundColor = '#000';
            body.style.color = '#00ff00';
            if (header) header.style.backgroundColor = '#000';
          } else {
            body.classList.remove('contrast-mode');
            body.style.backgroundColor = '#f40c3f';
            body.style.color = '#000';
            if (header) header.style.backgroundColor = '#f40c3f';
          }
        });
      }
      
      // Fisheye grid distortion canvas
      const fisheyeCanvas = document.getElementById('fisheye-canvas');
      if (fisheyeCanvas) {
        const ctx = fisheyeCanvas.getContext('2d');
        const R = 180;       // lens radius px
        const SIZE = R * 2 + 4;
        const GRID = 50;     // must match .grid-bg background-size
        fisheyeCanvas.width = SIZE;
        fisheyeCanvas.height = SIZE;
        let mx = -1000, my = -1000, raf = null;

        function drawFisheye() {
          const cx = SIZE / 2, cy = SIZE / 2;
          const isContrast = document.body.classList.contains('contrast-mode');
          const bgFill  = isContrast ? '#000000' : '#f40c3f';
          const lineCol = isContrast ? 'rgba(0,255,0,0.2)' : 'rgba(0,0,0,0.15)';

          ctx.clearRect(0, 0, SIZE, SIZE);

          // Clip to circle
          ctx.save();
          ctx.beginPath();
          ctx.arc(cx, cy, R, 0, Math.PI * 2);
          ctx.clip();

          // Cover static grid underneath
          ctx.fillStyle = bgFill;
          ctx.fillRect(0, 0, SIZE, SIZE);

          ctx.strokeStyle = lineCol;
          ctx.lineWidth = 1;

          // Align grid to cursor position so lines match the static background
          const ox = ((mx % GRID) + GRID) % GRID;
          const oy = ((my % GRID) + GRID) % GRID;

          // Barrel warp: points pushed outward from center, strongest at centre
          function warp(px, py) {
            const dx = px - cx, dy = py - cy;
            const r = Math.sqrt(dx * dx + dy * dy);
            if (r >= R || r < 0.01) return [px, py];
            const n = r / R;
            const rOut = r * (1 + Math.pow(1 - n, 2.2) * 0.9);
            return [cx + (dx / r) * rOut, cy + (dy / r) * rOut];
          }

          // Cover enough lines across the full lens diameter (R can span ~4 grid cells)
          const spread = (Math.ceil(R / GRID) + 1) * GRID;

          // Trace vertical grid lines through the lens
          for (let gx = -ox - spread; gx <= R + GRID; gx += GRID) {
            ctx.beginPath();
            let first = true;
            for (let gy = -R; gy <= R; gy += 3) {
              const [px, py] = warp(cx + gx, cy + gy);
              first ? (ctx.moveTo(px, py), first = false) : ctx.lineTo(px, py);
            }
            ctx.stroke();
          }

          // Trace horizontal grid lines through the lens
          for (let gy = -oy - spread; gy <= R + GRID; gy += GRID) {
            ctx.beginPath();
            let first = true;
            for (let gx = -R; gx <= R; gx += 3) {
              const [px, py] = warp(cx + gx, cy + gy);
              first ? (ctx.moveTo(px, py), first = false) : ctx.lineTo(px, py);
            }
            ctx.stroke();
          }

          ctx.restore();
          // No rim border

          raf = null;
        }

        document.addEventListener('mousemove', (e) => {
          mx = e.clientX; my = e.clientY;
          fisheyeCanvas.style.left = (mx - SIZE / 2) + 'px';
          fisheyeCanvas.style.top  = (my - SIZE / 2) + 'px';
          fisheyeCanvas.style.display = 'block';
          if (!raf) raf = requestAnimationFrame(drawFisheye);
        });
        document.addEventListener('mouseleave', () => { fisheyeCanvas.style.display = 'none'; });
      }

      // Reveal animations
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap !== 'undefined') {
          gsap.utils.toArray('.reveal').forEach((el) => {
            gsap.fromTo(el, 
              { opacity: 0, y: 50 },
              {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: 'power3.out',
                scrollTrigger: {
                  trigger: el,
                  start: 'top 80%',
                }
              }
            );
          });
        }
      });
    </script>
  </body>
</html>
