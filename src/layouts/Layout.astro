---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;900&family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#f40c3f] text-black min-h-screen">
    <div class="fixed inset-0 grid-bg pointer-events-none z-0"></div>

    <!-- DNA Helix canvas background -->
    <canvas id="dna-canvas" class="fixed inset-0 pointer-events-none z-[1]" style="mix-blend-mode: multiply; opacity: 0.55;"></canvas>
    
    <!-- Contrast Toggle -->
    <button 
      id="contrast-toggle" 
      class="fixed top-20 right-4 z-50 px-4 py-2 bg-black text-white font-bold text-sm border-2 border-black hover:bg-white hover:text-black transition-colors"
    >
      CONTRAST
    </button>
    
    <div id="main-content" class="relative z-10 min-h-screen flex flex-col">
      <slot />
    </div>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script is:inline>
      // Initialize GSAP
      if (typeof gsap !== 'undefined' && gsap.registerPlugin) {
        gsap.registerPlugin(ScrollTrigger);
      }
      
      // Contrast toggle
      let contrastMode = false;
      const toggle = document.getElementById('contrast-toggle');
      const body = document.body;
      const header = document.querySelector('header');
      
      if (toggle) {
        toggle.addEventListener('click', () => {
          contrastMode = !contrastMode;
          if (contrastMode) {
            body.classList.add('contrast-mode');
            body.style.backgroundColor = '#000';
            body.style.color = '#00ff00';
            if (header) header.style.backgroundColor = '#000';
          } else {
            body.classList.remove('contrast-mode');
            body.style.backgroundColor = '#f40c3f';
            body.style.color = '#000';
            if (header) header.style.backgroundColor = '#f40c3f';
          }
        });
      }
      
      // ── DNA Helix → Code Rain canvas background ──────────────────────────
      (function() {
        const cv = document.getElementById('dna-canvas');
        if (!cv) return;
        const ctx = cv.getContext('2d');

        let W, H;
        function resize() {
          W = cv.width  = window.innerWidth;
          H = cv.height = window.innerHeight;
          initRain();
        }
        window.addEventListener('resize', resize);

        // ── scroll progress (0→1) ─────────────────────────────────────────
        let scrollP = 0;
        window.addEventListener('scroll', () => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          scrollP = max > 0 ? Math.min(window.scrollY / max, 1) : 0;
        }, { passive: true });

        // ── Code rain columns ─────────────────────────────────────────────
        const CHARS = 'ATCGATCG01010101{}[]();=></>const let fn'.split('');
        let cols = [];
        function initRain() {
          cols = [];
          const spacing = 28;
          const n = Math.floor(W / spacing);
          for (let i = 0; i < n; i++) {
            cols.push({
              x: i * spacing + spacing / 2,
              y: Math.random() * H,
              speed: 0.8 + Math.random() * 1.4,
              trail: Math.floor(10 + Math.random() * 14),
              chars: Array.from({ length: 24 }, () => CHARS[Math.floor(Math.random() * CHARS.length)]),
              tick: 0,
            });
          }
        }

        function drawRain(alpha) {
          if (alpha <= 0) return;
          cols.forEach(col => {
            col.y += col.speed;
            if (col.y > H + col.trail * 22) col.y = -col.trail * 22;
            col.tick++;
            if (col.tick % 6 === 0) {
              const idx = Math.floor(Math.random() * col.chars.length);
              col.chars[idx] = CHARS[Math.floor(Math.random() * CHARS.length)];
            }
            col.chars.forEach((ch, i) => {
              const y = col.y - i * 22;
              if (y < 0 || y > H) return;
              const fade = 1 - i / col.trail;
              const bright = i === 0 ? 1 : fade * 0.85;
              ctx.globalAlpha = alpha * bright;
              ctx.fillStyle = '#000';
              ctx.font = `bold ${i === 0 ? 17 : 14}px monospace`;
              ctx.fillText(ch, col.x, y);
            });
          });
        }

        // ── DNA Helix ─────────────────────────────────────────────────────
        let time = 0;

        function drawHelix(alpha) {
          if (alpha <= 0) return;
          const cx   = W / 2;
          const amp  = Math.min(W * 0.14, 145);
          const freq = 2.8;
          const segs = 200;
          const rot  = time * 0.55;

          const s1 = [], s2 = [];
          for (let i = 0; i <= segs; i++) {
            const t     = i / segs;
            const y     = -10 + t * (H + 20);
            const angle = t * Math.PI * 2 * freq + rot;
            const cosA  = Math.cos(angle);
            const depth = (cosA + 1) / 2; // 0 = back, 1 = front
            s1.push({ x: cx + amp * cosA, y, depth });
            s2.push({ x: cx - amp * cosA, y, depth: 1 - depth });
          }

          ctx.lineCap  = 'round';
          ctx.shadowBlur = 0;

          // Collect all micro-segments from both strands, sort back→front
          const allSegs = [];
          for (let i = 0; i < segs; i++) {
            const d1 = (s1[i].depth + s1[i+1].depth) / 2;
            const d2 = (s2[i].depth + s2[i+1].depth) / 2;
            allSegs.push({ p: s1[i], q: s1[i+1], d: d1 });
            allSegs.push({ p: s2[i], q: s2[i+1], d: d2 });
          }
          allSegs.sort((a, b) => a.d - b.d); // painter's algorithm

          // ── Rungs ─────────────────────────────────────────────────────────
          const BASES = ['A','T','G','C','A','T','G','C'];
          for (let i = 0; i <= segs; i += 5) {
            const a = s1[i], b = s2[i];
            const d = (a.depth + b.depth) / 2;
            ctx.globalAlpha = alpha * (0.12 + d * 0.4);
            ctx.strokeStyle = '#0d0d0d';
            ctx.lineWidth   = 1.5 + d * 3;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
            if (i % 10 === 0) {
              ctx.globalAlpha = alpha * d * 0.6;
              ctx.fillStyle   = '#000';
              ctx.font        = 'bold 9px monospace';
              ctx.textAlign   = 'center';
              ctx.fillText(BASES[(i / 5) % BASES.length], (a.x + b.x) / 2, a.y - 1);
              ctx.textAlign   = 'left';
            }
          }

          // ── Strands: draw each micro-segment with depth-scaled lineWidth ──
          for (const seg of allSegs) {
            const lw = 3 + seg.d * 15;   // 3px at back → 18px at front
            const a  = 0.18 + seg.d * 0.72;

            ctx.shadowBlur  = seg.d > 0.65 ? 5 : 0;
            ctx.shadowColor = 'rgba(0,0,0,0.4)';
            ctx.globalAlpha = alpha * a;
            ctx.lineWidth   = lw;
            ctx.strokeStyle = '#111';
            ctx.beginPath();
            ctx.moveTo(seg.p.x, seg.p.y);
            ctx.lineTo(seg.q.x, seg.q.y);
            ctx.stroke();

            // Specular highlight on front-facing segments
            if (seg.d > 0.5) {
              ctx.shadowBlur  = 0;
              ctx.globalAlpha = alpha * (seg.d - 0.5) * 0.55;
              ctx.lineWidth   = Math.max(1.5, lw * 0.22);
              ctx.strokeStyle = 'rgba(95,95,95,0.8)';
              ctx.beginPath();
              ctx.moveTo(seg.p.x - 2.5, seg.p.y);
              ctx.lineTo(seg.q.x - 2.5, seg.q.y);
              ctx.stroke();
            }
          }
          ctx.shadowBlur = 0;
        }

        // ── Animation loop ────────────────────────────────────────────────
        function animate() {
          requestAnimationFrame(animate);
          time += 0.016;

          ctx.clearRect(0, 0, W, H);
          ctx.globalAlpha = 1;

          // Helix fades out between scroll 0.25 → 0.6
          const helixA = scrollP < 0.25 ? 1
                       : scrollP < 0.6  ? 1 - (scrollP - 0.25) / 0.35
                       : 0;

          // Code rain fades in between scroll 0.35 → 0.7
          const rainA  = scrollP < 0.35 ? 0
                       : scrollP < 0.7  ? (scrollP - 0.35) / 0.35
                       : 1;

          drawHelix(helixA);
          drawRain(rainA);
          ctx.globalAlpha = 1;
        }

        resize();
        animate();
      })();

      // Reveal animations
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap !== 'undefined') {
          gsap.utils.toArray('.reveal').forEach((el) => {
            gsap.fromTo(el, 
              { opacity: 0, y: 50 },
              {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: 'power3.out',
                scrollTrigger: {
                  trigger: el,
                  start: 'top 80%',
                }
              }
            );
          });
        }
      });
    </script>
  </body>
</html>
