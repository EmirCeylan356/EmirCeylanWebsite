---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;900&family=Inter:wght@400;500;600;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#f40c3f] text-black min-h-screen">
    <div class="fixed inset-0 grid-bg pointer-events-none z-0"></div>

    <!-- DNA Helix canvas background -->
    <canvas id="dna-canvas" class="fixed inset-0 pointer-events-none z-[1]" style="mix-blend-mode: multiply; opacity: 0.62;"></canvas>

    <canvas id="fisheye-canvas" class="fixed pointer-events-none z-[2]" style="display:none;"></canvas>
    
    <!-- Contrast Toggle -->
    <button 
      id="contrast-toggle" 
      class="fixed top-20 right-4 z-50 px-4 py-2 bg-black text-white font-bold text-sm border-2 border-black hover:bg-white hover:text-black transition-colors"
    >
      CONTRAST
    </button>
    
    <div id="main-content" class="relative z-10 min-h-screen flex flex-col">
      <slot />
    </div>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script is:inline>
      // Initialize GSAP
      if (typeof gsap !== 'undefined' && gsap.registerPlugin) {
        gsap.registerPlugin(ScrollTrigger);
      }
      
      // Contrast toggle
      let contrastMode = false;
      const toggle = document.getElementById('contrast-toggle');
      const body = document.body;
      const header = document.querySelector('header');
      
      if (toggle) {
        toggle.addEventListener('click', () => {
          contrastMode = !contrastMode;
          if (contrastMode) {
            body.classList.add('contrast-mode');
            body.style.backgroundColor = '#000';
            body.style.color = '#00ff00';
            if (header) header.style.backgroundColor = '#000';
          } else {
            body.classList.remove('contrast-mode');
            body.style.backgroundColor = '#f40c3f';
            body.style.color = '#000';
            if (header) header.style.backgroundColor = '#f40c3f';
          }
        });
      }
      
      // Fisheye grid distortion canvas
      const fisheyeCanvas = document.getElementById('fisheye-canvas');
      if (fisheyeCanvas) {
        const ctx = fisheyeCanvas.getContext('2d');
        const R = 180;       // lens radius px
        const SIZE = R * 2 + 4;
        const GRID = 50;     // must match .grid-bg background-size
        fisheyeCanvas.width = SIZE;
        fisheyeCanvas.height = SIZE;
        let mx = -1000, my = -1000, raf = null;

        function drawFisheye() {
          const cx = SIZE / 2, cy = SIZE / 2;
          const isContrast = document.body.classList.contains('contrast-mode');
          const bgFill  = isContrast ? '#000000' : '#f40c3f';
          const lineCol = isContrast ? 'rgba(0,255,0,0.2)' : 'rgba(0,0,0,0.15)';

          ctx.clearRect(0, 0, SIZE, SIZE);

          // Clip to circle
          ctx.save();
          ctx.beginPath();
          ctx.arc(cx, cy, R, 0, Math.PI * 2);
          ctx.clip();

          // Cover static grid underneath
          ctx.fillStyle = bgFill;
          ctx.fillRect(0, 0, SIZE, SIZE);

          ctx.strokeStyle = lineCol;
          ctx.lineWidth = 1;

          // Align grid to cursor position so lines match the static background
          const ox = ((mx % GRID) + GRID) % GRID;
          const oy = ((my % GRID) + GRID) % GRID;

          // Barrel warp: points pushed outward from center, strongest at centre
          function warp(px, py) {
            const dx = px - cx, dy = py - cy;
            const r = Math.sqrt(dx * dx + dy * dy);
            if (r >= R || r < 0.01) return [px, py];
            const n = r / R;
            const rOut = r * (1 + Math.pow(1 - n, 2.2) * 0.9);
            return [cx + (dx / r) * rOut, cy + (dy / r) * rOut];
          }

          // Cover enough lines across the full lens diameter (R can span ~4 grid cells)
          const spread = (Math.ceil(R / GRID) + 1) * GRID;

          // Trace vertical grid lines through the lens
          for (let gx = -ox - spread; gx <= R + GRID; gx += GRID) {
            ctx.beginPath();
            let first = true;
            for (let gy = -R; gy <= R; gy += 3) {
              const [px, py] = warp(cx + gx, cy + gy);
              first ? (ctx.moveTo(px, py), first = false) : ctx.lineTo(px, py);
            }
            ctx.stroke();
          }

          // Trace horizontal grid lines through the lens
          for (let gy = -oy - spread; gy <= R + GRID; gy += GRID) {
            ctx.beginPath();
            let first = true;
            for (let gx = -R; gx <= R; gx += 3) {
              const [px, py] = warp(cx + gx, cy + gy);
              first ? (ctx.moveTo(px, py), first = false) : ctx.lineTo(px, py);
            }
            ctx.stroke();
          }

          ctx.restore();
          // No rim border

          raf = null;
        }

        document.addEventListener('mousemove', (e) => {
          mx = e.clientX; my = e.clientY;
          fisheyeCanvas.style.left = (mx - SIZE / 2) + 'px';
          fisheyeCanvas.style.top  = (my - SIZE / 2) + 'px';
          fisheyeCanvas.style.display = 'block';
          if (!raf) raf = requestAnimationFrame(drawFisheye);
        });
        document.addEventListener('mouseleave', () => { fisheyeCanvas.style.display = 'none'; });
      }

      // ── DNA Helix → Code Rain canvas background ──────────────────────────
      (function() {
        const cv = document.getElementById('dna-canvas');
        if (!cv) return;
        const ctx = cv.getContext('2d');

        let W, H;
        function resize() {
          W = cv.width  = window.innerWidth;
          H = cv.height = window.innerHeight;
          initRain();
        }
        window.addEventListener('resize', resize);

        // ── scroll progress (0→1) ─────────────────────────────────────────
        let scrollP = 0;
        window.addEventListener('scroll', () => {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          scrollP = max > 0 ? Math.min(window.scrollY / max, 1) : 0;
        }, { passive: true });

        // ── Code rain columns ─────────────────────────────────────────────
        const CHARS = 'ATCGATCG01010101{}[]();=></>const let fn'.split('');
        let cols = [];
        function initRain() {
          cols = [];
          const spacing = 28;
          const n = Math.floor(W / spacing);
          for (let i = 0; i < n; i++) {
            cols.push({
              x: i * spacing + spacing / 2,
              y: Math.random() * H,
              speed: 0.8 + Math.random() * 1.4,
              trail: Math.floor(10 + Math.random() * 14),
              chars: Array.from({ length: 24 }, () => CHARS[Math.floor(Math.random() * CHARS.length)]),
              tick: 0,
            });
          }
        }

        function drawRain(alpha) {
          if (alpha <= 0) return;
          cols.forEach(col => {
            col.y += col.speed;
            if (col.y > H + col.trail * 18) col.y = -col.trail * 18;
            col.tick++;
            if (col.tick % 8 === 0) {
              const idx = Math.floor(Math.random() * col.chars.length);
              col.chars[idx] = CHARS[Math.floor(Math.random() * CHARS.length)];
            }
            col.chars.forEach((ch, i) => {
              const y = col.y - i * 18;
              if (y < 0 || y > H) return;
              const fade = 1 - i / col.trail;
              const bright = i === 0 ? 1 : fade * 0.8;
              ctx.globalAlpha = alpha * bright;
              ctx.fillStyle = i === 0 ? '#fff' : '#000';
              ctx.font = `${i === 0 ? 13 : 11}px monospace`;
              ctx.fillText(ch, col.x, y);
            });
          });
        }

        // ── DNA Helix ─────────────────────────────────────────────────────
        let time = 0;

        function drawHelix(alpha) {
          if (alpha <= 0) return;
          const cx   = W / 2;
          const amp  = Math.min(W * 0.13, 130);   // strand spread
          const freq = 2.8;                         // coils visible
          const segs = 140;
          const rot  = time * 0.55;                // spin speed

          const s1 = [], s2 = [];
          for (let i = 0; i <= segs; i++) {
            const t     = i / segs;
            const y     = -10 + t * (H + 20);
            const angle = t * Math.PI * 2 * freq + rot;
            const cosA  = Math.cos(angle);
            const depth = (cosA + 1) / 2;          // 0 = back, 1 = front
            s1.push({ x: cx + amp * cosA,  y, depth });
            s2.push({ x: cx - amp * cosA,  y, depth: 1 - depth });
          }

          // Rungs + base pair labels
          const BASES = ['A','T','G','C','A','T','G','C'];
          for (let i = 0; i <= segs; i += 5) {
            const a = s1[i], b = s2[i];
            const d = (a.depth + b.depth) / 2;
            ctx.globalAlpha = alpha * (d * 0.65 + 0.18);
            ctx.strokeStyle = '#000';
            ctx.lineWidth   = 2 + d * 2.5;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();

            // Label at rung midpoint when facing front-ish
            if (i % 10 === 0 && d > 0.55) {
              const mx = (a.x + b.x) / 2;
              const ch = BASES[(i / 5) % BASES.length];
              ctx.globalAlpha = alpha * d * 0.9;
              ctx.fillStyle   = '#000';
              ctx.font        = 'bold 9px monospace';
              ctx.textAlign   = 'center';
              ctx.fillText(ch, mx, a.y - 2);
              ctx.textAlign   = 'left';
            }
          }

          // Back strand (lower z-order, dimmer)
          ctx.globalAlpha = alpha * 0.5;
          ctx.strokeStyle = '#000';
          ctx.lineWidth   = 3;
          ctx.beginPath();
          s1.forEach((p, i) => {
            if (p.depth < 0.5) { i === 0 || p.depth < s1[i-1]?.depth ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y); }
            else ctx.moveTo(p.x, p.y);
          });
          ctx.stroke();

          ctx.beginPath();
          s2.forEach((p, i) => {
            if (p.depth < 0.5) { i === 0 || p.depth < s2[i-1]?.depth ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y); }
            else ctx.moveTo(p.x, p.y);
          });
          ctx.stroke();

          // Front strand (solid)
          function drawStrand(pts, baseAlpha) {
            let inSeg = false;
            ctx.beginPath();
            pts.forEach((p, i) => {
              if (p.depth >= 0.5) {
                ctx.globalAlpha = baseAlpha * alpha * (0.55 + p.depth * 0.45);
                inSeg ? ctx.lineTo(p.x, p.y) : ctx.moveTo(p.x, p.y);
                inSeg = true;
              } else {
                if (inSeg) ctx.stroke();
                ctx.beginPath();
                inSeg = false;
              }
            });
            if (inSeg) ctx.stroke();
          }

          ctx.strokeStyle = '#000';
          ctx.lineWidth   = 4.5;
          drawStrand(s1, 1);
          ctx.lineWidth   = 3.5;
          drawStrand(s2, 0.8);
        }

        // ── Animation loop ────────────────────────────────────────────────
        function animate() {
          requestAnimationFrame(animate);
          time += 0.016;

          ctx.clearRect(0, 0, W, H);
          ctx.globalAlpha = 1;

          // Helix fades out between scroll 0.25 → 0.6
          const helixA = scrollP < 0.25 ? 1
                       : scrollP < 0.6  ? 1 - (scrollP - 0.25) / 0.35
                       : 0;

          // Code rain fades in between scroll 0.35 → 0.7
          const rainA  = scrollP < 0.35 ? 0
                       : scrollP < 0.7  ? (scrollP - 0.35) / 0.35
                       : 1;

          drawHelix(helixA);
          drawRain(rainA);
          ctx.globalAlpha = 1;
        }

        resize();
        animate();
      })();

      // Reveal animations
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap !== 'undefined') {
          gsap.utils.toArray('.reveal').forEach((el) => {
            gsap.fromTo(el, 
              { opacity: 0, y: 50 },
              {
                opacity: 1,
                y: 0,
                duration: 0.8,
                ease: 'power3.out',
                scrollTrigger: {
                  trigger: el,
                  start: 'top 80%',
                }
              }
            );
          });
        }
      });
    </script>
  </body>
</html>
